# ============================================================
# DondeAnime - Variables de entorno (PLANTILLA)
# ============================================================
# Copiar este archivo a ".env" y rellenar con valores reales.
# NUNCA subir el archivo .env real al repositorio.
# ============================================================

# ----- APIs externas -----

# TMDb (https://www.themoviedb.org/settings/api)
# Crear cuenta gratis, ir a Settings > API, solicitar clave de tipo "Developer"
TMDB_API_KEY=tu_clave_tmdb_aqui
TMDB_API_BASE=https://api.themoviedb.org/3

# AniList NO requiere clave para queries públicas
ANILIST_API_BASE=https://graphql.anilist.co

# Embeddings semanticos (opcional, apagado por defecto)
EMBEDDINGS_ENABLED=false
EMBEDDING_MODEL=
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=

# LLM (Anthropic API) para traducir/redactar noticias (opcional, apagado por defecto)
LLM_ENABLED=false
LLM_MODEL=claude-haiku-4-5
LLM_API_BASE=https://api.anthropic.com
ANTHROPIC_API_KEY=
LLM_MAX_OUTPUT_TOKENS=1500

# Trakt.tv OAuth (opcional)
TRAKT_ENABLED=false
TRAKT_API_BASE=https://api.trakt.tv
TRAKT_OAUTH_BASE=https://trakt.tv
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:8080/api/trakt/oauth/callback
TRAKT_TOKEN_ENCRYPTION_SECRET=
# Firma los tokens que ligan /api/trakt/watched y /api/trakt/sync a la cuenta
# vinculada. Vacío = se usa JWT_SECRET.
TRAKT_ACCESS_TOKEN_SECRET=

# ----- Backups -----

# Claves públicas age (separadas por espacio) para cifrar los dumps antes de
# subirlos a R2. Vacío = sin cifrar. Ver DEPLOY.md "Cifrado de backups".
BACKUP_AGE_RECIPIENTS=

# ----- Base de datos -----

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dondeanime
POSTGRES_USER=dondeanime_user
POSTGRES_PASSWORD=cambiar_en_local

# ----- Backend Spring Boot -----

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ----- Admin local -----
# SOLO para desarrollo local. En producción NUNCA se usa este archivo:
# application-prod.properties exige ADMIN_PASSWORD real (sin default) y
# docker-compose.prod.yml fuerza el perfil prod. admin/admin aquí es
# inofensivo porque jamás llega a producción.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,https://dondeanime.com,https://www.dondeanime.com

# ----- Frontend Astro -----

PUBLIC_API_URL=http://localhost:8080
PUBLIC_SITE_URL=https://www.dondeanime.com
PUBLIC_CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321,https://dondeanime.com,https://www.dondeanime.com

# ----- Alertas email -----

# En local RESEND_ENABLED=false evita mandar correos reales.
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=alertas@dondeanime.com
JWT_SECRET=dev-secret-change-me
# Secretos separados por tipo de token (vacío = se usa JWT_SECRET):
# sesiones del panel admin y access tokens premium.
ADMIN_JWT_SECRET=
PREMIUM_ACCESS_TOKEN_SECRET=

# ----- Web Push -----

# Generar con: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@dondeanime.com
PUBLIC_VAPID_PUBLIC_KEY=

# --- Stripe Premium (Sprint 15) ---
# Solo claves de test. Reemplazar por claves live al activar Premium.
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REEMPLAZAR
STRIPE_PRICE_ID=price_REEMPLAZAR
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR
STRIPE_SUCCESS_URL=http://localhost:4321/premium?success=1
STRIPE_CANCEL_URL=http://localhost:4321/premium?canceled=1
STRIPE_PORTAL_RETURN_URL=http://localhost:4321/premium

# ----- Cron jobs -----

# Cada cuánto refrescar el catálogo desde las APIs (horas)
CATALOG_REFRESH_HOURS=12

# ----- Monetización (rellenar cuando aplique) -----

PLAUSIBLE_ENABLED=false
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=dondeanime.com
PUBLIC_PLAUSIBLE_ENABLED=false
PUBLIC_PLAUSIBLE_DOMAIN=dondeanime.com
PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

ADSENSE_ENABLED=false
PUBLIC_ADSENSE_ENABLED=false
PUBLIC_ADSENSE_CLIENT_ID=
PUBLIC_ADSENSE_SIDEBAR_SLOT=
PUBLIC_ADSENSE_INLINE_SLOT=
PUBLIC_ADSENSE_FOOTER_SLOT=
