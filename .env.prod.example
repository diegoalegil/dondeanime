# ============================================================
# DondeAnime - Variables de entorno PRODUCCIÓN (PLANTILLA)
# ------------------------------------------------------------
# Copiar este archivo a .env.prod EN EL VPS (no en local, no en
# repo) y rellenar con los valores reales.
#
# NUNCA commitear .env.prod al repositorio. Ya está en .gitignore.
# ============================================================

# --- Postgres ---
POSTGRES_DB=dondeanime
POSTGRES_USER=dondeanime_user
# Generar una contraseña fuerte y única. Ejemplo en el VPS:
#   openssl rand -base64 32
POSTGRES_PASSWORD=GENERA_UNA_CONTRASEÑA_FUERTE_AQUÍ

# --- TMDb ---
# El mismo token v4 que tienes en .env local. Empieza por eyJ...
TMDB_API_KEY=eyJ_TU_TOKEN_AQUÍ

# --- Vercel Deploy Hook ---
# URL del Deploy Hook de Vercel. Se rellena DESPUÉS de configurar
# Vercel: Project → Settings → Git → Deploy Hooks → Create.
# Hasta entonces, dejar vacío. El backend no llama si está vacío.
VERCEL_DEPLOY_HOOK=

# --- Scheduling ---
# En prod siempre true. Configurable por si quieres pausar el
# scheduler temporalmente sin recompilar (ej. mientras debuggas
# algo, evitas que el cron dispare al medio).
SCHEDULING_ENABLED=true

# --- Admin (Sprint 1) ---
# Generar una contraseña fuerte. Ejemplo:
#   openssl rand -base64 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GENERA_UNA_CONTRASEÑA_ADMIN_AQUÍ
ADMIN_CORS_ALLOWED_ORIGINS=https://dondeanime.com,https://www.dondeanime.com

# --- Alertas email (Sprint 2) ---
# JWT_SECRET firma tokens de confirmación/baja. Generar en el VPS:
#   openssl rand -base64 64
JWT_SECRET=GENERA_UN_SECRETO_JWT_FUERTE_AQUÍ
RESEND_ENABLED=true
RESEND_API_KEY=re_TU_API_KEY_DE_RESEND_AQUÍ
RESEND_FROM_EMAIL=alertas@dondeanime.com
PUBLIC_API_URL=https://api.dondeanime.com
PUBLIC_CORS_ALLOWED_ORIGINS=https://dondeanime.com,https://www.dondeanime.com

# --- Alertas críticas Telegram (Sprint 6) ---
# Crear bot con BotFather, obtener chat id y activar solo en prod.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Monetización / analítica (Sprint 3) ---
# Plausible: el script público puede activarse en Vercel. La API key
# solo es necesaria para que /api/admin/dashboard muestre top páginas.
PLAUSIBLE_ENABLED=false
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=dondeanime.com
PUBLIC_PLAUSIBLE_ENABLED=false
PUBLIC_PLAUSIBLE_DOMAIN=dondeanime.com
PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# AdSense queda preparado pero apagado hasta que Diego lo active.
ADSENSE_ENABLED=false
PUBLIC_ADSENSE_ENABLED=false
PUBLIC_ADSENSE_CLIENT_ID=
PUBLIC_ADSENSE_SIDEBAR_SLOT=
PUBLIC_ADSENSE_INLINE_SLOT=
PUBLIC_ADSENSE_FOOTER_SLOT=

# --- Backups Postgres + Cloudflare R2 (Sprint 4) ---
# El script scripts/backup-postgres-r2.sh crea backup local siempre.
# Si rellenas R2_*, además sube el .sql.gz y su checksum a R2.
BACKUP_DIR=/opt/dondeanime/backups
BACKUP_RETENTION_DAYS=30
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PREFIX=postgres
