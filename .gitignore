# NOTA: Renombrar a ".gitignore" (con punto delante) al copiar al repo real.
# macOS y Windows ocultan los archivos que empiezan por punto, por eso aquí
# se entrega con extensión .txt para que lo veas y puedas leerlo.

# ===== Variables de entorno y secretos =====
.env
.env.local
.env.production
.env.development
.env.prod
*.pem
*.key
secrets/

# ===== Java / Maven / Gradle =====
target/
build/
*.class
*.jar
*.war
*.ear
*.iml
hs_err_pid*.log
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ===== Node.js =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ===== Astro =====
dist/
.astro/
.output/

# ===== Next.js (por si se cambia de framework) =====
.next/
out/

# ===== Bases de datos locales =====
*.sqlite
*.db
*.sql.gz
data/postgres/
pgdata/

# ===== IDEs =====
.idea/
*.iml
.vscode/
*.swp
*.swo
.project
.classpath
.settings/

# ===== Sistema operativo =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===== Logs =====
logs/
*.log

# ===== Caches y temporales =====
.cache/
.tmp/
tmp/
*.tmp
*.bak

# ===== Cobertura de tests =====
coverage/
.nyc_output/
.lighthouseci/
playwright-report/
test-results/
frontend/lighthouse-report.json

# ===== Docker (si se mete más adelante) =====
docker-compose.override.yml

# ===== Exclusivos del proyecto =====
scripts/output/
backups/
