---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import AffiliateTrackingScript from '@/components/analytics/AffiliateTrackingScript.astro';
import SkeletonRow from '@/components/ui/SkeletonRow.astro';
import InstallPromotion from '@/components/pwa/InstallPromotion.astro';
import { localeFromPath, setLocale, t } from '@/i18n';
import { localizedEnPath, spanishPathFromLocalized } from '@/lib/localizedRoutes';
import geistLatinUrl from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  locale?: string;
  suppressAlternates?: boolean;
  noindex?: boolean;
}

const props = Astro.props;
const activeLocale = localeFromPath(Astro.url.pathname);
setLocale(activeLocale);
const publicLanguageRoute = !Astro.url.pathname.startsWith('/admin') && !Astro.url.pathname.startsWith('/api');
const spanishPath = spanishPathFromLocalized(Astro.url.pathname);
// Para el redirect por preferencia de idioma usamos localizedEnPath (devuelve
// null si la pagina inglesa NO existe), NO localizedPath (que inventa un
// /en/... de respaldo). Asi un usuario con cookie EN en una pagina solo-ES
// (p.ej. /buscar) se queda donde esta en vez de ser rebotado a /en/buscar -> 404.
const englishPath = localizedEnPath(spanishPath);
const languageRoutes = {
  es: spanishPath,
  en: englishPath ?? spanishPath,
};
const plausibleEnabled = import.meta.env.PUBLIC_PLAUSIBLE_ENABLED === 'true';
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN ?? 'dondeanime.com';
const plausibleScriptUrl = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_URL ?? 'https://plausible.io/js/script.js';
const adsenseEnabled =
  import.meta.env.ADSENSE_ENABLED === 'true' ||
  import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const adsenseClientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
// Verificacion de Google Search Console por meta-tag: define PUBLIC_GSC_VERIFICATION
// en Vercel con el codigo que da GSC y la etiqueta aparece (no hace falta DNS).
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
---
<!doctype html>
<html lang={activeLocale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <!-- Las cover/banner de anime (LCP) salen de s4.anilist.co; los logos de
         provider de image.tmdb.org. Preconnect acelera la primera imagen. -->
    <link rel="preconnect" href="https://s4.anilist.co" crossorigin />
    <link rel="dns-prefetch" href="https://s4.anilist.co" />
    <link rel="dns-prefetch" href="https://image.tmdb.org" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/pwa/icons/apple-touch-icon.png" />
    <meta name="theme-color" content="#0E1020" />
    <ClientRouter />
    <link rel="preload" href={geistLatinUrl} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // Anti-FOIT: apply saved theme before first paint.
      try {
        const stored = localStorage.getItem('dondeanime-theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      } catch (e) {}
    </script>
    <script is:inline>
      // Reintento escalonado de portadas. El CDN de AniList estrangula cuando un
      // cliente pide muchas a la vez (una rejilla entera): la primera carga da
      // error y, hasta ahora, caiamos directos al placeholder de marca, dejando
      // TODA la rejilla con la mascota. El throttle es por rafaga y transitorio,
      // y la portada queda cacheada en Cloudflare; reintentar la MISMA URL tras
      // un retardo con jitter acierta (cache HIT). Definido en <head> para que
      // exista antes de que cualquier <img> dispare su onerror.
      window.__coverError = function (img) {
        try {
          var n = img.__coverTries || 0;
          var fb = img.getAttribute('data-cover-fallback');
          if (n >= 2) {
            img.onerror = null;
            img.removeAttribute('srcset');
            img.removeAttribute('sizes');
            if (fb) img.src = fb;
            return;
          }
          img.__coverTries = n + 1;
          var url = (img.getAttribute('data-cover-src') || img.getAttribute('src') || '').split('#')[0];
          img.removeAttribute('srcset');
          img.removeAttribute('sizes');
          // El fragmento #rN fuerza la recarga (src distinto) pero NO viaja al
          // servidor: misma URL real => cache HIT de Cloudflare, no golpea origen.
          setTimeout(function () { img.src = url + '#r' + img.__coverTries; }, 300 + Math.random() * 1400 * (n + 1));
        } catch (e) {}
      };
    </script>
    {publicLanguageRoute && (
      <script is:inline define:vars={{ languageRoutes }}>
        // Solo respetamos la preferencia EXPLÍCITA del usuario (cookie del
        // selector de idioma). Nada de redirigir por navigator.language:
        // Googlebot renderiza con en-US y almacenamiento vacío, así que las
        // páginas ES parecían redirecciones (y las solo-ES acababan en /en/*
        // inventadas que daban 404).
        try {
          const normalizePath = (path) => path.replace(/\/+$/, '') || '/';
          const withLocationSuffix = (path) => `${path}${window.location.search}${window.location.hash}`;
          const cookieMatch = document.cookie.match(/(?:^|;\s*)dondeanime-locale=(es|en)(?:;|$)/);
          const preferredLocale = cookieMatch?.[1];
          const currentPath = normalizePath(window.location.pathname);
          const targetForPreference = preferredLocale ? normalizePath(languageRoutes[preferredLocale]) : null;

          if (preferredLocale && targetForPreference && currentPath !== targetForPreference) {
            window.location.replace(withLocationSuffix(languageRoutes[preferredLocale]));
          }
        } catch (e) {}
      </script>
    )}
    <script is:inline>
      (() => {
        if (window.__dondeanimeNavigationSkeletonBound) return;
        window.__dondeanimeNavigationSkeletonBound = true;

        let hideTimer;
        let showFrame;

        const skeleton = () => document.querySelector('[data-navigation-skeleton]');

        const showSkeleton = () => {
          const el = skeleton();
          if (!el) return;
          window.clearTimeout(hideTimer);
          window.cancelAnimationFrame(showFrame);
          el.hidden = false;
          el.setAttribute('aria-busy', 'true');
          showFrame = requestAnimationFrame(() => {
            el.dataset.visible = 'true';
          });
        };

        const hideSkeleton = () => {
          const el = skeleton();
          if (!el) return;
          window.cancelAnimationFrame(showFrame);
          el.dataset.visible = 'false';
          el.removeAttribute('aria-busy');
          hideTimer = window.setTimeout(() => {
            el.hidden = true;
          }, 180);
        };

        document.addEventListener('astro:before-preparation', showSkeleton);
        document.addEventListener('astro:after-swap', hideSkeleton);
        document.addEventListener('astro:page-load', hideSkeleton);
        window.addEventListener('pageshow', hideSkeleton);
      })();
    </script>
    <SEOHead {...props} />
    {plausibleEnabled && (
      <>
        <script is:inline>
          window.plausible = window.plausible || function() {
            (window.plausible.q = window.plausible.q || []).push(arguments);
          };
        </script>
        <script defer data-domain={plausibleDomain} src={plausibleScriptUrl}></script>
      </>
    )}
    {adsenseEnabled && adsenseClientId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    )}
    <slot name="head" />
  </head>
  <body class="bg-surface-0 text-fg-primary font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:border focus:border-surface-2 focus:bg-surface-1 focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-fg-primary focus:outline-none"
    >
      {t('layout.skipToContent')}
    </a>
    <Header />
    <div
      data-navigation-skeleton
      hidden
      class="fixed inset-x-0 top-[3.75rem] z-40 border-b border-surface-2 bg-surface-0/95 shadow-2xl shadow-black/25 backdrop-blur-md"
    >
      <SkeletonRow count={6} />
    </div>
    <main id="main" tabindex="-1" class="min-h-[calc(100vh-8rem)]" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <InstallPromotion />
    <AffiliateTrackingScript />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
