---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnimeGrid from '@/components/anime/AnimeGrid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getGenres, getAnimeByGenre, getProviders, requireNonEmpty } from '@/lib/api';
import { buildItemListSchema, absoluteUrl } from '@/lib/seo';
import { localizedGenreName } from '@/lib/genres';
import { getPlatform, isHiddenVariant } from '@/lib/platforms';
import { localizedPath } from '@/lib/localizedRoutes';
import { setLocale, t } from '@/i18n';

setLocale('es');

export async function getStaticPaths() {
  const genres = requireNonEmpty('géneros', await getGenres());
  return genres.map((g) => ({
    params: { genero: g.slug },
    props: { genreName: g.name, total: g.animeCount },
  }));
}

const { genero } = Astro.params;
const { genreName, total } = Astro.props;
const genreLabel = localizedGenreName(genero!, genreName);

const anime = await getAnimeByGenre(genero!);
const previewTitles = anime.slice(0, 5).map((a) => a.titleEnglish || a.titleRomaji).join(', ');

const seoTitle = t('genre.seo.title', { genre: genreLabel, total });
const seoDescription = t('genre.seo.description', {
  genre: genreLabel,
  titles: previewTitles,
  remaining: Math.max(0, total - 5),
});

const pageUrl = absoluteUrl(`/genero/${genero}`);
const itemListSchema = buildItemListSchema(
  anime.slice(0, 30).map((a) => ({
    name: a.titleEnglish || a.titleRomaji,
    url: absoluteUrl(`/anime/${a.slug}`),
  })),
  pageUrl,
  t('genre.schema.name', { genre: genreLabel }),
);

// Combos género×plataforma: enlazamos SOLO los que existen. El combo se genera
// para top-7 géneros × top-5 providers (ver anime/[genero]/en/[plataforma]);
// replicamos esa MISMA lógica (mismas llamadas, mismo build) para no crear
// enlaces a páginas inexistentes (404).
const isComboGenre = (await getGenres()).slice(0, 7).some((g) => g.slug === genero);
const comboProviders = isComboGenre
  ? (await getProviders()).filter((p) => !isHiddenVariant(p.slug)).slice(0, 5)
  : [];
---
<BaseLayout title={seoTitle} description={seoDescription} image={absoluteUrl('/og-genero.png')}>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.genres'), url: '/' },
      { name: genreLabel, url: `/genero/${genero}` },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <p class="text-xs uppercase tracking-wide text-accent-violet">{t('genre.eyebrow')}</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">
      {t('genre.headingPrefix')} <span class="brand-gradient-text">{genreLabel}</span>
    </h1>
    <p class="mt-4 text-lg text-fg-secondary">
      {t('genre.count', { count: anime.length, plural: anime.length === 1 ? '' : 's' })}
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    {anime.length === 0 ? (
      <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
        {t('genre.empty')}
      </p>
    ) : (
      <AnimeGrid anime={anime} />
    )}
  </section>

  {comboProviders.length > 0 && (
    <section class="mx-auto max-w-6xl border-t border-surface-2 px-4 pt-10 pb-20">
      <h2 class="text-2xl font-semibold tracking-tight">{t('genre.byPlatform.heading', { genre: genreLabel })}</h2>
      <ul class="mt-5 flex flex-wrap gap-2">
        {comboProviders.map((p) => (
          <li>
            <a
              href={localizedPath(`/anime/${genero}/en/${p.slug}`)}
              class="inline-flex rounded-full border border-surface-2 bg-surface-1 px-3 py-1.5 text-sm text-fg-secondary transition-colors hover:border-accent-violet/60 hover:text-fg-primary"
            >
              {t('genre.byPlatform.cta', { genre: genreLabel, platform: getPlatform(p.slug)?.name ?? p.providerName })}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>
