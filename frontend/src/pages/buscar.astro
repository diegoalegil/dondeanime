---
import AnimeCard from '@/components/anime/AnimeCard.astro';
import AnimeChatSearch from '@/components/chat/AnimeChatSearch.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import WatchedFilter from '@/components/trakt/WatchedFilter.astro';
import { getAllAnime } from '@/lib/api';

// Pre-renderizar el catálogo entero aquí pesaba ~1,5 MB de HTML. Servimos
// solo los más populares y la búsqueda hidrata contra /search-index.json
// (que ya se genera en cada build), cubriendo TODO el catálogo.
const POPULAR_COUNT = 24;
const anime = await getAllAnime();
const popular = [...anime]
  .sort((a, b) => (b.popularity ?? 0) - (a.popularity ?? 0))
  .slice(0, POPULAR_COUNT);
---
<BaseLayout
  title="Buscar anime | DondeAnime"
  description="Busca anime por titulo y abre su ficha para consultar plataformas de streaming."
  noindex={true}
>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-accent-violet">Busqueda</p>
        <h1 class="mt-2 text-3xl font-semibold text-fg-primary md:text-4xl">Buscar anime</h1>
      </div>
      <form action="/buscar" method="get" role="search" class="w-full max-w-md">
        <label class="sr-only" for="fallback-search-input">Buscar anime</label>
        <input
          id="fallback-search-input"
          name="q"
          type="search"
          autocomplete="off"
          placeholder="Buscar anime..."
          class="w-full rounded-md border border-surface-2 bg-surface-1 px-4 py-2 text-sm text-fg-primary placeholder:text-fg-muted focus:outline-none focus:ring-2 focus:ring-accent-violet"
          data-search-page-input
        />
      </form>
    </div>

    <div class="-mx-4">
      <AnimeChatSearch />
      <WatchedFilter />
    </div>

    <p class="mb-5 text-sm text-fg-muted" data-search-page-count aria-live="polite">
      Mostrando los {popular.length} mas populares. Escribe para buscar en todo el catalogo.
    </p>

    <div
      class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 md:gap-6 lg:grid-cols-5 xl:grid-cols-6"
      data-search-popular-grid
    >
      {popular.map((item) => (
        <div
          data-search-page-card
          data-anime-filter-item
          data-anime-slug={item.slug}
        >
          <AnimeCard anime={item} />
        </div>
      ))}
    </div>

    <div
      class="hidden grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 md:gap-6 lg:grid-cols-5 xl:grid-cols-6"
      data-search-results-grid
    ></div>

    <div
      class="flex-col items-center justify-center gap-4 py-12 text-center"
      style="display:none"
      data-search-empty
    >
      <img
        src="/mascota-vacio.webp"
        alt=""
        width="560"
        height="620"
        loading="lazy"
        decoding="async"
        class="h-40 w-auto drop-shadow-[0_8px_24px_rgba(0,0,0,0.45)]"
      />
      <p class="max-w-sm text-fg-secondary">
        No encontramos ningun anime con ese nombre. Prueba con otro titulo.
      </p>
    </div>
  </section>

  <script>
    interface SearchIndexEntry {
      slug: string;
      en: string;
      jp: string;
      year: number | null;
      format: string;
      cover: string;
    }

    const normalize = (value: string) =>
      value.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

    const input = document.querySelector('[data-search-page-input]') as HTMLInputElement | null;
    const count = document.querySelector('[data-search-page-count]');
    const popularGrid = document.querySelector('[data-search-popular-grid]') as HTMLElement | null;
    const resultsGrid = document.querySelector('[data-search-results-grid]') as HTMLElement | null;
    const emptyState = document.querySelector('[data-search-empty]') as HTMLElement | null;
    const defaultCountText = count?.textContent ?? '';

    let index: Array<SearchIndexEntry & { haystack: string }> | null = null;
    let indexPromise: Promise<void> | null = null;

    const loadIndex = () => {
      indexPromise ??= fetch('/search-index.json')
        .then((response) => (response.ok ? response.json() : []))
        .then((data: SearchIndexEntry[]) => {
          index = data.map((entry) => ({
            ...entry,
            haystack: normalize(`${entry.en} ${entry.jp} ${entry.slug}`),
          }));
        })
        .catch(() => {
          index = [];
        });
      return indexPromise;
    };

    const renderCard = (entry: SearchIndexEntry) => {
      const wrapper = document.createElement('div');
      wrapper.setAttribute('data-search-page-card', '');
      wrapper.setAttribute('data-anime-filter-item', '');
      wrapper.setAttribute('data-anime-slug', entry.slug);

      const article = document.createElement('article');
      article.className = 'group';

      const link = document.createElement('a');
      link.href = `/anime/${entry.slug}`;
      link.className = 'block';

      const figure = document.createElement('div');
      figure.className = 'relative aspect-[2/3] overflow-hidden rounded-lg bg-surface-2';
      const img = document.createElement('img');
      img.src = entry.cover;
      img.alt = entry.en || entry.jp;
      img.loading = 'lazy';
      img.className =
        'h-full w-full object-cover transition-transform duration-300 group-hover:scale-105';
      img.addEventListener('error', () => {
        img.src = '/cover-placeholder.webp';
      }, { once: true });
      figure.appendChild(img);

      const meta = document.createElement('div');
      meta.className = 'mt-3';
      const title = document.createElement('h3');
      title.className =
        'line-clamp-2 text-sm font-semibold text-fg-primary transition-colors group-hover:text-accent-violet';
      title.textContent = entry.en || entry.jp;
      const details = document.createElement('p');
      details.className = 'mt-1 text-xs text-fg-muted';
      details.textContent = `${entry.year ?? '---'} · ${entry.format}`;
      meta.append(title, details);

      link.append(figure, meta);
      article.appendChild(link);
      wrapper.appendChild(article);
      return wrapper;
    };

    const applySearch = async () => {
      const query = normalize(input?.value ?? '').trim();

      if (query.length === 0) {
        popularGrid?.classList.remove('hidden');
        resultsGrid?.classList.add('hidden');
        if (resultsGrid) resultsGrid.replaceChildren();
        if (emptyState) emptyState.style.display = 'none';
        if (count) count.textContent = defaultCountText;
        return;
      }

      await loadIndex();
      const matches = (index ?? []).filter((entry) => entry.haystack.includes(query));

      popularGrid?.classList.add('hidden');
      if (resultsGrid) {
        resultsGrid.classList.remove('hidden');
        resultsGrid.replaceChildren(...matches.map(renderCard));
      }
      if (emptyState) emptyState.style.display = matches.length === 0 ? 'flex' : 'none';
      if (count) count.textContent = `${matches.length} resultados`;
    };

    if (input) {
      const params = new URLSearchParams(window.location.search);
      input.value = params.get('q') ?? '';
      input.addEventListener('input', () => void applySearch());
      input.addEventListener('focus', () => void loadIndex(), { once: true });
      void applySearch();
    }
  </script>
</BaseLayout>
