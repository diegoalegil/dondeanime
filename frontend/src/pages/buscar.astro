---
import AnimeCard from '@/components/anime/AnimeCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllAnime } from '@/lib/api';

const anime = await getAllAnime();
---
<BaseLayout
  title="Buscar anime | DondeAnime"
  description="Busca anime por titulo y abre su ficha para consultar plataformas de streaming."
>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-accent-violet">Busqueda</p>
        <h1 class="mt-2 text-3xl font-semibold text-fg-primary md:text-4xl">Buscar anime</h1>
      </div>
      <form action="/buscar" method="get" role="search" class="w-full max-w-md">
        <label class="sr-only" for="fallback-search-input">Buscar anime</label>
        <input
          id="fallback-search-input"
          name="q"
          type="search"
          autocomplete="off"
          placeholder="Buscar anime..."
          class="w-full rounded-md border border-surface-2 bg-surface-1 px-4 py-2 text-sm text-fg-primary placeholder:text-fg-muted focus:outline-none focus:ring-2 focus:ring-accent-violet"
          data-search-page-input
        />
      </form>
    </div>

    <p class="mb-5 text-sm text-fg-muted" data-search-page-count>
      {anime.length} resultados
    </p>

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 md:gap-6 lg:grid-cols-5 xl:grid-cols-6">
      {anime.map((item) => (
        <div
          data-search-page-card
          data-search-text={`${item.titleEnglish} ${item.titleRomaji} ${item.slug}`.toLowerCase()}
        >
          <AnimeCard anime={item} />
        </div>
      ))}
    </div>
  </section>

  <script>
    const normalize = (value: string) =>
      value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

    const input = document.querySelector('[data-search-page-input]') as HTMLInputElement | null;
    const cards = [...document.querySelectorAll('[data-search-page-card]')] as HTMLElement[];
    const count = document.querySelector('[data-search-page-count]');

    const applySearch = () => {
      const query = normalize(input?.value ?? '').trim();
      let visible = 0;

      for (const card of cards) {
        const text = normalize(card.dataset.searchText ?? '');
        const matches = query.length === 0 || text.includes(query);
        card.classList.toggle('hidden', !matches);
        if (matches) visible += 1;
      }

      if (count) count.textContent = `${visible} resultados`;
    };

    if (input) {
      const params = new URLSearchParams(window.location.search);
      input.value = params.get('q') ?? '';
      input.addEventListener('input', applySearch);
      applySearch();
    }
  </script>
</BaseLayout>
