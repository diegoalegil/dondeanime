---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import NewsletterForm from '@/components/newsletter/NewsletterForm.astro';
import { getCollection } from 'astro:content';
import { absoluteUrl } from '@/lib/seo';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = new Intl.DateTimeFormat('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout
  title="Blog editorial | DondeAnime"
  description="Archivo editorial de DondeAnime para guías y piezas futuras sobre anime en streaming."
  canonical={absoluteUrl('/blog')}
>
  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: 'Blog', url: '/blog' },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <p class="text-xs uppercase tracking-wide text-accent-violet">Editorial</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">
      Blog <span class="brand-gradient-text">DondeAnime</span>
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
      Estructura preparada para publicar guías y análisis cuando Diego añada el contenido.
    </p>
  </section>

  <section class="mx-auto grid max-w-6xl gap-4 px-4 pb-12 md:grid-cols-2">
    {posts.map((post) => (
      <article class="rounded-lg border border-surface-2 bg-surface-1 p-5">
        <p class="text-sm text-fg-muted">
          {formatDate.format(post.data.pubDate)}
        </p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight">
          <a href={`/blog/${post.id}`} class="transition-colors hover:text-accent-violet">
            {post.data.title}
          </a>
        </h2>
        <p class="mt-3 text-sm leading-6 text-fg-secondary">
          {post.data.description}
        </p>
        <a
          href={`/blog/${post.id}`}
          class="mt-5 inline-flex text-sm font-medium text-accent-violet transition-colors hover:text-accent-pink"
        >
          Leer artículo
        </a>
      </article>
    ))}
  </section>

  <NewsletterForm />
</BaseLayout>
