---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import type { AnimeSummary, BeginnerAnime } from '@/lib/api';
import { getBeginnerAnimeByGenre, getGenres } from '@/lib/api';
import { beginnerGenrePath } from '@/lib/programmaticSeo';
import { absoluteUrl, buildItemListSchema } from '@/lib/seo';
import { localizedGenreName } from '@/lib/genres';

interface Props {
  genreName: string;
}

export async function getStaticPaths() {
  const genres = await getGenres();
  return genres.map((genre) => ({
    params: { genero: genre.slug },
    props: { genreName: genre.name },
  }));
}

const { genero } = Astro.params;
const { genreName } = Astro.props as Props;
const genreLabel = localizedGenreName(genero!, genreName, 'es');
const recommendations = await getBeginnerAnimeByGenre(genero!);
const anime = recommendations.map((item: BeginnerAnime) => item.anime);
const topTitles = anime.slice(0, 4).map((item: AnimeSummary) => item.titleEnglish || item.titleRomaji);
const pagePath = beginnerGenrePath(genero!);
const pageUrl = absoluteUrl(pagePath);

const seoTitle = `Anime para principiantes en ${genreLabel} | DondeAnime`;
const seoDescription = topTitles.length > 0
  ? `Empieza con anime de ${genreLabel}: ${topTitles.join(', ')} y mas recomendaciones populares.`
  : `Guia para empezar con anime de ${genreLabel}.`;

const intro = topTitles.length > 0
  ? `Si quieres empezar con anime de ${genreLabel}, esta seleccion prioriza titulos populares y faciles de ubicar en el catalogo. El objetivo es evitar listas enormes: diez opciones claras para probar el genero sin perderse entre sagas, spin-offs o estrenos demasiado concretos.`
  : `Todavia no tenemos anime suficientes para preparar una lista de inicio en ${genreLabel}, pero la pagina queda lista para completarse con el catalogo sincronizado.`;

const itemListSchema = buildItemListSchema(
  anime.map((item: AnimeSummary) => ({
    name: item.titleEnglish || item.titleRomaji,
    url: absoluteUrl(`/anime/${item.slug}`),
  })),
  pageUrl,
  `Anime para principiantes en ${genreLabel}`,
);
---
<BaseLayout title={seoTitle} description={seoDescription} canonical={pageUrl}>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: genreLabel, url: pagePath },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div class="md:max-w-3xl">
        <p class="text-xs uppercase text-accent-violet">Guia de entrada</p>
        <h1 class="mt-2 text-4xl font-semibold md:text-5xl">
          Anime para principiantes en <span class="brand-gradient-text">{genreLabel}</span>
        </h1>
        <p class="mt-4 text-lg text-fg-secondary">
          {intro}
        </p>
      </div>
      <img
        src="/mascota-welcome.webp"
        alt=""
        width="192"
        height="275"
        loading="eager"
        decoding="async"
        class="hidden h-auto w-40 shrink-0 self-end md:block lg:w-48"
      />
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-5 px-4 pb-20">
    {recommendations.length === 0 ? null : (
      recommendations.map((item: BeginnerAnime, index: number) => (
        <article class="rounded-lg border border-surface-2 bg-surface-1 p-5" data-beginner-result>
          <div class="flex flex-col gap-4 md:flex-row">
            <a href={`/anime/${item.anime.slug}`} class="shrink-0">
              <img
                src={item.anime.coverImage}
                alt={item.anime.titleEnglish || item.anime.titleRomaji}
                class="h-36 w-24 rounded-md object-cover"
                loading={index < 2 ? 'eager' : 'lazy'}
                onerror="this.onerror=null;this.src='/cover-placeholder.webp'"
              />
            </a>
            <div>
              <p class="text-xs font-semibold uppercase text-accent-violet">#{index + 1}</p>
              <h2 class="mt-1 text-xl font-semibold text-fg-primary">
                <a href={`/anime/${item.anime.slug}`} class="transition-colors hover:text-accent-violet">
                  {item.anime.titleEnglish || item.anime.titleRomaji}
                </a>
              </h2>
              <p class="mt-2 max-w-3xl text-sm leading-relaxed text-fg-secondary">
                {item.beginnerRecommendation ?? `Buena puerta de entrada al ${genreLabel}: es uno de los titulos mas populares del genero en el catalogo y permite orientarte rapido antes de pasar a listas mas largas.`}
              </p>
            </div>
          </div>
        </article>
      ))
    )}
  </section>
</BaseLayout>
