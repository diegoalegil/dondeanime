---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Solo rutas que existen de verdad en el build: no hay índices /genero,
// /plataforma, /temporada ni /estrenos (daban 404 dentro del propio 404).
const popularLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/buscar', label: 'Buscar anime' },
  { href: '/genero/action', label: 'Anime de acción' },
  { href: '/plataforma/crunchyroll', label: 'Anime en Crunchyroll' },
  { href: '/estrenos/proxima-semana', label: 'Próximos estrenos' },
];
---
<BaseLayout
  title="Página no encontrada · DondeAnime"
  description="La página que buscas no existe. Vuelve al inicio o busca tu anime favorito."
>
  <section class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-4 py-16 text-center">
    <img
      src="/mascota-404.webp"
      alt=""
      width="364"
      height="700"
      loading="eager"
      decoding="async"
      class="mb-2 h-48 w-auto drop-shadow-[0_8px_24px_rgba(0,0,0,0.45)] sm:h-56"
    />
    <p class="bg-gradient-to-r from-accent-violet to-accent-pink bg-clip-text text-7xl font-black text-transparent sm:text-8xl">
      404
    </p>
    <h1 class="mt-4 text-2xl font-bold text-fg-primary sm:text-3xl">
      Esta página se perdió entre temporadas
    </h1>
    <p class="mt-3 max-w-xl text-fg-secondary">
      El enlace que seguiste no existe o el anime cambió de dirección. Búscalo o vuelve al inicio.
    </p>

    <form action="/buscar" method="get" role="search" class="mt-8 flex w-full max-w-md gap-2">
      <label for="q" class="sr-only">Buscar anime</label>
      <input
        id="q"
        name="q"
        type="search"
        placeholder="Busca un anime..."
        class="w-full rounded-md border border-surface-2 bg-surface-0 px-4 py-2.5 text-sm text-fg-primary placeholder:text-fg-muted focus:border-accent-violet focus:outline-none"
      />
      <button
        type="submit"
        class="rounded-md bg-gradient-to-r from-accent-violet to-accent-pink px-5 py-2.5 text-sm font-semibold text-white"
      >
        Buscar
      </button>
    </form>

    <nav class="mt-10 flex flex-wrap items-center justify-center gap-3" aria-label="Enlaces útiles">
      {popularLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-full border border-surface-2 bg-surface-1 px-4 py-2 text-sm text-fg-secondary transition hover:border-accent-violet hover:text-fg-primary"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
