---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { setLocale, t } from '@/i18n';

setLocale('es');
---
<BaseLayout
  title={t('legal.cookies.title')}
  description={t('legal.cookies.description')}
>
  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.cookies'), url: '/legal/cookies' },
    ]}
  />

  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-semibold text-fg-primary">{t('legal.cookies.heading')}</h1>
    <div class="mt-6 space-y-5 text-sm leading-7 text-fg-secondary">
      <p>{t('legal.cookies.paragraph1')}</p>
      <p>{t('legal.cookies.paragraph2')}</p>
      <p>{t('legal.cookies.paragraph3')}</p>
      <p>{t('legal.cookies.paragraph4')}</p>
    </div>
  </section>
</BaseLayout>
