---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { setLocale, t } from '@/i18n';

setLocale('es');

const sections = [
  { heading: t('contact.catalog.heading'), body: t('contact.catalog.body') },
  { heading: t('contact.privacy.heading'), body: t('contact.privacy.body') },
  { heading: t('contact.business.heading'), body: t('contact.business.body') },
];
---
<BaseLayout
  title={t('contact.title')}
  description={t('contact.description')}
>
  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.contact'), url: '/contacto' },
    ]}
  />

  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-semibold text-fg-primary">{t('contact.heading')}</h1>
    <p class="mt-5 text-base leading-7 text-fg-secondary">
      {t('contact.lead')}
    </p>
    <a
      href="mailto:contacto@dondeanime.com"
      class="mt-6 inline-flex rounded-md border border-accent-violet/50 px-4 py-2 text-sm font-medium text-accent-violet transition-colors hover:border-accent-pink hover:text-accent-pink"
    >
      contacto@dondeanime.com
    </a>

    <div class="mt-10 space-y-8">
      {sections.map((section) => (
        <section>
          <h2 class="text-xl font-semibold text-fg-primary">{section.heading}</h2>
          <p class="mt-3 text-sm leading-7 text-fg-secondary">{section.body}</p>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
