---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';

const siteUrl = import.meta.env.PUBLIC_SITE_URL.replace(/\/$/, '');
const apiBaseUrl = (import.meta.env.PUBLIC_API_URL ?? '').replace(/\/$/, '');
const docsUrl = apiBaseUrl ? `${apiBaseUrl}/api/v1/docs` : '#documentacion';
const exampleApiUrl = apiBaseUrl || 'PUBLIC_API_URL';
const curlExample = `API_URL="${exampleApiUrl}"

curl -H "X-API-Key: da_free_tu_key" \\
  "$API_URL/api/v1/anime"`;
const jsExample = `const apiUrl =
  "${exampleApiUrl}";
const path = "/api/v1/anime";

const response = await fetch(apiUrl + path, {
  headers: {
    "X-API-Key": "da_free_tu_key",
  },
});

const anime = await response.json();`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'DondeAnime Public API',
  serviceType: 'Anime streaming availability API',
  url: `${siteUrl}/api`,
  description: 'API publica para consultar anime, plataformas, generos y temporadas disponibles en DondeAnime.',
  provider: {
    '@type': 'Organization',
    name: 'DondeAnime',
    url: siteUrl,
  },
  areaServed: ['ES', 'MX', 'AR', 'CO', 'CL'],
};
---
<BaseLayout
  title="API DondeAnime"
  description="API publica de DondeAnime para consultar catalogo, plataformas, generos y temporadas de anime."
  canonical={`${siteUrl}/api`}
>
  <JsonLd slot="head" data={serviceSchema} />

  <section class="mx-auto max-w-6xl px-4 py-10">
    <Breadcrumbs
      items={[
        { name: 'Inicio', url: '/' },
        { name: 'API', url: '/api' },
      ]}
    />

    <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_21rem]">
      <div class="min-w-0 space-y-8">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase text-accent-violet">API publica</p>
          <h1 class="mt-2 text-4xl font-semibold text-fg-primary md:text-5xl">
            API DondeAnime
          </h1>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-fg-secondary">
            Consulta catalogo, plataformas, generos y temporadas con endpoints versionados en
            <span class="font-mono text-fg-primary">/api/v1</span>.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
            <p class="text-sm font-semibold text-fg-primary">Versionado estable</p>
            <p class="mt-2 text-sm leading-6 text-fg-secondary">
              Los endpoints publicos viven bajo <span class="font-mono">/api/v1</span> y los cambios incompatibles se anuncian antes de mover version.
            </p>
          </div>
          <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
            <p class="text-sm font-semibold text-fg-primary">API key obligatoria</p>
            <p class="mt-2 text-sm leading-6 text-fg-secondary">
              Cada request usa el header <span class="font-mono">X-API-Key</span>. El plan free tiene 1000 requests al mes.
            </p>
          </div>
          <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
            <p class="text-sm font-semibold text-fg-primary">Docs interactivas</p>
            <p class="mt-2 text-sm leading-6 text-fg-secondary">
              Swagger UI permite revisar rutas, parametros y respuestas reales de la API publica.
            </p>
          </div>
        </div>

        <section id="conseguir-key" aria-labelledby="api-key-title" class="min-w-0 rounded-lg border border-surface-2 bg-surface-1 p-6">
          <h2 id="api-key-title" class="text-2xl font-semibold text-fg-primary">Conseguir una key</h2>
          <div class="mt-4 grid gap-4 text-sm leading-6 text-fg-secondary md:grid-cols-3">
            <p>
              Escribe a <a href="mailto:contacto@dondeanime.com?subject=API%20key%20DondeAnime" class="text-accent-violet transition-colors hover:text-accent-pink">contacto@dondeanime.com</a> con tu email, caso de uso y volumen estimado.
            </p>
            <p>
              Diego crea la key desde el panel admin y asigna tier <span class="font-mono text-fg-primary">FREE</span> o <span class="font-mono text-fg-primary">PAID</span>.
            </p>
            <p>
              La respuesta incluye la key y el limite mensual. No la expongas en repos publicos ni apps cliente sin proxy.
            </p>
          </div>
        </section>

        <section id="ejemplos" aria-labelledby="examples-title" class="grid min-w-0 gap-4 lg:grid-cols-2">
          <div class="min-w-0 rounded-lg border border-surface-2 bg-surface-1 p-5">
            <h2 id="examples-title" class="text-xl font-semibold text-fg-primary">Ejemplo curl</h2>
            <pre class="mt-4 max-w-full overflow-x-auto rounded-md border border-surface-2 bg-surface-0 p-4 text-sm text-fg-secondary"><code>{curlExample}</code></pre>
          </div>

          <div class="min-w-0 rounded-lg border border-surface-2 bg-surface-1 p-5">
            <h2 class="text-xl font-semibold text-fg-primary">Ejemplo JavaScript</h2>
            <pre class="mt-4 max-w-full overflow-x-auto rounded-md border border-surface-2 bg-surface-0 p-4 text-sm text-fg-secondary"><code>{jsExample}</code></pre>
          </div>
        </section>

        <section aria-labelledby="endpoints-title" class="min-w-0 overflow-hidden rounded-lg border border-surface-2">
          <div class="border-b border-surface-2 bg-surface-1 px-5 py-4">
            <h2 id="endpoints-title" class="text-xl font-semibold text-fg-primary">Endpoints principales</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[42rem] text-left text-sm">
              <thead class="bg-surface-1 text-xs uppercase text-fg-muted">
                <tr>
                  <th class="px-5 py-3 font-semibold">Metodo</th>
                  <th class="px-5 py-3 font-semibold">Ruta</th>
                  <th class="px-5 py-3 font-semibold">Uso</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-2 text-fg-secondary">
                <tr>
                  <td class="px-5 py-4 font-mono text-fg-primary">GET</td>
                  <td class="px-5 py-4 font-mono">/api/v1/anime</td>
                  <td class="px-5 py-4">Catalogo publico de anime.</td>
                </tr>
                <tr>
                  <td class="px-5 py-4 font-mono text-fg-primary">GET</td>
                  <td class="px-5 py-4 font-mono">/api/v1/anime/&#123;slug&#125;</td>
                  <td class="px-5 py-4">Detalle y providers agrupados por pais.</td>
                </tr>
                <tr>
                  <td class="px-5 py-4 font-mono text-fg-primary">GET</td>
                  <td class="px-5 py-4 font-mono">/api/v1/providers</td>
                  <td class="px-5 py-4">Plataformas con conteos globales o por pais.</td>
                </tr>
                <tr>
                  <td class="px-5 py-4 font-mono text-fg-primary">GET</td>
                  <td class="px-5 py-4 font-mono">/api/v1/genres</td>
                  <td class="px-5 py-4">Generos disponibles y paginas por genero.</td>
                </tr>
                <tr>
                  <td class="px-5 py-4 font-mono text-fg-primary">GET</td>
                  <td class="px-5 py-4 font-mono">/api/v1/seasons</td>
                  <td class="px-5 py-4">Temporadas y estrenos por anio.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <aside id="documentacion" class="min-w-0 h-fit rounded-lg border border-surface-2 bg-surface-1 p-5">
        <p class="text-sm font-semibold text-fg-secondary">Documentacion</p>
        <a
          href={docsUrl}
          class="mt-3 block rounded-md bg-accent-violet px-4 py-2.5 text-center text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
        >
          Abrir Swagger UI
        </a>
        <dl class="mt-6 space-y-4 text-sm">
          <div>
            <dt class="font-semibold text-fg-primary">Header</dt>
            <dd class="mt-1 font-mono text-fg-secondary">X-API-Key</dd>
          </div>
          <div>
            <dt class="font-semibold text-fg-primary">Free</dt>
            <dd class="mt-1 text-fg-secondary">1000 requests al mes</dd>
          </div>
          <div>
            <dt class="font-semibold text-fg-primary">Paid</dt>
            <dd class="mt-1 text-fg-secondary">100000 requests al mes</dd>
          </div>
          <div>
            <dt class="font-semibold text-fg-primary">Base URL</dt>
            <dd class="mt-1 break-all font-mono text-fg-secondary">{apiBaseUrl || 'PUBLIC_API_URL'}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>
</BaseLayout>
