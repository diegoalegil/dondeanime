---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { absoluteUrl } from '@/lib/seo';
import { setLocale } from '@/i18n';

setLocale('en');

const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
const publishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY ?? '';
const stripeMode = publishableKey.startsWith('pk_live_')
  ? 'Live'
  : publishableKey.startsWith('pk_test_')
    ? 'Test'
    : 'Pending';
---
<BaseLayout
  title="DondeAnime Premium"
  description="DondeAnime Premium plan with fewer ads and improvements for frequent users."
  image={absoluteUrl('/og-premium.png')}
>
  <Breadcrumbs
    items={[
      { name: 'Home', url: '/' },
      { name: 'Premium', url: '/premium' },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-6">
    <img
      src="/heroes/hero-premium-mascota.webp"
      alt=""
      width="2200"
      height="760"
      loading="eager"
      decoding="async"
      class="w-full rounded-2xl ring-1 ring-surface-2/60"
    />
  </section>

  <section
    class="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-[1fr_24rem]"
    data-premium-page
    data-api-url={apiUrl}
    data-stripe-key={publishableKey}
    data-stripe-mode={stripeMode}
  >
    <div class="space-y-8">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase text-warning">Premium</p>
        <h1 class="mt-2 text-4xl font-semibold text-fg-primary md:text-5xl">
          DondeAnime Premium
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-fg-secondary">
          A cleaner experience for checking premieres, platforms and anime pages with less noise.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <p class="text-sm font-semibold text-fg-primary">No ads</p>
          <p class="mt-2 text-sm leading-6 text-fg-secondary">
            Ad slots are hidden when this browser has a verified Premium session.
          </p>
        </div>
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <p class="text-sm font-semibold text-fg-primary">Support the project</p>
          <p class="mt-2 text-sm leading-6 text-fg-secondary">
            Help maintain the catalog, alerts and improvements without relying only on affiliates.
          </p>
        </div>
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <p class="text-sm font-semibold text-fg-primary">Ready for real benefits</p>
          <p class="mt-2 text-sm leading-6 text-fg-secondary">
            The infrastructure is ready to enable Stripe-backed Premium benefits.
          </p>
        </div>
      </div>

      <section aria-labelledby="premium-comparison" class="overflow-hidden rounded-lg border border-surface-2">
        <div class="border-b border-surface-2 bg-surface-1 px-5 py-4">
          <h2 id="premium-comparison" class="text-xl font-semibold text-fg-primary">
            Free vs Premium
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[38rem] text-left text-sm">
            <thead class="bg-surface-1 text-xs uppercase text-fg-muted">
              <tr>
                <th class="px-5 py-3 font-semibold">Feature</th>
                <th class="px-5 py-3 font-semibold">Free</th>
                <th class="px-5 py-3 font-semibold">Premium</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-2 text-fg-secondary">
              <tr>
                <td class="px-5 py-4 text-fg-primary">Catalog and SEO pages</td>
                <td class="px-5 py-4">Included</td>
                <td class="px-5 py-4">Included</td>
              </tr>
              <tr>
                <td class="px-5 py-4 text-fg-primary">Premiere alerts</td>
                <td class="px-5 py-4">Included</td>
                <td class="px-5 py-4">Included</td>
              </tr>
              <tr>
                <td class="px-5 py-4 text-fg-primary">Display ads</td>
                <td class="px-5 py-4">May appear</td>
                <td class="px-5 py-4">Hidden</td>
              </tr>
              <tr>
                <td class="px-5 py-4 text-fg-primary">Status badge</td>
                <td class="px-5 py-4">No</td>
                <td class="px-5 py-4">Yes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <aside class="h-fit rounded-lg border border-surface-2 bg-surface-1 p-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-fg-secondary">Monthly plan</p>
          <p class="mt-2 text-4xl font-semibold text-fg-primary">3.99&nbsp;&euro;</p>
        </div>
        <span class="rounded-md border border-warning/40 bg-warning/10 px-2 py-1 text-xs font-semibold text-warning">
          {stripeMode === 'Live' ? 'Live' : stripeMode === 'Test' ? 'Test mode' : 'Config pending'}
        </span>
      </div>

      <form class="mt-6 space-y-4" data-premium-checkout-form>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-fg-secondary">Email</span>
          <input
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="you@email.com"
            class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none transition-colors focus:border-warning"
          />
        </label>
        <button
          type="submit"
          class="w-full rounded-md bg-warning px-4 py-2.5 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
        >
          Go to checkout
        </button>
        <button
          type="button"
          class="w-full rounded-md border border-surface-2 px-4 py-2.5 text-sm font-semibold text-fg-secondary transition-colors hover:border-warning hover:text-warning"
          data-premium-portal-button
        >
          Manage subscription
        </button>
        <button
          type="button"
          class="w-full rounded-md border border-surface-2 px-4 py-2.5 text-sm font-semibold text-fg-secondary transition-colors hover:border-warning hover:text-warning"
          data-premium-access-button
        >
          Activate on this browser
        </button>
        <p class="min-h-5 text-sm text-fg-muted" data-premium-status></p>
      </form>

      <p class="mt-4 text-xs leading-5 text-fg-muted">
        Checkout is ready for Stripe. Real activation depends on the backend webhook and the link sent by email.
      </p>
    </aside>
  </section>

  <script>
    const root = document.querySelector('[data-premium-page]');
    const apiUrl = root?.getAttribute('data-api-url') ?? '';
    const stripeKey = root?.getAttribute('data-stripe-key') ?? '';
    const form = document.querySelector('[data-premium-checkout-form]');
    const portalButton = document.querySelector('[data-premium-portal-button]');
    const accessButton = document.querySelector('[data-premium-access-button]');
    const status = document.querySelector('[data-premium-status]');

    const setStatus = (message, tone = 'muted') => {
      if (!status) return;
      status.textContent = message;
      status.className = `min-h-5 text-sm ${tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'}`;
    };

    const isStripePublishableKey = (value) => (
      !value || value.startsWith('pk_test_') || value.startsWith('pk_live_')
    );

    const storePremiumSession = (token, body) => {
      localStorage.setItem('dondeanime-premium-token', token);
      localStorage.setItem('dondeanime-premium-tier', body.planTier || 'Premium');
      if (body.expiresAt) {
        localStorage.setItem('dondeanime-premium-expires-at', body.expiresAt);
      } else {
        localStorage.removeItem('dondeanime-premium-expires-at');
      }
    };

    const clearPremiumSession = () => {
      localStorage.removeItem('dondeanime-premium-token');
      localStorage.removeItem('dondeanime-premium-tier');
      localStorage.removeItem('dondeanime-premium-expires-at');
    };

    const verifyPremiumToken = async (token) => {
      if (!apiUrl || !token) return false;
      const response = await fetch(`${apiUrl}/api/premium/status`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const body = response.ok ? await response.json() : null;
      if (body?.premium === true) {
        storePremiumSession(token, body);
        setStatus('Premium is active on this browser.', 'success');
        return true;
      }
      clearPremiumSession();
      setStatus('The Premium link is invalid or has expired.', 'danger');
      return false;
    };

    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === '1') {
      try {
        localStorage.removeItem('dondeanime-premium-source-list');
      } catch (error) {}
      setStatus('Payment completed. Premium will activate when the webhook confirms the subscription.', 'success');
    } else if (params.get('canceled') === '1') {
      setStatus('Checkout canceled. Your plan has not changed.');
    } else if (params.get('manage') === '1') {
      setStatus('Enter your email to open the customer portal.');
    } else if (params.get('portal') === '1') {
      setStatus('Customer portal closed.');
    }

    const accessToken = params.get('access_token') || params.get('premium_token');
    if (accessToken) {
      verifyPremiumToken(accessToken).then((verified) => {
        if (!verified) return;
        params.delete('access_token');
        params.delete('premium_token');
        const nextUrl = params.toString() ? `${window.location.pathname}?${params}` : window.location.pathname;
        window.history.replaceState({}, '', nextUrl);
      }).catch(() => setStatus('Premium could not be verified right now.', 'danger'));
    }

    const currentEmail = () => {
      if (!(form instanceof HTMLFormElement)) return '';
      const data = new FormData(form);
      return String(data.get('email') ?? '').trim();
    };

    const sourceListSlug = () => {
      try {
        return localStorage.getItem('dondeanime-premium-source-list') || '';
      } catch (error) {
        return '';
      }
    };

    const redirectToPremiumUrl = async (path, email) => {
      const payload = path.endsWith('/checkout')
        ? { email, sourceListSlug: sourceListSlug() }
        : { email };
      const response = await fetch(`${apiUrl}${path}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) return false;

      const body = await response.json();
      if (!body.url) return false;

      window.location.href = body.url;
      return true;
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!apiUrl) {
        setStatus('API is not configured.', 'danger');
        return;
      }

      if (!isStripePublishableKey(stripeKey)) {
        setStatus('Stripe public key is not valid.', 'danger');
        return;
      }

      const email = currentEmail();
      if (!email) {
        setStatus('Enter an email.', 'danger');
        return;
      }

      setStatus('Creating checkout...');
      if (!(await redirectToPremiumUrl('/api/premium/checkout', email))) {
        setStatus('Checkout could not be created.', 'danger');
      }
    });

    portalButton?.addEventListener('click', async () => {
      if (!apiUrl) {
        setStatus('API is not configured.', 'danger');
        return;
      }

      const email = currentEmail();
      if (!email) {
        setStatus('Enter an email.', 'danger');
        return;
      }

      const button = portalButton instanceof HTMLButtonElement ? portalButton : null;
      if (button) button.disabled = true;
      setStatus('Sending customer portal link...');
      try {
        const response = await fetch(`${apiUrl}/api/premium/portal`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (response.ok) {
          setStatus('If you have an active subscription, we have emailed you a customer portal link.', 'success');
        } else {
          setStatus('The request could not be processed. Try again later.', 'danger');
        }
      } catch (error) {
        setStatus('Could not connect to the server.', 'danger');
      } finally {
        if (button) button.disabled = false;
      }
    });

    accessButton?.addEventListener('click', async () => {
      if (!apiUrl) {
        setStatus('API is not configured.', 'danger');
        return;
      }

      const email = currentEmail();
      if (!email) {
        setStatus('Enter an email.', 'danger');
        return;
      }

      const button = accessButton instanceof HTMLButtonElement ? accessButton : null;
      if (button) button.disabled = true;
      setStatus('Sending access link...');
      try {
        const response = await fetch(`${apiUrl}/api/premium/access-link`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (response.ok) {
          setStatus('If you have active Premium, we have emailed you an access link.', 'success');
        } else {
          setStatus('The request could not be processed. Try again later.', 'danger');
        }
      } catch (error) {
        setStatus('Could not connect to the server.', 'danger');
      } finally {
        if (button) button.disabled = false;
      }
    });
  </script>
</BaseLayout>
