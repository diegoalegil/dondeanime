---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getNews, getNewsBySlug } from '@/lib/api';
import { buildNewsArticleSchema } from '@/lib/seo';
import { setLocale, getLocale, t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

setLocale('en');

export async function getStaticPaths() {
  const news = await getNews(100);
  return news.map((n) => ({ params: { slug: n.slug } }));
}

const { slug } = Astro.params;
const item = await getNewsBySlug(slug!);
if (!item) {
  return Astro.redirect('/en/news');
}

// Las noticias aún se publican solo en español: esta ruta sirve el MISMO body
// bajo lang=en, así que canonicaliza a /noticias/{slug} y no emite hreflang
// propio (mismo patrón que anime/[slug]/[pais] sin providers).
const canonicalUrl = `${import.meta.env.PUBLIC_SITE_URL.replace(/\/$/, '')}/noticias/${item.slug}`;
const activeLocale = getLocale();
const date = new Intl.DateTimeFormat(activeLocale === 'en' ? 'en-US' : 'es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(item.publishedAt));

const articleSchema = buildNewsArticleSchema(item, canonicalUrl);
const metaDescription = item.metaDescription ?? item.summary ?? item.title;
---
<BaseLayout
  title={item.metaTitle ?? t('news.detail.title', { title: item.title })}
  description={metaDescription}
  canonical={canonicalUrl}
  suppressAlternates
  image={item.imageUrl ?? undefined}
  type="article"
>
  <JsonLd slot="head" data={articleSchema} />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: t('breadcrumbs.news'), url: localizedPath('/noticias') },
      { name: item.title, url: localizedPath(`/noticias/${item.slug}`) },
    ]}
  />

  <article class="mx-auto max-w-3xl px-4 pt-8 pb-20">
    <p class="text-sm text-fg-muted">{item.sourceName} • {date}</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">{item.title}</h1>
    {item.summary && <p class="mt-4 text-lg leading-8 text-fg-secondary">{item.summary}</p>}

    {item.imageUrl && (
      <img src={item.imageUrl} alt={item.title} loading="eager" class="mt-8 w-full rounded-lg" />
    )}

    {item.body && (
      <div class="news-content mt-8 border-t border-surface-2 pt-8 text-fg-secondary" set:html={item.body} />
    )}

    <p class="mt-10 border-t border-surface-2 pt-6 text-sm">
      <span class="text-fg-muted">{t('news.detail.source')}: </span>
      <a href={item.sourceUrl} rel="nofollow noopener" target="_blank" class="text-accent-violet hover:underline">
        {item.sourceName} — {t('news.detail.readOriginal')} →
      </a>
    </p>
  </article>
</BaseLayout>

<style>
  .news-content :global(h2) {
    margin-top: 2rem;
    color: var(--color-fg-primary);
    font-size: 1.5rem;
    font-weight: 650;
  }
  .news-content :global(p) {
    margin-top: 1rem;
    line-height: 1.8;
  }
  .news-content :global(ul) {
    margin-top: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }
  .news-content :global(li) {
    margin-top: 0.5rem;
  }
</style>
