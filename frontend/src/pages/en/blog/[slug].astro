---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { absoluteUrl } from '@/lib/seo';
import { setLocale, getLocale, t } from '@/i18n';
import { blogSlug, isPublishedBlogPost } from '@/lib/blog';
import { localizedPath } from '@/lib/localizedRoutes';
import { getAllAnime } from '@/lib/api';
import AnimeCard from '@/components/anime/AnimeCard.astro';

setLocale('en');

interface Props {
  post: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', (post) => isPublishedBlogPost(post, 'en'));

  return posts.map((post) => ({
    params: { slug: blogSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
const slug = blogSlug(post);
const pageUrl = absoluteUrl(`/en/blog/${slug}`);
const published = post.data.pubDate.toISOString();
const modified = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const activeLocale = getLocale();

// Anime citados por el post (animeSlugs): tarjetas con portada + enlace a ficha.
const eventSlugs = post.data.animeSlugs ?? [];
const eventAnime = eventSlugs.length
  ? (await getAllAnime())
      .filter((anime) => eventSlugs.includes(anime.slug))
      .sort((a, b) => eventSlugs.indexOf(a.slug) - eventSlugs.indexOf(b.slug))
  : [];

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: published,
  dateModified: modified,
  inLanguage: activeLocale,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  author: {
    '@type': 'Organization',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: t('brand.name'),
    logo: {
      '@type': 'ImageObject',
      url: absoluteUrl('/og-default.png'),
    },
  },
};
---
<BaseLayout
  title={t('blog.post.title', { title: post.data.title })}
  description={post.data.description}
  canonical={pageUrl}
  type="article"
>
  <JsonLd slot="head" data={blogPostingSchema} />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: t('breadcrumbs.blog'), url: localizedPath('/blog') },
      { name: post.data.title, url: localizedPath(`/blog/${slug}`) },
    ]}
  />

  <article class="mx-auto max-w-3xl px-4 pt-8 pb-20">
    <p class="text-sm text-fg-muted">
      {new Intl.DateTimeFormat(activeLocale === 'en' ? 'en-US' : 'es-ES', { day: 'numeric', month: 'long', year: 'numeric' }).format(post.data.pubDate)}
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">
      {post.data.title}
    </h1>
    <p class="mt-4 text-lg leading-8 text-fg-secondary">
      {post.data.description}
    </p>

    {eventAnime.length > 0 && (
      <section class="mt-8">
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-wide text-accent-violet">{t('blog.eventAnime')}</h2>
        <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5">
          {eventAnime.map((anime) => <AnimeCard anime={anime} />)}
        </div>
      </section>
    )}

    <div class="blog-content mt-10 border-t border-surface-2 pt-8 text-fg-secondary">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-content :global(h2) {
    margin-top: 2rem;
    color: var(--color-fg-primary);
    font-size: 1.5rem;
    font-weight: 650;
  }

  .blog-content :global(p) {
    margin-top: 1rem;
    line-height: 1.8;
  }

  .blog-content :global(ul) {
    margin-top: 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .blog-content :global(li) {
    margin-top: 0.5rem;
  }
</style>
