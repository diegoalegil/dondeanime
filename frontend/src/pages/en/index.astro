---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnimeGrid from '@/components/anime/AnimeGrid.astro';
import NewsLatest from '@/components/news/NewsLatest.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getAllAnime, getGenres, getSeasons, getAnimeByGenre, getAnimeBySeason, getNews } from '@/lib/api';
import { getHomeFaqs, buildFAQPageSchema, buildWebSiteSchema, buildItemListSchema, absoluteUrl } from '@/lib/seo';
import { formatSeason } from '@/lib/format';
import { COUNTRIES, COUNTRY_SLUGS } from '@/lib/countries';
import { PLATFORMS, PLATFORM_SLUGS, type PlatformSlug } from '@/lib/platforms';
import { BEST_ANIME_YEARS_DESC } from '@/lib/bestYears';
import { setLocale, t } from '@/i18n';
import { localizedCountryName, localizedPath } from '@/lib/localizedRoutes';
import { getCollection } from 'astro:content';
import { isPublishedBlogPost } from '@/lib/blog';
import FeaturedPost from '@/components/blog/FeaturedPost.astro';

setLocale('en');

const blogPosts = (await getCollection('blog')).filter((post) => isPublishedBlogPost(post, 'en'));
const featuredPost =
  blogPosts.find((post) => post.data.featured) ??
  [...blogPosts].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())[0];

const latestNews = await getNews(6);

const SEASON_ORDER: Record<string, number> = { WINTER: 0, SPRING: 1, SUMMER: 2, FALL: 3 };

const currentSeasonFor = (date: Date) => {
  const month = date.getUTCMonth() + 1;
  const season = month <= 3 ? 'WINTER' : month <= 6 ? 'SPRING' : month <= 9 ? 'SUMMER' : 'FALL';
  return { year: date.getUTCFullYear(), season };
};

const [anime, genres, seasons] = await Promise.all([
  getAllAnime(),
  getGenres(),
  getSeasons(),
]);

// Portadas del catálogo de los anime que cita el post destacado (ver index.astro).
const featuredCovers = (featuredPost?.data.animeSlugs ?? []).flatMap((slug) => {
  const item = anime.find((a) => a.slug === slug);
  return item
    ? [{ slug: item.slug, title: item.titleEnglish || item.titleRomaji, coverImage: item.coverImage }]
    : [];
});

const trending = [...anime]
  .filter((a) => a.popularity !== null)
  .sort((a, b) => (b.popularity ?? 0) - (a.popularity ?? 0))
  .slice(0, 12);

const airing = [...anime]
  .filter((a) => a.status === 'RELEASING')
  .sort((a, b) => (b.popularity ?? 0) - (a.popularity ?? 0))
  .slice(0, 12);

const topGenre = genres[0];
const topGenreAnime = topGenre ? (await getAnimeByGenre(topGenre.slug)).slice(0, 12) : [];

const seasonsByRecency = [...seasons].sort((a, b) => {
  if (a.year !== b.year) return b.year - a.year;
  return (SEASON_ORDER[b.season] ?? 0) - (SEASON_ORDER[a.season] ?? 0);
});

const currentSeason = currentSeasonFor(new Date());
const homeSeason = seasons.find((s) =>
  s.year === currentSeason.year
  && s.season === currentSeason.season
  && s.animeCount > 0
) ?? seasonsByRecency.find((s) => s.animeCount > 0);
const homeSeasonAnime = homeSeason
  ? (await getAnimeBySeason(homeSeason.year, homeSeason.season.toLowerCase())).slice(0, 12)
  : [];

const featuredPlatforms: PlatformSlug[] = ['crunchyroll', 'netflix', 'amazon-prime-video', 'hbo-max', 'disney-plus'];

const homeFaqs = getHomeFaqs();
const websiteSchema = buildWebSiteSchema();
const faqSchema = buildFAQPageSchema(homeFaqs);
const itemListSchema = buildItemListSchema(
  anime.slice(0, 20).map((a) => ({
    name: a.titleEnglish || a.titleRomaji,
    url: absoluteUrl(`/en/anime/${a.slug}`),
  })),
  absoluteUrl('/en'),
  t('home.itemListName'),
);
---
<BaseLayout
  title={t('home.title')}
  description={t('home.description')}
  image={absoluteUrl('/og-home.png')}
>
  <JsonLd slot="head" data={websiteSchema} />
  <JsonLd slot="head" data={faqSchema} />
  <JsonLd slot="head" data={itemListSchema} />

  <section class="mx-auto max-w-6xl px-4 pt-16 pb-12">
    <div class="flex flex-col items-center gap-8 md:flex-row md:items-center md:justify-between md:gap-10">
      <div class="text-center md:text-left">
        <h1 class="text-4xl font-semibold tracking-tight md:text-6xl">
          {t('home.hero.line1')}
          <span class="brand-gradient-text">{t('home.hero.highlight')}</span>
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
          {t('home.hero.subtitle')}
        </p>
      </div>
      <img
        src="/mascota-hero.webp"
        alt=""
        width="528"
        height="760"
        loading="eager"
        decoding="async"
        class="h-44 w-auto shrink-0 drop-shadow-[0_10px_30px_rgba(0,0,0,0.45)] sm:h-56 md:h-72 lg:h-80"
      />
    </div>
  </section>

  {featuredPost && <FeaturedPost post={featuredPost} covers={featuredCovers} />}

  <section
    class="mx-auto max-w-6xl px-4 pb-12"
    data-home-library
    hidden
    data-anime-prefix={localizedPath('/anime')}
    data-title-favorites={t('library.home.favorites')}
    data-title-recent={t('library.recent.title')}
  >
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold" data-home-library-title>{t('library.home.favorites')}</h2>
      <a
        href={localizedPath('/mi-lista')}
        class="text-sm text-accent-violet transition-colors hover:text-fg-primary"
      >
        {t('library.home.viewAll')} →
      </a>
    </div>
    <div
      class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 md:gap-6 lg:grid-cols-5 xl:grid-cols-6"
      data-home-library-grid
    ></div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold">{t('home.trending')}</h2>
      <span class="text-sm text-fg-muted">{t('home.topCount', { count: trending.length })}</span>
    </div>
    <AnimeGrid anime={trending} badge="top" />
  </section>

  {airing.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-12">
      <div class="mb-5 flex items-baseline justify-between">
        <h2 class="text-2xl font-semibold">{t('airing.home.title')}</h2>
        <a
          href={localizedPath('/en-emision')}
          class="text-sm text-accent-violet transition-colors hover:text-fg-primary"
        >
          {t('airing.home.viewAll')} →
        </a>
      </div>
      <AnimeGrid anime={airing} />
    </section>
  )}

  <NewsLatest items={latestNews} />

  {homeSeason && homeSeasonAnime.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-12">
      <div class="mb-5 flex items-baseline justify-between">
        <h2 class="text-2xl font-semibold">
          {t('home.seasonPremieres', { season: formatSeason(homeSeason.season), year: homeSeason.year })}
        </h2>
        <a
          href={localizedPath(`/temporada/${homeSeason.year}/${homeSeason.season.toLowerCase()}`)}
          class="text-sm text-accent-violet transition-colors hover:text-fg-primary"
        >
          {t('home.viewSeason')} →
        </a>
      </div>
      <AnimeGrid anime={homeSeasonAnime} />
    </section>
  )}

  {topGenre && topGenreAnime.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-12">
      <div class="mb-5 flex items-baseline justify-between">
        <h2 class="text-2xl font-semibold">
          {t('home.bestInGenrePrefix')} <span class="brand-gradient-text">{topGenre.name}</span>
        </h2>
        <a
          href={localizedPath(`/genero/${topGenre.slug}`)}
          class="text-sm text-accent-violet transition-colors hover:text-fg-primary"
        >
          {t('home.viewGenre')} →
        </a>
      </div>
      <AnimeGrid anime={topGenreAnime} />
    </section>
  )}

  <section class="mx-auto max-w-6xl px-4 pb-12">
    <h2 class="mb-5 text-2xl font-semibold">{t('home.exploreByCountry')}</h2>
    <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-5">
      {COUNTRY_SLUGS.map((slug) => {
        const c = COUNTRIES[slug];
        return (
          <a
            href={localizedPath(`/pais/${slug}`)}
            class="flex items-center gap-3 rounded-lg border border-surface-2 bg-surface-1 px-4 py-3 transition-colors hover:border-accent-violet/40"
          >
            <span class={`fi fi-${c.flagCode} rounded text-lg`} aria-hidden="true"></span>
            <span class="text-sm font-semibold text-fg-primary">{localizedCountryName(slug)}</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12">
    <h2 class="mb-5 text-2xl font-semibold">{t('home.featuredPlatforms')}</h2>
    <div class="flex flex-wrap gap-2">
      {featuredPlatforms.map((slug) => (
        <a
          href={localizedPath(`/plataforma/${slug}`)}
          class="rounded-full border border-surface-2 bg-surface-1 px-4 py-2 text-sm text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary"
        >
          {PLATFORMS[slug].name}
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12">
    <h2 class="mb-5 text-2xl font-semibold">{t('home.bestByYear')}</h2>
    <div class="flex flex-wrap gap-2">
      {BEST_ANIME_YEARS_DESC.map((year) => (
        <a
          href={localizedPath(`/mejores/${year}`)}
          class="rounded-full border border-surface-2 bg-surface-1 px-4 py-2 text-sm text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary"
        >
          {year}
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-12">
    <h2 class="mb-5 text-2xl font-semibold">{t('home.faq')}</h2>
    <div class="grid gap-3 md:grid-cols-2">
      {homeFaqs.map((faq) => (
        <details class="rounded-lg border border-surface-2 bg-surface-1 p-4">
          <summary class="cursor-pointer text-sm font-semibold text-fg-primary">
            {faq.question}
          </summary>
          <p class="mt-3 text-sm leading-6 text-fg-secondary">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  {/* Solo un teaser del catálogo (ver index.astro): el catálogo completo vive
      en /buscar, que es la única página de búsqueda real (no hay /en/buscar). */}
  <section class="mx-auto max-w-6xl px-4 pb-20">
    <div class="mb-5 flex items-baseline justify-between">
      <h2 class="text-2xl font-semibold">{t('home.fullCatalog')}</h2>
      <span class="text-sm text-fg-muted">{t('home.animeCount', { count: anime.length })}</span>
    </div>
    <AnimeGrid anime={anime.slice(0, 60)} />
    <div class="mt-8 text-center">
      <a
        href="/buscar"
        class="inline-flex items-center gap-2 rounded-md border border-surface-2 bg-surface-1 px-5 py-2.5 text-sm font-semibold text-fg-primary transition-colors hover:border-accent-violet hover:text-accent-violet"
      >
        {t('home.viewFullCatalog')} →
      </a>
    </div>
  </section>
</BaseLayout>
<script>
  // Carga diferida (ver index.astro): la home solo importa la biblioteca si el
  // usuario ya tiene datos, para no penalizar el rendimiento de visitantes nuevos.
  const hasLibraryData = () => {
    try {
      return !!(localStorage.getItem('dondeanime-favorites') || localStorage.getItem('dondeanime-recent'));
    } catch {
      return false;
    }
  };

  const render = async () => {
    const root = document.querySelector<HTMLElement>('[data-home-library]');
    if (!root) return;
    if (!hasLibraryData()) {
      root.setAttribute('hidden', '');
      return;
    }
    const { getFavorites, getRecent, renderLibraryCard } = await import('../../lib/personalLibrary');
    const prefix = root.dataset.animePrefix || '/en/anime';
    const favorites = getFavorites();
    const recent = getRecent();
    const items = favorites.length ? favorites.slice(0, 12) : recent.slice(0, 12);
    const title = favorites.length ? root.dataset.titleFavorites : root.dataset.titleRecent;
    const grid = root.querySelector('[data-home-library-grid]');
    const heading = root.querySelector('[data-home-library-title]');
    if (heading) heading.textContent = title ?? '';
    if (grid) grid.replaceChildren(...items.map((item) => renderLibraryCard(item, prefix)));
    root.toggleAttribute('hidden', items.length === 0);
  };

  document.addEventListener('astro:page-load', render);
</script>
