---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { setLocale, t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

setLocale('en');
---
<BaseLayout
  title={t('legal.terms.title')}
  description={t('legal.terms.description')}
>
  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: t('breadcrumbs.terms'), url: localizedPath('/legal/terminos') },
    ]}
  />

  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-3xl font-semibold text-fg-primary">{t('legal.terms.heading')}</h1>
    <div class="mt-6 space-y-5 text-sm leading-7 text-fg-secondary">
      <p>{t('legal.terms.paragraph1')}</p>
      <p>{t('legal.terms.paragraph2')}</p>
      <p>{t('legal.terms.paragraph3')}</p>
      <p>{t('legal.terms.paragraph4')}</p>
    </div>
  </section>
</BaseLayout>
