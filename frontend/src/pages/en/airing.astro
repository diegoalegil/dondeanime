---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import AnimeGrid from '@/components/anime/AnimeGrid.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getAllAnime } from '@/lib/api';
import { buildItemListSchema, absoluteUrl } from '@/lib/seo';
import { setLocale, t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

setLocale('en');

const all = await getAllAnime();
const anime = all
  .filter((item) => item.status === 'RELEASING')
  .sort((a, b) => (b.popularity ?? 0) - (a.popularity ?? 0));

const pageUrl = absoluteUrl('/en-emision');
const itemListSchema = buildItemListSchema(
  anime.map((item) => ({
    name: item.titleEnglish || item.titleRomaji,
    url: absoluteUrl(`/anime/${item.slug}`),
  })),
  pageUrl,
  t('airing.schema.name'),
);
---
<BaseLayout title={t('airing.title')} description={t('airing.description')}>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: t('airing.breadcrumb'), url: localizedPath('/en-emision') },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <p class="text-xs uppercase tracking-wide text-accent-violet">{t('airing.eyebrow')}</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">
      {t('airing.heading.prefix')} <span class="brand-gradient-text">{t('airing.heading.highlight')}</span>
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">{t('airing.count', { count: anime.length })}</p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    {anime.length === 0 ? (
      <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
        {t('airing.empty')}
      </p>
    ) : (
      <AnimeGrid anime={anime} />
    )}
  </section>
</BaseLayout>
