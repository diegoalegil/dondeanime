---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnimeHero from '@/components/anime/AnimeHero.astro';
import AnimeSynopsis from '@/components/anime/AnimeSynopsis.astro';
import MetaList from '@/components/anime/MetaList.astro';
import CountrySwitcher from '@/components/ui/CountrySwitcher.astro';
import ProviderRow from '@/components/providers/ProviderRow.astro';
import NotAvailableInCountry from '@/components/providers/NotAvailableInCountry.astro';
import AvailabilityAlertForm from '@/components/alerts/AvailabilityAlertForm.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getBuildableAnimeDetails } from '@/lib/api';
import type { AnimeDetail } from '@/lib/api';
import { COUNTRIES, COUNTRY_SLUGS, type CountrySlug } from '@/lib/countries';
import { filterVisibleProviders } from '@/lib/platforms';
import { buildAnimeReviewSchema, buildTVSeriesSchema, absoluteUrl } from '@/lib/seo';
import { setLocale, t } from '@/i18n';
import { canonicalCountrySlug, countryParamForLocale, localizedCountryName, localizedPath } from '@/lib/localizedRoutes';

setLocale('en');

interface Props {
  detail: AnimeDetail;
}

export async function getStaticPaths() {
  const entries = await getBuildableAnimeDetails();
  return entries.flatMap(({ detail }) =>
    COUNTRY_SLUGS.map((countrySlug) => ({
      params: { slug: detail.anime.slug, pais: countryParamForLocale(countrySlug, 'en') },
      props: { detail },
    })),
  );
}

const { slug, pais } = Astro.params;
const countrySlug = canonicalCountrySlug(pais);
if (!countrySlug) throw new Error(`Unknown country slug: ${pais}`);
const country = COUNTRIES[countrySlug];
const countryName = localizedCountryName(countrySlug);

const { detail } = Astro.props as Props;
const title = detail.anime.titleEnglish || detail.anime.titleRomaji;

const providersRaw = detail.watchProvidersByCountry[country.iso] ?? [];
const providers = filterVisibleProviders(providersRaw);
const hasProviders = providers.length > 0;

const availableInCountries = COUNTRY_SLUGS.filter((s) => {
  if (s === countrySlug) return false;
  const list = detail.watchProvidersByCountry[COUNTRIES[s].iso] ?? [];
  return filterVisibleProviders(list).length > 0;
});

const platformNames = providers.map((p) => p.providerName).join(', ');
const seoTitle = hasProviders
  ? t('anime.country.seo.availableTitle', { title, country: countryName, platforms: platformNames })
  : t('anime.country.seo.unavailableTitle', { title, country: countryName });
const seoDescription = hasProviders
  ? t('anime.country.seo.availableDescription', { title, country: countryName, platforms: platformNames })
  : t('anime.country.seo.unavailableDescription', { title, country: countryName });

const pageUrl = absoluteUrl(localizedPath(`/anime/${slug}/${countrySlug}`));
const tvSchema = buildTVSeriesSchema(detail.anime, providers, pageUrl);
const reviewSchema = buildAnimeReviewSchema(detail.anime, pageUrl);

// Canonical: las páginas país SIN providers son thin content (todas dicen "no
// disponible"), así que canonicalizan a la ficha base para no diluir SEO ni gastar
// crawl budget. Las que tienen streaming real en ese país aportan info diferencial
// (providers distintos por país) y mantienen self-canonical.
const canonicalOverride = hasProviders ? undefined : absoluteUrl(localizedPath(`/anime/${slug}`));
---
<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical={canonicalOverride}
  suppressAlternates={!hasProviders}
  image={detail.anime.bannerImage ?? detail.anime.coverImage}
  type="article"
  locale={country.hreflang.replace('-', '_')}
>
  <JsonLd slot="head" data={tvSchema} />
  {reviewSchema && <JsonLd slot="head" data={reviewSchema} />}

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: title, url: localizedPath(`/anime/${slug}`) },
      { name: countryName, url: localizedPath(`/anime/${slug}/${countrySlug}`) },
    ]}
  />
  <AnimeHero anime={detail.anime} />
  <CountrySwitcher animeSlug={slug!} activeCountry={countrySlug} />

  {hasProviders ? (
    <section class="mx-auto max-w-6xl px-4 py-8">
      <h2 class="mb-6 text-lg font-semibold text-fg-primary">
        {t('anime.country.whereToWatch', { title, country: countryName })}
      </h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {providers.map((p) => <ProviderRow provider={p} animeSlug={slug!} />)}
      </div>
    </section>
  ) : (
    <>
      <NotAvailableInCountry
        animeSlug={slug!}
        animeTitle={title}
        countrySlug={countrySlug}
        availableInCountries={availableInCountries}
      />
      <AvailabilityAlertForm
        animeSlug={slug!}
        animeTitle={title}
        countryIso={country.iso}
        countryName={countryName}
      />
    </>
  )}

  <AdSlot position="sidebar" />

  <AnimeSynopsis
    description={detail.anime.description}
    translationPending={detail.anime.descriptionTranslationPending}
  />
  <MetaList anime={detail.anime} />

  <section class="mx-auto max-w-6xl px-4 py-8">
    <a
      href={localizedPath(`/anime/${slug}`)}
      class="inline-flex items-center gap-2 text-sm text-fg-muted transition-colors hover:text-accent-violet"
    >
      {t('anime.country.allPlatforms')} →
    </a>
  </section>
</BaseLayout>
