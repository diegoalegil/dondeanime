---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { getGenres } from '@/lib/api';
import { localizedGenreName } from '@/lib/genres';
import { absoluteUrl } from '@/lib/seo';
import { localizedPath } from '@/lib/localizedRoutes';
import { setLocale, t } from '@/i18n';

setLocale('en');

const genres = (await getGenres())
  .slice()
  .sort((a, b) => b.animeCount - a.animeCount);
---
<BaseLayout
  title="Anime genres — every genre and where to watch it | DondeAnime"
  description="Browse anime by genre: action, romance, horror, comedy and more, with which streaming platforms carry each show across Latin America and Spain."
  image={absoluteUrl('/og-genero.png')}
>
  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: t('breadcrumbs.genres'), url: localizedPath('/generos') },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-4">
    <p class="text-xs uppercase tracking-wide text-accent-violet">Catalog by genre</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">Anime by genre</h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
      Every anime genre, most to least catalog. Open one to see its shows and which platforms stream them.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
      {genres.map((g) => (
        <li>
          <a
            href={`/en/genre/${g.slug}`}
            class="flex items-center justify-between rounded-lg border border-surface-2 bg-surface-1 px-4 py-3 transition-colors hover:border-accent-violet/60"
          >
            <span class="font-medium text-fg-primary">{localizedGenreName(g.slug, g.name)}</span>
            <span class="text-xs text-fg-muted">{g.animeCount}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
