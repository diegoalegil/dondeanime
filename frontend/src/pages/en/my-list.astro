---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { setLocale, t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

setLocale('en');

const animePrefix = localizedPath('/anime');
const homeHref = localizedPath('/');
---
<BaseLayout
  title={t('library.page.title')}
  description={t('library.page.description')}
  noindex={true}
  suppressAlternates={true}
>
  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: localizedPath('/') },
      { name: t('library.breadcrumb'), url: localizedPath('/mi-lista') },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-16" data-library data-anime-prefix={animePrefix}>
    <h1 class="text-3xl font-semibold tracking-tight md:text-4xl">{t('library.heading')}</h1>
    <p class="mt-3 max-w-2xl text-fg-secondary">{t('library.intro')}</p>

    <div data-library-favorites hidden class="mt-8">
      <div
        class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
        data-library-favorites-grid
      ></div>
    </div>

    <div
      data-library-empty
      class="mt-8 rounded-xl border border-surface-2 bg-surface-1 p-8 text-center"
    >
      <img
        src="/mascota-vacio.webp"
        alt=""
        width="160"
        height="160"
        loading="lazy"
        decoding="async"
        class="mx-auto h-28 w-auto"
      />
      <h2 class="mt-4 text-lg font-semibold text-fg-primary">{t('library.empty.title')}</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-fg-secondary">{t('library.empty.body')}</p>
      <a
        href={homeHref}
        class="mt-5 inline-flex rounded-md border border-surface-2 px-4 py-2.5 text-sm font-semibold transition-colors hover:border-accent-violet hover:text-accent-violet"
      >
        {t('library.empty.cta')}
      </a>
    </div>

    <div data-library-recent hidden class="mt-12">
      <h2 class="mb-5 text-2xl font-semibold">{t('library.recent.title')}</h2>
      <div
        class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6"
        data-library-recent-grid
      ></div>
    </div>
  </section>
</BaseLayout>
<script>
  import { getFavorites, getRecent, renderLibraryCard, LIBRARY_CHANGE_EVENT } from '../../lib/personalLibrary';

  const render = () => {
    const root = document.querySelector<HTMLElement>('[data-library]');
    if (!root) return;
    const prefix = root.dataset.animePrefix || '/en/anime';

    const favorites = getFavorites();
    const favWrap = root.querySelector('[data-library-favorites]');
    const favGrid = root.querySelector('[data-library-favorites-grid]');
    const empty = root.querySelector('[data-library-empty]');
    if (favGrid) {
      favGrid.replaceChildren(...favorites.map((item) => renderLibraryCard(item, prefix)));
    }
    favWrap?.toggleAttribute('hidden', favorites.length === 0);
    empty?.toggleAttribute('hidden', favorites.length !== 0);

    const recent = getRecent().filter((item) => !favorites.some((fav) => fav.slug === item.slug));
    const recentWrap = root.querySelector('[data-library-recent]');
    const recentGrid = root.querySelector('[data-library-recent-grid]');
    if (recentGrid) {
      recentGrid.replaceChildren(...recent.map((item) => renderLibraryCard(item, prefix)));
    }
    recentWrap?.toggleAttribute('hidden', recent.length === 0);
  };

  document.addEventListener('astro:page-load', render);
  window.addEventListener(LIBRARY_CHANGE_EVENT, render);
</script>
