---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { t } from '@/i18n';

const apiUrl = import.meta.env.PUBLIC_API_URL;
---
<BaseLayout
  title={t('admin.affiliates.title')}
  description={t('admin.affiliates.description')}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.admin'), url: '/admin' },
      { name: t('breadcrumbs.affiliates'), url: '/admin/affiliate-links' },
    ]}
  />

  <section
    class="mx-auto max-w-6xl px-4 py-8"
    data-affiliate-admin
    data-api-url={apiUrl}
    data-status-loading={t('admin.status.loading')}
    data-status-links-loaded={t('admin.status.linksLoaded')}
    data-status-wrong-credentials={t('admin.status.wrongCredentials')}
    data-status-login-required-save={t('admin.status.loginRequiredSave')}
    data-status-link-saved={t('admin.status.linkSaved')}
    data-status-link-deleted={t('admin.status.linkDeleted')}
    data-status-links-load-error={t('admin.status.linksLoadError')}
    data-status-login-required-manage={t('admin.status.loginRequiredManage')}
    data-status-no-links={t('admin.status.noLinks')}
    data-label-active={t('admin.affiliates.active')}
    data-label-paused={t('admin.affiliates.paused')}
    data-label-delete={t('admin.affiliates.delete')}
  >
    <header class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase text-accent-violet">{t('admin.eyebrow')}</p>
        <h1 class="mt-1 text-3xl font-semibold text-fg-primary">{t('admin.affiliateLinks')}</h1>
      </div>
      <a href="/admin/dashboard" class="text-sm text-fg-muted transition-colors hover:text-accent-violet">
        {t('admin.affiliates.viewDashboard')} ->
      </a>
    </header>

    <div class="grid gap-6 lg:grid-cols-[24rem_1fr]">
      <aside class="rounded-lg border border-surface-2 bg-surface-1 p-5">
        <form class="space-y-4" data-login-form>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">{t('admin.username')}</span>
            <input name="username" autocomplete="username" value="admin" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">{t('admin.password')}</span>
            <input name="password" type="password" autocomplete="current-password" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <button type="submit" class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90">
            {t('admin.login')}
          </button>
        </form>

        <form class="mt-6 space-y-4 border-t border-surface-2 pt-5" data-link-form>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">{t('admin.affiliates.providerSlug')}</span>
            <input name="providerSlug" required placeholder="crunchyroll" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">{t('admin.affiliates.country')}</span>
            <input name="country" required maxlength="2" placeholder="ES" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">{t('admin.affiliates.affiliateUrl')}</span>
            <input name="affiliateUrl" required type="url" placeholder="https://..." class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <label class="flex items-center gap-2 text-sm text-fg-secondary">
            <input name="active" type="checkbox" checked />
            {t('admin.affiliates.active')}
          </label>
          <button type="submit" class="rounded-md bg-accent-pink px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90">
            {t('admin.affiliates.saveLink')}
          </button>
          <p class="min-h-5 text-sm text-fg-muted" data-status></p>
        </form>

        <form class="mt-6 space-y-4 border-t border-surface-2 pt-5" data-bulk-form>
          <div>
            <p class="text-sm font-semibold text-fg-primary">Import CSV</p>
            <p class="mt-1 text-xs text-fg-muted">provider_slug,country_code,url,active</p>
          </div>
          <label class="flex min-h-24 cursor-pointer flex-col items-center justify-center rounded-lg border border-dashed border-surface-2 bg-surface-0 px-4 py-5 text-center text-sm text-fg-muted transition-colors hover:border-accent-violet hover:text-accent-violet" data-csv-drop>
            <span>Arrastra un CSV o selecciónalo</span>
            <input name="csv" type="file" accept=".csv,text/csv" class="sr-only" data-csv-input />
          </label>
          <div class="max-h-48 overflow-auto rounded-md border border-surface-2 bg-surface-0">
            <table class="w-full min-w-[32rem] text-left text-xs">
              <thead class="text-fg-muted">
                <tr>
                  <th class="border-b border-surface-2 px-3 py-2">Provider</th>
                  <th class="border-b border-surface-2 px-3 py-2">Pais</th>
                  <th class="border-b border-surface-2 px-3 py-2">URL</th>
                  <th class="border-b border-surface-2 px-3 py-2">Activo</th>
                </tr>
              </thead>
              <tbody data-bulk-preview>
                <tr><td colspan="4" class="px-3 py-4 text-fg-muted">Sin CSV cargado.</td></tr>
              </tbody>
            </table>
          </div>
          <button type="submit" disabled class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 opacity-50 transition-opacity enabled:hover:opacity-90" data-bulk-submit>
            Confirmar import
          </button>
          <p class="min-h-5 text-sm text-fg-muted" data-bulk-status></p>
        </form>
      </aside>

      <section class="rounded-lg border border-surface-2 bg-surface-1 p-5">
        <h2 class="text-lg font-semibold text-fg-primary">{t('admin.affiliates.configuredLinks')}</h2>
        <div class="mt-5 overflow-x-auto">
          <table class="w-full min-w-[42rem] text-left text-sm">
            <thead class="text-xs uppercase text-fg-muted">
              <tr>
                <th class="border-b border-surface-2 pb-3">{t('admin.affiliates.provider')}</th>
                <th class="border-b border-surface-2 pb-3">{t('admin.affiliates.country')}</th>
                <th class="border-b border-surface-2 pb-3">{t('admin.affiliates.clicks')}</th>
                <th class="border-b border-surface-2 pb-3">{t('admin.affiliates.state')}</th>
                <th class="border-b border-surface-2 pb-3"></th>
              </tr>
            </thead>
            <tbody data-links-body></tbody>
          </table>
        </div>
      </section>
    </div>
  </section>

  <script>
    const root = document.querySelector('[data-affiliate-admin]');
    const apiUrl = root?.getAttribute('data-api-url') ?? '';
    const messages = {
      loading: root?.getAttribute('data-status-loading') ?? '',
      linksLoaded: root?.getAttribute('data-status-links-loaded') ?? '',
      wrongCredentials: root?.getAttribute('data-status-wrong-credentials') ?? '',
      loginRequiredSave: root?.getAttribute('data-status-login-required-save') ?? '',
      linkSaved: root?.getAttribute('data-status-link-saved') ?? '',
      linkDeleted: root?.getAttribute('data-status-link-deleted') ?? '',
      linksLoadError: root?.getAttribute('data-status-links-load-error') ?? '',
      loginRequiredManage: root?.getAttribute('data-status-login-required-manage') ?? '',
      noLinks: root?.getAttribute('data-status-no-links') ?? '',
      active: root?.getAttribute('data-label-active') ?? '',
      paused: root?.getAttribute('data-label-paused') ?? '',
      delete: root?.getAttribute('data-label-delete') ?? '',
    };
    const tokenKey = 'dondeanime-admin-token';
    const loginForm = document.querySelector('[data-login-form]');
    const linkForm = document.querySelector('[data-link-form]');
    const status = document.querySelector('[data-status]');
    const body = document.querySelector('[data-links-body]');
    const bulkForm = document.querySelector('[data-bulk-form]');
    const csvDrop = document.querySelector('[data-csv-drop]');
    const csvInput = document.querySelector('[data-csv-input]');
    const bulkPreview = document.querySelector('[data-bulk-preview]');
    const bulkSubmit = document.querySelector('[data-bulk-submit]');
    const bulkStatus = document.querySelector('[data-bulk-status]');
    let pendingCsv = '';

    const setStatus = (message, tone = 'muted') => {
      if (!status) return;
      status.textContent = message;
      status.className = `min-h-5 text-sm ${
        tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'
      }`;
    };

    const setBulkStatus = (message, tone = 'muted') => {
      if (!bulkStatus) return;
      bulkStatus.textContent = message;
      bulkStatus.className = `min-h-5 text-sm ${
        tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'
      }`;
    };

    const authHeaders = () => {
      const token = localStorage.getItem(tokenKey);
      return token ? { Authorization: `Bearer ${token}` } : {};
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const splitCsvLine = (line) => {
      const columns = [];
      let current = '';
      let inQuotes = false;
      for (let index = 0; index < line.length; index += 1) {
        const char = line[index];
        if (char === '"') {
          if (inQuotes && line[index + 1] === '"') {
            current += '"';
            index += 1;
          } else {
            inQuotes = !inQuotes;
          }
        } else if (char === ',' && !inQuotes) {
          columns.push(current.trim());
          current = '';
        } else {
          current += char;
        }
      }
      columns.push(current.trim());
      return columns;
    };

    const previewCsv = (csv) => {
      pendingCsv = csv;
      const rows = csv
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter(Boolean)
        .filter((line, index) => !(index === 0 && line.toLowerCase().startsWith('provider_slug,')))
        .map(splitCsvLine);

      if (!rows.length) {
        bulkPreview.innerHTML = '<tr><td colspan="4" class="px-3 py-4 text-fg-muted">Sin filas válidas.</td></tr>';
        bulkSubmit.disabled = true;
        setBulkStatus('CSV vacío.', 'danger');
        return;
      }

      bulkPreview.innerHTML = rows.slice(0, 20).map((row) => `
        <tr>
          <td class="border-b border-surface-2 px-3 py-2 text-fg-primary">${escapeHtml(row[0])}</td>
          <td class="border-b border-surface-2 px-3 py-2 text-fg-secondary">${escapeHtml(row[1])}</td>
          <td class="border-b border-surface-2 px-3 py-2 text-fg-secondary">${escapeHtml(row[2])}</td>
          <td class="border-b border-surface-2 px-3 py-2 text-fg-secondary">${escapeHtml(row[3])}</td>
        </tr>
      `).join('');
      bulkSubmit.disabled = false;
      setBulkStatus(`${rows.length} filas listas para confirmar.`, 'success');
    };

    const readCsvFile = (file) => {
      const reader = new FileReader();
      reader.addEventListener('load', () => previewCsv(String(reader.result ?? '')));
      reader.readAsText(file);
    };

    async function request(path, options = {}) {
      const response = await fetch(`${apiUrl}${path}`, {
        ...options,
        headers: {
          ...authHeaders(),
          ...(options.headers ?? {}),
        },
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return response.status === 204 ? null : response.json();
    }

    async function loadLinks() {
      setStatus(messages.loading);
      const links = await request('/api/admin/affiliate-links');
      body.innerHTML = links.map((link) => `
        <tr>
          <td class="border-b border-surface-2 py-3 text-fg-primary">${escapeHtml(link.providerSlug)}</td>
          <td class="border-b border-surface-2 py-3 text-fg-secondary">${escapeHtml(link.countryCode)}</td>
          <td class="border-b border-surface-2 py-3 text-fg-secondary">${link.clickCount}</td>
          <td class="border-b border-surface-2 py-3 text-fg-secondary">${link.active ? messages.active : messages.paused}</td>
          <td class="border-b border-surface-2 py-3 text-right">
            <button
              type="button"
              class="rounded-md border border-surface-2 px-3 py-1 text-xs font-semibold text-fg-secondary transition-colors hover:border-danger hover:text-danger"
              data-delete-link="${link.id}"
            >
              ${messages.delete}
            </button>
          </td>
        </tr>
      `).join('') || `<tr><td colspan="5" class="py-6 text-sm text-fg-muted">${messages.noLinks}</td></tr>`;
      setStatus(messages.linksLoaded, 'success');
    }

    loginForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(loginForm);
      const response = await fetch(`${apiUrl}/api/admin/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          username: String(data.get('username') ?? ''),
          password: String(data.get('password') ?? ''),
        }),
      });
      if (!response.ok) {
        localStorage.removeItem(tokenKey);
        setStatus(messages.wrongCredentials, 'danger');
        return;
      }
      const session = await response.json();
      localStorage.setItem(tokenKey, session.token);
      loadLinks().catch(() => {
        localStorage.removeItem(tokenKey);
        setStatus(messages.wrongCredentials, 'danger');
      });
    });

    linkForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!localStorage.getItem(tokenKey)) {
        setStatus(messages.loginRequiredSave, 'danger');
        return;
      }
      const data = new FormData(linkForm);
      await request('/api/admin/affiliate-links', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          providerSlug: String(data.get('providerSlug') ?? ''),
          country: String(data.get('country') ?? ''),
          affiliateUrl: String(data.get('affiliateUrl') ?? ''),
          active: data.get('active') === 'on',
        }),
      });
      linkForm.reset();
      linkForm.querySelector('[name="active"]').checked = true;
      await loadLinks();
      setStatus(messages.linkSaved, 'success');
    });

    body?.addEventListener('click', async (event) => {
      const button = event.target?.closest?.('[data-delete-link]');
      if (!button) return;
      await request(`/api/admin/affiliate-links/${button.getAttribute('data-delete-link')}`, {
        method: 'DELETE',
      });
      await loadLinks();
      setStatus(messages.linkDeleted, 'success');
    });

    csvInput?.addEventListener('change', () => {
      const file = csvInput.files?.[0];
      if (file) readCsvFile(file);
    });

    csvDrop?.addEventListener('dragover', (event) => {
      event.preventDefault();
      csvDrop.classList.add('border-accent-violet', 'text-accent-violet');
    });

    csvDrop?.addEventListener('dragleave', () => {
      csvDrop.classList.remove('border-accent-violet', 'text-accent-violet');
    });

    csvDrop?.addEventListener('drop', (event) => {
      event.preventDefault();
      csvDrop.classList.remove('border-accent-violet', 'text-accent-violet');
      const file = event.dataTransfer?.files?.[0];
      if (file) readCsvFile(file);
    });

    bulkForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!localStorage.getItem(tokenKey)) {
        setBulkStatus('Inicia sesión antes de importar.', 'danger');
        return;
      }
      if (!pendingCsv.trim()) {
        setBulkStatus('Carga un CSV antes de confirmar.', 'danger');
        return;
      }

      try {
        const result = await request('/api/admin/affiliate-links/bulk', {
          method: 'POST',
          headers: { 'Content-Type': 'text/csv' },
          body: pendingCsv,
        });
        pendingCsv = '';
        csvInput.value = '';
        bulkSubmit.disabled = true;
        bulkPreview.innerHTML = '<tr><td colspan="4" class="px-3 py-4 text-fg-muted">Sin CSV cargado.</td></tr>';
        await loadLinks();
        setBulkStatus(`${result.imported} links importados.`, 'success');
      } catch (error) {
        setBulkStatus('CSV rechazado por validación.', 'danger');
      }
    });

    if (localStorage.getItem(tokenKey)) {
      loadLinks().catch(() => setStatus(messages.linksLoadError, 'danger'));
    } else {
      setStatus(messages.loginRequiredManage);
    }
  </script>
</BaseLayout>
