---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
---
<BaseLayout
  title="Listas curadas | Admin DondeAnime"
  description="Editor admin de listas curadas de DondeAnime."
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: 'Admin', url: '/admin' },
      { name: 'Listas', url: '/admin/lists' },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 py-8" data-list-admin data-api-url={apiUrl}>
    <header class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase text-accent-violet">Admin</p>
        <h1 class="mt-1 text-3xl font-semibold text-fg-primary">Listas curadas</h1>
      </div>
      <a href="/admin" class="text-sm text-fg-muted transition-colors hover:text-accent-violet">
        Volver al panel
      </a>
    </header>

    <div class="grid gap-6 lg:grid-cols-[22rem_1fr]">
      <aside class="rounded-lg border border-surface-2 bg-surface-1 p-5">
        <form class="space-y-4" data-login-form>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">Usuario</span>
            <input name="username" autocomplete="username" value="admin" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">Contraseña</span>
            <input name="password" type="password" autocomplete="current-password" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <button type="submit" class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90">
            Entrar
          </button>
        </form>

        <form class="mt-6 space-y-4 border-t border-surface-2 pt-5" data-list-form>
          <input type="hidden" name="slug" data-list-slug />
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">Titulo</span>
            <input name="title" required maxlength="160" placeholder="Anime corto para empezar" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">Descripcion</span>
            <textarea name="description" required maxlength="2000" rows="4" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet"></textarea>
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-fg-secondary">Curador</span>
            <input name="owner" required maxlength="120" value="Diego" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
          </label>
          <div class="grid grid-cols-2 gap-3">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-fg-secondary">Estado</span>
              <select name="status" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet">
                <option value="DRAFT">Borrador</option>
                <option value="PENDING_REVIEW">Revision</option>
                <option value="PUBLISHED">Publicada</option>
                <option value="REJECTED">Rechazada</option>
              </select>
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-fg-secondary">Visibilidad</span>
              <select name="visibility" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet">
                <option value="PRIVATE">Privada</option>
                <option value="UNLISTED">Oculta</option>
                <option value="PUBLIC">Publica</option>
              </select>
            </label>
          </div>
          <button type="submit" class="rounded-md bg-accent-pink px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90">
            Guardar lista
          </button>
          <p class="min-h-5 text-sm text-fg-muted" data-status></p>
        </form>
      </aside>

      <section class="grid gap-6">
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-lg font-semibold text-fg-primary">Listas</h2>
            <button type="button" class="rounded-md border border-surface-2 px-3 py-2 text-sm text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary" data-new-list>
              Nueva
            </button>
          </div>
          <div class="grid gap-2" data-list-body></div>
        </div>

        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5" data-detail-panel>
          <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase text-accent-pink" data-detail-status>Sin lista seleccionada</p>
              <h2 class="mt-1 text-xl font-semibold text-fg-primary" data-detail-title>Selecciona o crea una lista</h2>
            </div>
            <button type="button" class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90 disabled:opacity-40" data-publish disabled>
              Publicar
            </button>
          </div>

          <form class="grid gap-3 border-b border-surface-2 pb-5 md:grid-cols-[1fr_1fr_auto]" data-item-form>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-fg-secondary">Anime slug</span>
              <input name="animeSlug" required placeholder="frieren-beyond-journeys-end" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-fg-secondary">Nota</span>
              <input name="note" maxlength="600" placeholder="Por que entra en la lista" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet" />
            </label>
            <button type="submit" class="self-end rounded-md border border-surface-2 px-4 py-2 text-sm font-semibold text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary">
              Añadir
            </button>
          </form>

          <ol class="mt-5 grid gap-3" data-items-body></ol>
        </div>
      </section>
    </div>
  </section>

  <script>
    const root = document.querySelector('[data-list-admin]');
    const apiUrl = root?.getAttribute('data-api-url') ?? '';
    const tokenKey = 'dondeanime-admin-token';
    const loginForm = document.querySelector('[data-login-form]');
    const listForm = document.querySelector('[data-list-form]');
    const itemForm = document.querySelector('[data-item-form]');
    const status = document.querySelector('[data-status]');
    const listBody = document.querySelector('[data-list-body]');
    const itemsBody = document.querySelector('[data-items-body]');
    const detailTitle = document.querySelector('[data-detail-title]');
    const detailStatus = document.querySelector('[data-detail-status]');
    const publishButton = document.querySelector('[data-publish]');
    const newButton = document.querySelector('[data-new-list]');
    const slugInput = document.querySelector('[data-list-slug]');
    let lists = [];
    let activeSlug = '';

    const setStatus = (message, tone = 'muted') => {
      if (!status) return;
      status.textContent = message;
      status.className = `min-h-5 text-sm ${tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'}`;
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const authHeaders = () => {
      const token = localStorage.getItem(tokenKey);
      return token ? { Authorization: `Bearer ${token}` } : {};
    };

    async function request(path, options = {}) {
      const response = await fetch(`${apiUrl}${path}`, {
        ...options,
        headers: {
          ...authHeaders(),
          ...(options.headers ?? {}),
        },
      });
      if (response.status === 401) {
        setStatus('Inicia sesion para gestionar listas.', 'danger');
      }
      return response;
    }

    function currentList() {
      return lists.find((list) => list.slug === activeSlug) ?? null;
    }

    const setFieldValue = (name, value) => {
      const field = listForm?.querySelector(`[name="${name}"]`);
      if (field) field.value = value;
    };

    function syncList(updated) {
      const index = lists.findIndex((list) => list.slug === updated.slug);
      if (index >= 0) {
        lists[index] = updated;
      } else {
        lists = [updated, ...lists];
      }
      activeSlug = updated.slug;
      render();
    }

    function render() {
      if (!listBody || !itemsBody) return;
      if (!lists.length) {
        listBody.innerHTML = '<p class="text-sm text-fg-muted">No hay listas todavia.</p>';
      } else {
        listBody.innerHTML = lists.map((list) => `
          <button type="button" class="rounded-md border px-3 py-2 text-left text-sm transition-colors ${
            list.slug === activeSlug ? 'border-accent-violet bg-surface-0 text-fg-primary' : 'border-surface-2 text-fg-secondary hover:border-accent-violet'
          }" data-list-select="${escapeHtml(list.slug)}">
            <span class="block font-semibold">${escapeHtml(list.title)}</span>
            <span class="mt-1 block text-xs text-fg-muted">${escapeHtml(list.status)} · ${list.items?.length ?? 0} anime</span>
          </button>
        `).join('');
      }

      const list = currentList();
      publishButton.disabled = !list;
      detailTitle.textContent = list?.title ?? 'Selecciona o crea una lista';
      detailStatus.textContent = list ? `${list.status} · ${list.visibility}` : 'Sin lista seleccionada';
      slugInput.value = list?.slug ?? '';
      if (list) {
        setFieldValue('title', list.title ?? '');
        setFieldValue('description', list.description ?? '');
        setFieldValue('owner', list.owner ?? 'Diego');
        setFieldValue('status', list.status ?? 'DRAFT');
        setFieldValue('visibility', list.visibility ?? 'PRIVATE');
      }

      const items = list?.items ?? [];
      itemsBody.innerHTML = items.length
        ? items.map((item) => `
          <li class="grid gap-3 rounded-lg border border-surface-2 bg-surface-0 p-3 md:grid-cols-[1fr_auto]">
            <div>
              <p class="text-sm font-semibold text-fg-primary">${item.position}. ${escapeHtml(item.anime?.titleEnglish ?? item.animeSlug)}</p>
              <p class="mt-1 text-xs text-fg-muted">${escapeHtml(item.animeSlug)}</p>
              ${item.note ? `<p class="mt-2 text-sm text-fg-secondary">${escapeHtml(item.note)}</p>` : ''}
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <button type="button" class="rounded-md border border-surface-2 px-3 py-2 text-xs text-fg-secondary hover:border-accent-violet" data-item-up="${escapeHtml(item.animeSlug)}">Subir</button>
              <button type="button" class="rounded-md border border-surface-2 px-3 py-2 text-xs text-fg-secondary hover:border-accent-violet" data-item-down="${escapeHtml(item.animeSlug)}">Bajar</button>
              <button type="button" class="rounded-md border border-surface-2 px-3 py-2 text-xs text-danger hover:border-danger" data-item-delete="${escapeHtml(item.animeSlug)}">Quitar</button>
            </div>
          </li>
        `).join('')
        : '<li class="text-sm text-fg-muted">Añade anime por slug para empezar.</li>';
    }

    async function loadLists() {
      const response = await request('/api/admin/lists');
      if (!response.ok) return;
      lists = await response.json();
      activeSlug = lists[0]?.slug ?? '';
      render();
      setStatus('Listas cargadas.', 'success');
    }

    loginForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(loginForm);
      const response = await fetch(`${apiUrl}/api/admin/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          username: String(data.get('username') ?? ''),
          password: String(data.get('password') ?? ''),
        }),
      });
      if (!response.ok) {
        setStatus('Credenciales incorrectas.', 'danger');
        return;
      }
      const payload = await response.json();
      localStorage.setItem(tokenKey, payload.token);
      setStatus('Sesion iniciada.', 'success');
      await loadLists();
    });

    newButton?.addEventListener('click', () => {
      activeSlug = '';
      slugInput.value = '';
      listForm.reset();
      setFieldValue('owner', 'Diego');
      detailTitle.textContent = 'Nueva lista';
      detailStatus.textContent = 'Borrador';
      itemsBody.innerHTML = '<li class="text-sm text-fg-muted">Guarda la lista antes de añadir anime.</li>';
      publishButton.disabled = true;
    });

    listBody?.addEventListener('click', (event) => {
      const button = event.target.closest('[data-list-select]');
      if (!button) return;
      activeSlug = button.getAttribute('data-list-select') ?? '';
      render();
    });

    listForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(listForm);
      const response = await request('/api/admin/lists', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          slug: String(data.get('slug') ?? ''),
          title: String(data.get('title') ?? ''),
          description: String(data.get('description') ?? ''),
          owner: String(data.get('owner') ?? ''),
          status: String(data.get('status') ?? 'DRAFT'),
          visibility: String(data.get('visibility') ?? 'PRIVATE'),
        }),
      });
      if (!response.ok) {
        setStatus('No se pudo guardar la lista.', 'danger');
        return;
      }
      syncList(await response.json());
      setStatus('Lista guardada.', 'success');
    });

    itemForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!activeSlug) {
        setStatus('Guarda una lista antes de añadir anime.', 'danger');
        return;
      }
      const data = new FormData(itemForm);
      const response = await request(`/api/admin/lists/${activeSlug}/items`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          animeSlug: String(data.get('animeSlug') ?? ''),
          note: String(data.get('note') ?? ''),
        }),
      });
      if (!response.ok) {
        setStatus('No se pudo añadir el anime.', 'danger');
        return;
      }
      itemForm.reset();
      syncList(await response.json());
      setStatus('Anime añadido.', 'success');
    });

    itemsBody?.addEventListener('click', async (event) => {
      const up = event.target.closest('[data-item-up]');
      const down = event.target.closest('[data-item-down]');
      const remove = event.target.closest('[data-item-delete]');
      const animeSlug = up?.getAttribute('data-item-up') ?? down?.getAttribute('data-item-down') ?? remove?.getAttribute('data-item-delete');
      if (!activeSlug || !animeSlug) return;
      const path = remove
        ? `/api/admin/lists/${activeSlug}/items/${animeSlug}`
        : `/api/admin/lists/${activeSlug}/items/${animeSlug}/${up ? 'up' : 'down'}`;
      const response = await request(path, { method: remove ? 'DELETE' : 'POST' });
      if (!response.ok) {
        setStatus('No se pudo actualizar el orden.', 'danger');
        return;
      }
      syncList(await response.json());
    });

    publishButton?.addEventListener('click', async () => {
      if (!activeSlug) return;
      const response = await request(`/api/admin/lists/${activeSlug}/publish`, { method: 'POST' });
      if (!response.ok) {
        setStatus('No se pudo publicar.', 'danger');
        return;
      }
      syncList(await response.json());
      setStatus('Lista publicada.', 'success');
    });

    if (localStorage.getItem(tokenKey)) {
      loadLists();
    } else {
      render();
    }
  </script>
</BaseLayout>
