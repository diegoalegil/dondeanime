---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { getAllAnime } from '@/lib/api';
import { t } from '@/i18n';

export async function getStaticPaths() {
  const all = await getAllAnime();
  return all.map((anime) => ({
    params: { slug: anime.slug },
    props: { anime },
  }));
}

const { anime } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL;
const title = anime.titleEnglish || anime.titleRomaji;

const fieldPanels = [
  {
    name: 'title_english',
    title: t('admin.editor.englishTitle'),
    helper: t('admin.editor.publicValue'),
    input: 'input',
  },
  {
    name: 'title_romaji',
    title: t('admin.editor.romajiTitle'),
    helper: t('admin.editor.publicValue'),
    input: 'input',
  },
  {
    name: 'description',
    title: t('admin.editor.descriptionField'),
    helper: t('admin.editor.publicDescriptionValue'),
    input: 'textarea',
  },
  {
    name: 'beginner_recommendation',
    title: t('admin.editor.beginnerRecommendationField'),
    helper: t('admin.editor.beginnerRecommendationHelper'),
    input: 'textarea',
  },
];
---
<BaseLayout
  title={t('admin.editor.title', { title })}
  description={t('admin.editor.description', { title })}
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.admin'), url: '/admin' },
      { name: title, url: `/admin/anime/${anime.slug}` },
    ]}
  />

  <section
    class="mx-auto max-w-6xl px-4 py-8"
    data-admin-editor
    data-api-url={apiUrl}
    data-slug={anime.slug}
    data-status-loading={t('admin.status.editorLoading')}
    data-status-session-active={t('admin.status.sessionActive')}
    data-status-wrong-credentials={t('admin.status.wrongCredentials')}
    data-status-loaded={t('admin.status.loaded')}
    data-status-no-value={t('admin.status.noValue')}
    data-status-login-required-save={t('admin.status.loginRequiredSave')}
    data-status-empty-override={t('admin.status.emptyOverride')}
    data-status-saving={t('admin.status.saving')}
    data-status-saved={t('admin.status.saved')}
    data-status-login-required-reset={t('admin.status.loginRequiredReset')}
    data-status-resetting={t('admin.status.resetting')}
    data-status-reset-done={t('admin.status.resetDone')}
    data-status-load-error={t('admin.status.editorLoadError')}
  >
    <header class="mb-8 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <div class="flex gap-4">
        <img
          src={anime.coverImage}
          alt={title}
          class="h-28 w-20 shrink-0 rounded-lg object-cover shadow-xl shadow-black/30"
        />
        <div>
          <p class="text-xs font-semibold uppercase text-accent-violet">{t('admin.editor.eyebrow')}</p>
          <h1 class="mt-1 text-3xl font-semibold text-fg-primary">{title}</h1>
          {anime.titleRomaji && anime.titleRomaji !== anime.titleEnglish && (
            <p class="mt-1 text-sm text-fg-muted">{anime.titleRomaji}</p>
          )}
          <a
            href={`/anime/${anime.slug}`}
            class="mt-3 inline-flex text-sm text-fg-muted transition-colors hover:text-accent-violet"
          >
            {t('admin.editor.publicPage')}
          </a>
        </div>
      </div>

      <form class="rounded-lg border border-surface-2 bg-surface-1 p-4" data-login-form>
        <div class="grid gap-3 sm:grid-cols-[9rem_12rem_auto]">
          <label>
            <span class="mb-1 block text-xs font-medium text-fg-secondary">{t('admin.username')}</span>
            <input
              name="username"
              autocomplete="username"
              value="admin"
              class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet"
            />
          </label>
          <label>
            <span class="mb-1 block text-xs font-medium text-fg-secondary">{t('admin.password')}</span>
            <input
              name="password"
              type="password"
              autocomplete="current-password"
              class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet"
            />
          </label>
          <button
            type="submit"
            class="self-end rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
          >
            {t('admin.login')}
          </button>
        </div>
        <p class="mt-2 min-h-5 text-sm text-fg-muted" data-login-status></p>
      </form>
    </header>

    <div class="mb-5 rounded-lg border border-surface-2 bg-surface-1 px-4 py-3 text-sm text-fg-secondary" data-global-status>
      {t('admin.status.editorLoading')}
    </div>

    <div class="grid gap-5">
      {fieldPanels.map((field) => (
        <article class="rounded-lg border border-surface-2 bg-surface-1 p-5" data-field-panel={field.name}>
          <div class="mb-4 flex flex-col gap-1 md:flex-row md:items-center md:justify-between">
            <h2 class="text-lg font-semibold text-fg-primary">{field.title}</h2>
            <p class="text-sm text-fg-muted">{field.helper} <span data-effective></span></p>
          </div>
          <label class="block">
            <span class="mb-2 block text-sm font-medium text-fg-secondary">{t('admin.editor.originalAniList')}</span>
            {field.input === 'textarea' ? (
              <textarea
                readonly
                data-original
                rows="6"
                class="w-full resize-y rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm leading-relaxed text-fg-muted"
              ></textarea>
            ) : (
              <input
                readonly
                data-original
                class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-muted"
              />
            )}
          </label>
          <label class="mt-4 block">
            <span class="mb-2 block text-sm font-medium text-fg-secondary">{t('admin.editor.spanishOverride')}</span>
            {field.input === 'textarea' ? (
              <textarea
                data-input
                rows="10"
                class="w-full resize-y rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm leading-relaxed text-fg-primary outline-none focus:border-accent-violet"
              ></textarea>
            ) : (
              <input
                data-input
                class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none focus:border-accent-violet"
              />
            )}
          </label>
          <div class="mt-4 flex flex-wrap gap-3">
            <button
              type="button"
              class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
              data-save
            >
              {t('admin.editor.save')}
            </button>
            <button
              type="button"
              class="rounded-md border border-surface-2 px-4 py-2 text-sm font-semibold text-fg-secondary transition-colors hover:border-danger hover:text-danger"
              data-reset
            >
              {t('admin.editor.reset')}
            </button>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    const root = document.querySelector('[data-admin-editor]');
    const apiUrl = root?.getAttribute('data-api-url') ?? '';
    const slug = root?.getAttribute('data-slug') ?? '';
    const messages = {
      loading: root?.getAttribute('data-status-loading') ?? '',
      sessionActive: root?.getAttribute('data-status-session-active') ?? '',
      wrongCredentials: root?.getAttribute('data-status-wrong-credentials') ?? '',
      loaded: root?.getAttribute('data-status-loaded') ?? '',
      noValue: root?.getAttribute('data-status-no-value') ?? '',
      loginRequiredSave: root?.getAttribute('data-status-login-required-save') ?? '',
      emptyOverride: root?.getAttribute('data-status-empty-override') ?? '',
      saving: root?.getAttribute('data-status-saving') ?? '',
      saved: root?.getAttribute('data-status-saved') ?? '',
      loginRequiredReset: root?.getAttribute('data-status-login-required-reset') ?? '',
      resetting: root?.getAttribute('data-status-resetting') ?? '',
      resetDone: root?.getAttribute('data-status-reset-done') ?? '',
      loadError: root?.getAttribute('data-status-load-error') ?? '',
    };
    const tokenKey = 'dondeanime-admin-token';
    const globalStatus = document.querySelector('[data-global-status]');
    const loginForm = document.querySelector('[data-login-form]');
    const loginStatus = document.querySelector('[data-login-status]');
    const panels = Array.from(document.querySelectorAll('[data-field-panel]'));

    const apiFieldByOverride = {
      title_english: 'titleEnglish',
      title_romaji: 'titleRomaji',
      description: 'description',
      beginner_recommendation: null,
    };

    const setGlobalStatus = (message, tone = 'muted') => {
      if (!globalStatus) return;
      globalStatus.textContent = message;
      globalStatus.className = `mb-5 rounded-lg border border-surface-2 bg-surface-1 px-4 py-3 text-sm ${
        tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-secondary'
      }`;
    };

    const setLoginStatus = (message, tone = 'muted') => {
      if (!loginStatus) return;
      loginStatus.textContent = message;
      loginStatus.className = `mt-2 min-h-5 text-sm ${
        tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'
      }`;
    };

    const getToken = () => localStorage.getItem(tokenKey);
    const authHeaders = () => {
      const token = getToken();
      return token ? { Authorization: `Bearer ${token}` } : {};
    };

    const asText = (value) => value ?? '';
    const stripHtml = (value) => asText(value).replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();

    async function fetchJson(path, options = {}) {
      const response = await fetch(`${apiUrl}${path}`, options);
      if (!response.ok) {
        const error = new Error(`HTTP ${response.status}`);
        error.status = response.status;
        throw error;
      }
      return response.json();
    }

    async function loadEditor() {
      setGlobalStatus(messages.loading);
      const detail = await fetchJson(`/api/anime/${slug}`);
      let overrides = [];

      if (getToken()) {
        try {
          overrides = await fetchJson(`/api/admin/anime/${slug}/overrides`, {
            headers: authHeaders(),
          });
          setLoginStatus(messages.sessionActive, 'success');
        } catch (error) {
          if (error.status === 401) {
            localStorage.removeItem(tokenKey);
            setLoginStatus(messages.wrongCredentials, 'danger');
          }
        }
      }

      const overrideByField = new Map(overrides.map((override) => [override.fieldName, override]));

      panels.forEach((panel) => {
        const fieldName = panel.getAttribute('data-field-panel');
        const apiField = apiFieldByOverride[fieldName];
        const override = overrideByField.get(fieldName);
        const originalValue = override?.originalValue ?? (apiField ? detail.anime[apiField] : '');
        const effectiveValue = override?.fieldValue ?? (apiField ? detail.anime[apiField] : '');
        const displayEffective = fieldName === 'description' ? stripHtml(effectiveValue) : asText(effectiveValue);

        panel.querySelector('[data-original]').value = fieldName === 'description'
          ? stripHtml(originalValue)
          : asText(originalValue);
        panel.querySelector('[data-input]').value = override?.fieldValue ?? '';

        const effective = panel.querySelector('[data-effective]');
        if (effective) {
          effective.textContent = displayEffective || messages.noValue;
        }
      });

      setGlobalStatus(messages.loaded, 'success');
    }

    async function saveField(panel) {
      const fieldName = panel.getAttribute('data-field-panel');
      const fieldValue = panel.querySelector('[data-input]').value.trim();

      if (!getToken()) {
        setGlobalStatus(messages.loginRequiredSave, 'danger');
        return;
      }

      if (!fieldValue) {
        setGlobalStatus(messages.emptyOverride, 'danger');
        return;
      }

      setGlobalStatus(messages.saving);
      await fetchJson(`/api/admin/anime/${slug}/override`, {
        method: 'POST',
        headers: {
          ...authHeaders(),
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ fieldName, fieldValue, locale: 'es' }),
      });
      await loadEditor();
      setGlobalStatus(messages.saved, 'success');
    }

    async function resetField(panel) {
      const fieldName = panel.getAttribute('data-field-panel');

      if (!getToken()) {
        setGlobalStatus(messages.loginRequiredReset, 'danger');
        return;
      }

      setGlobalStatus(messages.resetting);
      await fetchJson(`/api/admin/anime/${slug}/override?field=${encodeURIComponent(fieldName)}&locale=es`, {
        method: 'DELETE',
        headers: authHeaders(),
      });
      await loadEditor();
      setGlobalStatus(messages.resetDone, 'success');
    }

    loginForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(loginForm);
      const username = String(data.get('username') ?? '');
      const password = String(data.get('password') ?? '');
      const response = await fetch(`${apiUrl}/api/admin/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password }),
      });
      if (!response.ok) {
        localStorage.removeItem(tokenKey);
        setLoginStatus(messages.wrongCredentials, 'danger');
        return;
      }
      const session = await response.json();
      localStorage.setItem(tokenKey, session.token);
      try {
        await loadEditor();
      } catch (error) {
        localStorage.removeItem(tokenKey);
        setLoginStatus(messages.wrongCredentials, 'danger');
      }
    });

    panels.forEach((panel) => {
      panel.querySelector('[data-save]')?.addEventListener('click', () => saveField(panel));
      panel.querySelector('[data-reset]')?.addEventListener('click', () => resetField(panel));
    });

    loadEditor().catch(() => {
      setGlobalStatus(messages.loadError, 'danger');
    });
  </script>
</BaseLayout>
