---
import BaseLayout from '@/layouts/BaseLayout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
---
<BaseLayout
  title="Login admin — DondeAnime"
  description="Acceso admin de DondeAnime."
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <section class="mx-auto flex min-h-[70vh] max-w-md items-center px-4 py-10" data-admin-login data-api-url={apiUrl}>
    <form class="w-full rounded-lg border border-surface-2 bg-surface-1 p-6" data-login-form>
      <p class="text-xs font-semibold uppercase text-accent-violet">Admin</p>
      <h1 class="mt-1 text-2xl font-semibold text-fg-primary">Iniciar sesión</h1>

      <label class="mt-6 block">
        <span class="mb-1 block text-sm font-medium text-fg-secondary">Usuario</span>
        <input name="username" autocomplete="username" value="admin" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none transition-colors focus:border-accent-violet" />
      </label>

      <label class="mt-4 block">
        <span class="mb-1 block text-sm font-medium text-fg-secondary">Contraseña</span>
        <input name="password" type="password" autocomplete="current-password" class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none transition-colors focus:border-accent-violet" />
      </label>

      <button type="submit" class="mt-5 w-full rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90">
        Entrar
      </button>
      <p class="mt-3 min-h-5 text-sm text-fg-muted" data-login-status></p>
    </form>
  </section>

  <script>
    const root = document.querySelector('[data-admin-login]');
    const form = document.querySelector('[data-login-form]');
    const status = document.querySelector('[data-login-status]');
    const apiUrl = root?.getAttribute('data-api-url') ?? '';
    const tokenKey = 'dondeanime-admin-token';

    const setStatus = (message, tone = 'muted') => {
      if (!status) return;
      status.textContent = message;
      status.className = `mt-3 min-h-5 text-sm ${tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'}`;
    };

    const nextUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const next = params.get('next') || '/admin';
      return next.startsWith('/admin') ? next : '/admin';
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(form);
      setStatus('Verificando...');

      const response = await fetch(`${apiUrl}/api/admin/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          username: String(data.get('username') ?? ''),
          password: String(data.get('password') ?? ''),
        }),
      });

      if (!response.ok) {
        localStorage.removeItem(tokenKey);
        setStatus('Credenciales incorrectas.', 'danger');
        return;
      }

      const session = await response.json();
      localStorage.setItem(tokenKey, session.token);
      setStatus('Sesión iniciada.', 'success');
      window.location.href = nextUrl();
    });
  </script>
</BaseLayout>
