---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnimeGrid from '@/components/anime/AnimeGrid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getSeasons, getAnimeBySeason } from '@/lib/api';
import { formatSeason } from '@/lib/format';
import { buildItemListSchema, absoluteUrl } from '@/lib/seo';
import { setLocale, t } from '@/i18n';

setLocale('es');

export async function getStaticPaths() {
  const seasons = await getSeasons();
  return seasons.map((s) => ({
    params: { year: String(s.year), season: s.season.toLowerCase() },
    props: { total: s.animeCount },
  }));
}

const { year, season } = Astro.params;

const yearNum = Number(year);
const seasonLabel = formatSeason(season!.toUpperCase());
const anime = await getAnimeBySeason(yearNum, season!);
const previewTitles = anime.slice(0, 5).map((a) => a.titleEnglish || a.titleRomaji).join(', ');

const seoTitle = t('season.seo.title', { season: seasonLabel, year: year! });
const seoDescription = t('season.seo.description', {
  season: seasonLabel.toLowerCase(),
  year: year!,
  titles: previewTitles,
});

const pageUrl = absoluteUrl(`/temporada/${year}/${season}`);
const itemListSchema = buildItemListSchema(
  anime.map((a) => ({
    name: a.titleEnglish || a.titleRomaji,
    url: absoluteUrl(`/anime/${a.slug}`),
  })),
  pageUrl,
  t('season.schema.name', { season: seasonLabel, year: year! }),
);
---
<BaseLayout title={seoTitle} description={seoDescription}>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.seasons'), url: '/' },
      { name: `${seasonLabel} ${year}`, url: `/temporada/${year}/${season}` },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <p class="text-xs uppercase tracking-wide text-accent-violet">{t('season.eyebrow')}</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">
      {t('season.headingPrefix')} <span class="brand-gradient-text">{seasonLabel} {year}</span>
    </h1>
    <p class="mt-4 text-lg text-fg-secondary">
      {t('season.count', { count: anime.length, plural: anime.length === 1 ? '' : 's' })}
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    {anime.length === 0 ? (
      <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
        {t('season.empty')}
      </p>
    ) : (
      <AnimeGrid anime={anime} />
    )}
  </section>
</BaseLayout>
