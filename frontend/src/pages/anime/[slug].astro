---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnimeHero from '@/components/anime/AnimeHero.astro';
import AnimeSynopsis from '@/components/anime/AnimeSynopsis.astro';
import TrailerEmbed from '@/components/anime/TrailerEmbed.astro';
import CharacterList from '@/components/anime/CharacterList.astro';
import MetaList from '@/components/anime/MetaList.astro';
import SimilarAnime from '@/components/anime/SimilarAnime.astro';
import NewsLatest from '@/components/news/NewsLatest.astro';
import ProvidersByCountry from '@/components/providers/ProvidersByCountry.astro';
import AdSlot from '@/components/ads/AdSlot.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getBuildableAnimeDetails, getSimilarAnime, getAnimeNews } from '@/lib/api';
import type { AnimeDetail } from '@/lib/api';
import { buildRelatedAnimeSchema, buildTVSeriesSchema, absoluteUrl } from '@/lib/seo';
import { filterVisibleProviders } from '@/lib/platforms';
import { buildAnimeImageUrl, buildAnimeImageSrcset, canOptimizeAnimeImage, HERO_COVER_SIZES } from '@/lib/images';
import { setLocale, t } from '@/i18n';

setLocale('es');

interface Props {
  detail: AnimeDetail;
}

export async function getStaticPaths() {
  const entries = await getBuildableAnimeDetails();
  return entries.map(({ detail }) => ({ params: { slug: detail.anime.slug }, props: { detail } }));
}

const { slug } = Astro.params;
const { detail } = Astro.props as Props;
const similarAnime = await getSimilarAnime(slug!);
const animeNews = await getAnimeNews(slug!);
const title = detail.anime.titleEnglish || detail.anime.titleRomaji;

// Preload de la portada del hero (LCP de la ficha): mismos src/srcset/sizes que
// pinta AnimeHero, así el navegador la descubre y descarga antes sin doble
// descarga (HERO_COVER_SIZES es la constante compartida con AnimeHero).
const heroCover = detail.anime.coverImage;
const canPreloadHero = !!heroCover && canOptimizeAnimeImage(heroCover);
const heroPreloadSrc = heroCover ? buildAnimeImageUrl(heroCover, 1) : undefined;
const heroPreloadSrcset = heroCover ? buildAnimeImageSrcset(heroCover) : undefined;

const allProviders = Object.values(detail.watchProvidersByCountry).flat();
const uniqueProviders = filterVisibleProviders(
  Array.from(new Map(allProviders.map((p) => [p.providerSlug, p])).values())
);

const seoDescription = detail.anime.description
  ? detail.anime.description.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').slice(0, 160).trim()
  : t('anime.seo.description', { title });

const pageUrl = absoluteUrl(`/anime/${slug}`);
const tvSchema = buildTVSeriesSchema(detail.anime, uniqueProviders, pageUrl);
const relatedSchema = buildRelatedAnimeSchema(detail.anime, similarAnime, pageUrl);
---
<BaseLayout
  title={t('anime.seo.title', { title })}
  description={seoDescription}
  image={detail.anime.bannerImage ?? detail.anime.coverImage ?? absoluteUrl('/og-anime-fallback.png')}
  type="article"
>
  <JsonLd slot="head" data={tvSchema} />
  {relatedSchema && <JsonLd slot="head" data={relatedSchema} />}
  {canPreloadHero && (
    <link
      slot="head"
      rel="preload"
      as="image"
      href={heroPreloadSrc}
      imagesrcset={heroPreloadSrcset}
      imagesizes={HERO_COVER_SIZES}
      fetchpriority="high"
    />
  )}

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.anime'), url: '/' },
      { name: title, url: `/anime/${slug}` },
    ]}
  />
  <AnimeHero anime={detail.anime} />
  <ProvidersByCountry providersByCountry={detail.watchProvidersByCountry} animeSlug={slug!} />
  <TrailerEmbed youtubeId={detail.anime.trailerYoutubeId} title={title} />
  <AdSlot position="inline" />
  <AnimeSynopsis
    description={detail.anime.description}
    translationPending={detail.anime.descriptionTranslationPending}
  />
  <CharacterList characters={detail.anime.characters} />
  <MetaList anime={detail.anime} />
  <SimilarAnime anime={similarAnime} sourceSlug={slug!} />

  <NewsLatest items={animeNews} heading={t('news.anime.heading')} viewAllHref={`/anime/${slug}/noticias`} />
</BaseLayout>
