---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnimeGrid from '@/components/anime/AnimeGrid.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import type { AnimeSummary, ProviderSummary } from '@/lib/api';
import { getAnimeByProvider, getGenres, getProviders } from '@/lib/api';
import { AutoTextGenerator } from '@/lib/autoTextGenerator.mjs';
import { COUNTRIES } from '@/lib/countries';
import { buildItemListSchema, absoluteUrl } from '@/lib/seo';
import { getPlatform, isHiddenVariant } from '@/lib/platforms';

interface Props {
  genreName: string;
  provider: ProviderSummary;
}

const slugifyGenre = (genre: string): string => genre.toLowerCase().replace(/\s+/g, '-');

export async function getStaticPaths() {
  const topGenreLimit = 7;
  const topProviderLimit = 5;
  const [genres, providers] = await Promise.all([
    getGenres(),
    getProviders(),
  ]);

  const topGenres = genres.slice(0, topGenreLimit);
  const topProviders = providers
    .filter((provider) => !isHiddenVariant(provider.slug))
    .slice(0, topProviderLimit);

  return topGenres.flatMap((genre) =>
    topProviders.map((provider) => ({
      params: {
        genero: genre.slug,
        plataforma: provider.slug,
      },
      props: {
        genreName: genre.name,
        provider,
      },
    }))
  );
}

const { genero, plataforma } = Astro.params;
const { genreName, provider } = Astro.props as Props;
const platformName = getPlatform(provider.slug)?.name ?? provider.providerName;

const animeByCountry = await Promise.all(
  Object.values(COUNTRIES).map((country) => getAnimeByProvider(plataforma!, country.iso)),
);

const providerAnime = Array.from(
  new Map(animeByCountry.flat().map((anime) => [anime.slug, anime])).values(),
);

const anime = providerAnime
  .filter((item) => item.genres.some((genre) => slugifyGenre(genre) === genero))
  .sort((a, b) => (b.popularity ?? 0) - (a.popularity ?? 0));
const autoText = new AutoTextGenerator().generateGenrePlatform({
  animeCount: anime.length,
  countries: Object.values(COUNTRIES).map((country) => country.name).join(', '),
  genreName,
  platformName,
  topTitles: anime.slice(0, 4).map((item) => item.titleEnglish || item.titleRomaji),
});

const seoTitle = `Anime de ${genreName} en ${platformName} | DondeAnime`;
const seoDescription = anime.length > 0
  ? `Anime de ${genreName} disponibles en ${platformName}: ${anime.slice(0, 5).map((item) => item.titleEnglish || item.titleRomaji).join(', ')}.`
  : `Anime de ${genreName} disponibles en ${platformName} en España y Latinoamérica.`;

const pageUrl = absoluteUrl(`/anime/${genero}/en/${plataforma}`);
const itemListSchema = buildItemListSchema(
  anime.slice(0, 30).map((item: AnimeSummary) => ({
    name: item.titleEnglish || item.titleRomaji,
    url: absoluteUrl(`/anime/${item.slug}`),
  })),
  pageUrl,
  `Anime de ${genreName} en ${platformName}`,
);
---
<BaseLayout title={seoTitle} description={seoDescription}>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: 'Géneros', url: `/genero/${genero}` },
      { name: platformName, url: `/plataforma/${plataforma}` },
      { name: `${genreName} en ${platformName}`, url: `/anime/${genero}/en/${plataforma}` },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <p class="text-xs uppercase tracking-wide text-accent-violet">Género + plataforma</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">
      Anime de <span class="brand-gradient-text">{genreName}</span> en {platformName}
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
      {anime.length} anime que cruzan este género con esta plataforma en países hispanos.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-10">
    <div
      class="grid gap-4 rounded-lg border border-surface-2 bg-surface-1 p-5"
      data-auto-text
      set:html={autoText.html}
    />
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    {anime.length === 0 ? (
      <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
        No tenemos anime catalogados con este cruce ahora mismo.
      </p>
    ) : (
      <AnimeGrid anime={anime} />
    )}
  </section>
</BaseLayout>
