---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getProvidersByCountry } from '@/lib/api';
import { COUNTRIES, COUNTRY_SLUGS, type CountrySlug } from '@/lib/countries';
import { isHiddenVariant, getPlatform } from '@/lib/platforms';
import { buildItemListSchema, absoluteUrl } from '@/lib/seo';

export async function getStaticPaths() {
  return COUNTRY_SLUGS.map((s) => ({ params: { pais: s } }));
}

const { pais } = Astro.params;
const countrySlug = pais as CountrySlug;
const country = COUNTRIES[countrySlug];

const rawProviders = await getProvidersByCountry(country.iso);
const providers = rawProviders.filter((p) => !isHiddenVariant(p.slug));

const seoTitle = `Anime en streaming en ${country.name} — Plataformas disponibles | DondeAnime`;
const seoDescription = `Descubre todas las plataformas de streaming con anime en ${country.name}: ${providers.slice(0, 5).map((p) => p.providerName).join(', ')} y más.`;

const pageUrl = absoluteUrl(`/pais/${countrySlug}`);
const itemListSchema = buildItemListSchema(
  providers.map((p) => ({
    name: p.providerName,
    url: absoluteUrl(`/plataforma/${p.slug}/${countrySlug}`),
  })),
  pageUrl,
  `Plataformas de anime en ${country.name}`,
);
---
<BaseLayout
  title={seoTitle}
  description={seoDescription}
  locale={country.hreflang.replace('-', '_')}
>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: country.name, url: `/pais/${countrySlug}` },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-10">
    <div class="flex items-center gap-4">
      <span class={`fi fi-${country.flagCode} rounded text-3xl`} aria-hidden="true"></span>
      <h1 class="text-3xl font-semibold tracking-tight md:text-4xl">
        Anime en streaming en {country.name}
      </h1>
    </div>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
      {providers.length} plataforma{providers.length === 1 ? '' : 's'} con catálogo de anime detectada{providers.length === 1 ? '' : 's'} en {country.name}.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    <h2 class="mb-6 text-2xl font-semibold">Plataformas</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {providers.map((p) => {
        const platform = getPlatform(p.slug);
        const displayName = platform?.name ?? p.providerName;
        return (
          <a
            href={`/plataforma/${p.slug}/${countrySlug}`}
            class="flex items-center justify-between rounded-xl border border-surface-2 bg-surface-1 p-5 transition-colors hover:border-accent-violet/40"
          >
            <div class="flex items-center gap-4">
              <img
                src={p.logoUrl}
                alt={displayName}
                loading="lazy"
                class="h-14 w-14 rounded-lg object-cover ring-1 ring-surface-2"
              />
              <div>
                <h3 class="text-base font-semibold text-fg-primary">{displayName}</h3>
                <p class="mt-1 text-sm text-fg-muted">
                  {p.animeCount} anime{p.animeCount === 1 ? '' : 's'}
                </p>
              </div>
            </div>
            <span class="text-fg-muted">→</span>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
