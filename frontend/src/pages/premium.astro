---
import BaseLayout from '@/layouts/BaseLayout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
const publishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY ?? 'pk_test_REEMPLAZAR';
---
<BaseLayout
  title="Premium DondeAnime"
  description="Plan Premium de DondeAnime con experiencia sin anuncios y mejoras para usuarios frecuentes."
>
  <section
    class="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-[1fr_24rem]"
    data-premium-page
    data-api-url={apiUrl}
    data-stripe-key={publishableKey}
  >
    <div class="space-y-8">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase text-warning">Premium</p>
        <h1 class="mt-2 text-4xl font-semibold text-fg-primary md:text-5xl">
          Premium DondeAnime
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-fg-secondary">
          Una versi&oacute;n sin anuncios para consultar estrenos, plataformas y fichas con menos ruido.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <p class="text-sm font-semibold text-fg-primary">Sin anuncios</p>
          <p class="mt-2 text-sm leading-6 text-fg-secondary">
            Los slots AdSense se ocultan cuando el navegador marca la cuenta como Premium.
          </p>
        </div>
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <p class="text-sm font-semibold text-fg-primary">Soporte al proyecto</p>
          <p class="mt-2 text-sm leading-6 text-fg-secondary">
            Ayuda a mantener el cat&aacute;logo, alertas y mejoras sin depender solo de afiliados.
          </p>
        </div>
        <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
          <p class="text-sm font-semibold text-fg-primary">Base para futuras ventajas</p>
          <p class="mt-2 text-sm leading-6 text-fg-secondary">
            La infraestructura queda lista para activar ventajas reales desde Stripe.
          </p>
        </div>
      </div>

      <section aria-labelledby="premium-comparison" class="overflow-hidden rounded-lg border border-surface-2">
        <div class="border-b border-surface-2 bg-surface-1 px-5 py-4">
          <h2 id="premium-comparison" class="text-xl font-semibold text-fg-primary">
            Free vs Premium
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[38rem] text-left text-sm">
            <thead class="bg-surface-1 text-xs uppercase text-fg-muted">
              <tr>
                <th class="px-5 py-3 font-semibold">Funci&oacute;n</th>
                <th class="px-5 py-3 font-semibold">Free</th>
                <th class="px-5 py-3 font-semibold">Premium</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-2 text-fg-secondary">
              <tr>
                <td class="px-5 py-4 text-fg-primary">Cat&aacute;logo y fichas SEO</td>
                <td class="px-5 py-4">Incluido</td>
                <td class="px-5 py-4">Incluido</td>
              </tr>
              <tr>
                <td class="px-5 py-4 text-fg-primary">Alertas de estrenos</td>
                <td class="px-5 py-4">Incluido</td>
                <td class="px-5 py-4">Incluido</td>
              </tr>
              <tr>
                <td class="px-5 py-4 text-fg-primary">Anuncios display</td>
                <td class="px-5 py-4">Pueden mostrarse</td>
                <td class="px-5 py-4">Ocultos</td>
              </tr>
              <tr>
                <td class="px-5 py-4 text-fg-primary">Badge de estado</td>
                <td class="px-5 py-4">No</td>
                <td class="px-5 py-4">S&iacute;</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <aside class="h-fit rounded-lg border border-surface-2 bg-surface-1 p-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold text-fg-secondary">Plan mensual</p>
          <p class="mt-2 text-4xl font-semibold text-fg-primary">3,99&nbsp;&euro;</p>
        </div>
        <span class="rounded-md border border-warning/40 bg-warning/10 px-2 py-1 text-xs font-semibold text-warning">
          Test mode
        </span>
      </div>

      <form class="mt-6 space-y-4" data-premium-checkout-form>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-fg-secondary">Email</span>
          <input
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="tu@email.com"
            class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none transition-colors focus:border-warning"
          />
        </label>
        <button
          type="submit"
          class="w-full rounded-md bg-warning px-4 py-2.5 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
        >
          Ir a checkout
        </button>
        <button
          type="button"
          class="w-full rounded-md border border-surface-2 px-4 py-2.5 text-sm font-semibold text-fg-secondary transition-colors hover:border-warning hover:text-warning"
          data-premium-portal-button
        >
          Gestionar suscripci&oacute;n
        </button>
        <p class="min-h-5 text-sm text-fg-muted" data-premium-status></p>
      </form>

      <p class="mt-4 text-xs leading-5 text-fg-muted">
        Checkout preparado con Stripe en modo test. La activaci&oacute;n real depende del webhook del backend.
      </p>
    </aside>
  </section>

  <script>
    const root = document.querySelector('[data-premium-page]');
    const apiUrl = root?.getAttribute('data-api-url') ?? '';
    const stripeKey = root?.getAttribute('data-stripe-key') ?? '';
    const form = document.querySelector('[data-premium-checkout-form]');
    const portalButton = document.querySelector('[data-premium-portal-button]');
    const status = document.querySelector('[data-premium-status]');

    const setStatus = (message, tone = 'muted') => {
      if (!status) return;
      status.textContent = message;
      status.className = `min-h-5 text-sm ${tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'}`;
    };

    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === '1') {
      try {
        localStorage.setItem('dondeanime-premium', 'true');
        localStorage.setItem('dondeanime-premium-tier', 'Premium');
        localStorage.removeItem('dondeanime-premium-source-list');
      } catch (error) {}
      setStatus('Premium activo en este navegador.', 'success');
    } else if (params.get('canceled') === '1') {
      setStatus('Checkout cancelado. No se ha cambiado tu plan.');
    } else if (params.get('manage') === '1') {
      setStatus('Introduce tu email para abrir el portal de cliente.');
    } else if (params.get('portal') === '1') {
      setStatus('Portal de cliente cerrado.');
    }

    const currentEmail = () => {
      if (!(form instanceof HTMLFormElement)) return '';
      const data = new FormData(form);
      return String(data.get('email') ?? '').trim();
    };

    const sourceListSlug = () => {
      try {
        return localStorage.getItem('dondeanime-premium-source-list') || '';
      } catch (error) {
        return '';
      }
    };

    const redirectToPremiumUrl = async (path, email) => {
      const payload = path.endsWith('/checkout')
        ? { email, sourceListSlug: sourceListSlug() }
        : { email };
      const response = await fetch(`${apiUrl}${path}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) return false;

      const body = await response.json();
      if (!body.url) return false;

      window.location.href = body.url;
      return true;
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!apiUrl) {
        setStatus('API no configurada.', 'danger');
        return;
      }

      if (!stripeKey.startsWith('pk_test_')) {
        setStatus('Clave publica Stripe test no configurada.', 'danger');
        return;
      }

      const email = currentEmail();
      if (!email) {
        setStatus('Introduce un email.', 'danger');
        return;
      }

      try {
        localStorage.setItem('dondeanime-premium-email', email);
      } catch (error) {}

      setStatus('Creando checkout...');
      if (!(await redirectToPremiumUrl('/api/premium/checkout', email))) {
        setStatus('No se pudo crear el checkout.', 'danger');
      }
    });

    portalButton?.addEventListener('click', async () => {
      if (!apiUrl) {
        setStatus('API no configurada.', 'danger');
        return;
      }

      const email = currentEmail();
      if (!email) {
        setStatus('Introduce un email.', 'danger');
        return;
      }

      // Por seguridad el backend NO devuelve la URL del portal: la envía al
      // email del titular. Respuesta genérica para no revelar quién es
      // suscriptor. Deshabilitamos el botón para evitar envíos duplicados.
      const button = portalButton instanceof HTMLButtonElement ? portalButton : null;
      if (button) button.disabled = true;
      setStatus('Enviando enlace del portal...');
      try {
        const response = await fetch(`${apiUrl}/api/premium/portal`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (response.ok) {
          setStatus('Si tienes una suscripción activa, te hemos enviado un enlace a tu email.', 'success');
        } else {
          setStatus('No se pudo procesar la solicitud. Inténtalo más tarde.', 'danger');
        }
      } catch (error) {
        setStatus('No se pudo conectar con el servidor.', 'danger');
      } finally {
        if (button) button.disabled = false;
      }
    });
  </script>
</BaseLayout>
