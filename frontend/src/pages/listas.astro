---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { getAnimeBySlug, getCuratedListBySlug, getCuratedLists, type AnimeDetail } from '@/lib/api';
import {
  DURATION_FILTERS,
  buildCuratedListMarketplaceItem,
  curatedListTitlePreview,
  defaultCountryOptions,
  defaultPlatformOptions,
  mergeFilterOptions,
} from '@/lib/curatedLists';
import { absoluteUrl, buildItemListSchema } from '@/lib/seo';
import { getPlatform } from '@/lib/platforms';
import { setLocale } from '@/i18n';

setLocale('es');

const summaries = await getCuratedLists();
const detailResults = await Promise.all(
  summaries.map(async (summary) => {
    try {
      return await getCuratedListBySlug(summary.slug);
    } catch {
      return null;
    }
  }),
);
const details = detailResults.filter((detail): detail is NonNullable<typeof detail> => detail !== null);
const animeSlugs = Array.from(new Set(details.flatMap((list) => list.items.map((item) => item.animeSlug))));
const animeDetails = await Promise.all(
  animeSlugs.map(async (slug) => {
    try {
      return await getAnimeBySlug(slug);
    } catch {
      return null;
    }
  }),
);
const animeDetailBySlug = new Map<string, AnimeDetail>(
  animeDetails
    .filter((detail): detail is AnimeDetail => detail !== null)
    .map((detail) => [detail.anime.slug, detail]),
);
const marketplaceLists = details.map((list) =>
  buildCuratedListMarketplaceItem(list, animeDetailBySlug),
);

const genreOptions = mergeFilterOptions(marketplaceLists, 'genreOptions');
const countryOptions = mergeFilterOptions(marketplaceLists, 'countryOptions');
const platformOptions = mergeFilterOptions(marketplaceLists, 'platformOptions');
const durationOptions = mergeFilterOptions(marketplaceLists, 'durationOptions');
const selectableCountries = countryOptions.length > 0 ? countryOptions : defaultCountryOptions();
const selectablePlatforms = platformOptions.length > 0 ? platformOptions : defaultPlatformOptions();
const selectableDurations = durationOptions.length > 0 ? durationOptions : DURATION_FILTERS;

const seoTitle = 'Listas curadas de anime | DondeAnime';
const seoDescription = 'Listas públicas de anime para descubrir qué ver según género, plataforma, país y duración.';
const pageUrl = absoluteUrl('/listas');
const itemListSchema = buildItemListSchema(
  marketplaceLists.map((item) => ({
    name: item.list.title,
    url: absoluteUrl(`/listas/${item.list.slug}`),
  })),
  pageUrl,
  'Listas curadas de anime',
);
---
<BaseLayout title={seoTitle} description={seoDescription} image={absoluteUrl('/og-listas.png')}>
  <JsonLd slot="head" data={itemListSchema} />

  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: 'Listas', url: '/listas' },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-6">
    <img
      src="/heroes/hero-listas.svg"
      alt=""
      width="2200"
      height="680"
      loading="eager"
      decoding="async"
      class="w-full rounded-2xl ring-1 ring-surface-2/60"
    />
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-8">
    <p class="text-xs uppercase tracking-wide text-accent-violet">Listas curadas</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">
      Listas curadas de anime
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
      Selecciones compactas para encontrar anime por intención real: empezar rápido, ver algo corto o cruzar gustos con plataformas disponibles.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20" data-list-marketplace>
    <form
      class="grid gap-3 rounded-lg border border-surface-2 bg-surface-1 p-4 md:grid-cols-[repeat(4,minmax(0,1fr))_auto]"
      data-list-filters
    >
      <label class="grid gap-1 text-sm">
        <span class="text-xs font-semibold uppercase tracking-wide text-fg-muted">Género</span>
        <select data-filter="genre" class="rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-fg-primary">
          <option value="">Todos</option>
          {genreOptions.map((option) => (
            <option value={option.slug}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="grid gap-1 text-sm">
        <span class="text-xs font-semibold uppercase tracking-wide text-fg-muted">País</span>
        <select data-filter="country" class="rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-fg-primary">
          <option value="">Todos</option>
          {selectableCountries.map((option) => (
            <option value={option.slug}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="grid gap-1 text-sm">
        <span class="text-xs font-semibold uppercase tracking-wide text-fg-muted">Plataforma</span>
        <select data-filter="platform" class="rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-fg-primary">
          <option value="">Todas</option>
          {selectablePlatforms.map((option) => (
            <option value={option.slug}>{option.label}</option>
          ))}
        </select>
      </label>

      <label class="grid gap-1 text-sm">
        <span class="text-xs font-semibold uppercase tracking-wide text-fg-muted">Duración</span>
        <select data-filter="duration" class="rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-fg-primary">
          <option value="">Todas</option>
          {selectableDurations.map((option) => (
            <option value={option.slug}>{option.label}</option>
          ))}
        </select>
      </label>

      <button
        type="button"
        class="self-end rounded-md border border-surface-2 px-4 py-2 text-sm text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary"
        data-clear-filters
      >
        Limpiar
      </button>
    </form>

    <div class="mt-5 flex items-center justify-between gap-4 text-sm text-fg-muted">
      <p data-list-count>
        {marketplaceLists.length} {marketplaceLists.length === 1 ? 'lista' : 'listas'}
      </p>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2" data-list-grid>
      {marketplaceLists.map((item) => {
        const preview = curatedListTitlePreview(item.list);
        const platformLabel = item.platformOptions[0]
          ? getPlatform(item.platformOptions[0].slug)?.name ?? item.platformOptions[0].label
          : null;

        return (
          <article
            class="rounded-lg border border-surface-2 bg-surface-1 p-4 transition-colors hover:border-accent-violet/50"
            data-list-card
            data-genres={item.genreTokens.join(' ')}
            data-countries={item.countryTokens.join(' ')}
            data-platforms={item.platformTokens.join(' ')}
            data-country-platforms={item.countryPlatformTokens.join(' ')}
            data-durations={item.durationTokens.join(' ')}
          >
            <a href={`/listas/${item.list.slug}`} class="grid gap-4 sm:grid-cols-[7rem_1fr]">
              <div class="grid h-24 grid-cols-4 gap-1 overflow-hidden rounded-lg bg-surface-2 sm:h-32">
                {item.coverImages.length > 0 ? (
                  item.coverImages.map((cover, index) => (
                    <img
                      src={cover}
                      alt=""
                      loading={index === 0 ? 'eager' : 'lazy'}
                      class="h-full w-full object-cover"
                    />
                  ))
                ) : (
                  <div class="col-span-4 flex items-center justify-center text-xs text-fg-muted">
                    Sin portada
                  </div>
                )}
              </div>

              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2 text-xs text-fg-muted">
                  <span>{item.list.itemCount ?? item.list.items.length} anime</span>
                  {item.durationOptions[0] && <span>&middot; {item.durationOptions[0].label}</span>}
                  {platformLabel && <span>&middot; {platformLabel}</span>}
                  {item.list.premiumOnly && <span class="rounded bg-accent-violet/15 px-2 py-0.5 text-accent-violet">Premium</span>}
                </div>
                <h2 class="mt-2 text-xl font-semibold text-fg-primary transition-colors hover:text-accent-violet">
                  {item.list.title}
                </h2>
                {item.list.description && (
                  <p class="mt-2 line-clamp-2 text-sm text-fg-secondary">{item.list.description}</p>
                )}
                {preview && (
                  <p class="mt-3 line-clamp-1 text-xs text-fg-muted">{preview}</p>
                )}
                <div class="mt-4 flex flex-wrap gap-2">
                  {item.genreOptions.slice(0, 3).map((genre) => (
                    <span class="rounded-md bg-surface-2 px-2 py-1 text-xs text-fg-secondary">
                      {genre.label}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          </article>
        );
      })}
    </div>

    <p
      class="mt-6 rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary"
      data-list-empty
      hidden={marketplaceLists.length > 0}
    >
      Todavía no hay listas públicas. Cuando el backend de Sprint 24 esté desplegado, aparecerán aquí sin tocar esta página.
    </p>
    <p
      class="mt-6 rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary"
      data-filter-empty
      hidden
    >
      No hay listas con esos filtros.
    </p>
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-list-marketplace]');
      if (!root) return;

      const cards = Array.from(root.querySelectorAll('[data-list-card]'));
      const count = root.querySelector('[data-list-count]');
      const empty = root.querySelector('[data-list-empty]');
      const filterEmpty = root.querySelector('[data-filter-empty]');
      const controls = {
        genre: root.querySelector('[data-filter="genre"]'),
        country: root.querySelector('[data-filter="country"]'),
        platform: root.querySelector('[data-filter="platform"]'),
        duration: root.querySelector('[data-filter="duration"]'),
      };

      const values = () => ({
        genre: controls.genre?.value || '',
        country: controls.country?.value || '',
        platform: controls.platform?.value || '',
        duration: controls.duration?.value || '',
      });

      const hasAnyFilter = (current) =>
        Boolean(current.genre || current.country || current.platform || current.duration);

      const tokens = (card, key) =>
        new Set((card.dataset[key] || '').split(/\s+/).filter(Boolean));

      const matches = (card, current) => {
        if (current.genre && !tokens(card, 'genres').has(current.genre)) return false;
        if (current.duration && !tokens(card, 'durations').has(current.duration)) return false;

        if (current.country && current.platform) {
          return tokens(card, 'countryPlatforms').has(`${current.country}:${current.platform}`);
        }
        if (current.country && !tokens(card, 'countries').has(current.country)) return false;
        if (current.platform && !tokens(card, 'platforms').has(current.platform)) return false;
        return true;
      };

      const setFromUrl = () => {
        const params = new URLSearchParams(window.location.search);
        for (const [key, control] of Object.entries(controls)) {
          if (!control) continue;
          if (key === 'genre') control.value = params.get('genero') || params.get('genre') || '';
          else if (key === 'country') control.value = params.get('pais') || params.get('country') || '';
          else if (key === 'platform') control.value = params.get('plataforma') || params.get('platform') || '';
          else control.value = params.get('duracion') || params.get('duration') || '';
        }
      };

      const updateUrl = () => {
        const current = values();
        const params = new URLSearchParams();
        if (current.genre) params.set('genero', current.genre);
        if (current.country) params.set('pais', current.country);
        if (current.platform) params.set('plataforma', current.platform);
        if (current.duration) params.set('duracion', current.duration);
        const query = params.toString();
        window.history.replaceState(null, '', query ? `/listas?${query}` : '/listas');
      };

      const apply = () => {
        const current = values();
        let visible = 0;
        for (const card of cards) {
          const show = matches(card, current);
          card.hidden = !show;
          if (show) visible += 1;
        }

        if (count) count.textContent = `${visible} ${visible === 1 ? 'lista' : 'listas'}`;
        if (empty) empty.hidden = cards.length > 0 || hasAnyFilter(current);
        if (filterEmpty) filterEmpty.hidden = cards.length === 0 || visible > 0;
      };

      setFromUrl();
      apply();

      for (const control of Object.values(controls)) {
        control?.addEventListener('change', () => {
          updateUrl();
          apply();
        });
      }

      root.querySelector('[data-clear-filters]')?.addEventListener('click', () => {
        for (const control of Object.values(controls)) {
          if (control) control.value = '';
        }
        updateUrl();
        apply();
      });
    })();
  </script>
</BaseLayout>
