---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import AnimePicture from '@/components/anime/AnimePicture.astro';
import { getCuratedListBySlug, getCuratedLists } from '@/lib/api';
import { formatType } from '@/lib/format';
import { absoluteUrl, buildItemListSchema } from '@/lib/seo';
import { setLocale } from '@/i18n';

setLocale('es');

export async function getStaticPaths() {
  const lists = await getCuratedLists();
  return lists.map((list) => ({ params: { slug: list.slug } }));
}

const { slug } = Astro.params;
const list = await getCuratedListBySlug(slug!);
const items = (list.items ?? []).toSorted((a, b) => a.position - b.position);
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'https://api.dondeanime.com';
const titles = items
  .map((item) => item.anime?.titleEnglish || item.anime?.titleRomaji || item.animeSlug)
  .slice(0, 4);
const seoTitle = `${list.title} | Listas curadas | DondeAnime`;
const seoDescription = list.description
  ?? `Lista curada con ${titles.join(', ')} y más anime para descubrir qué ver.`;
const schema = list.schema ?? buildItemListSchema(
  items.map((item) => ({
    name: item.anime?.titleEnglish || item.anime?.titleRomaji || item.animeSlug,
    url: absoluteUrl(`/anime/${item.animeSlug}`),
  })),
  absoluteUrl(`/listas/${list.slug}`),
  list.title,
);
---
<BaseLayout title={seoTitle} description={seoDescription} image={absoluteUrl('/og-listas.png')}>
  <JsonLd slot="head" data={schema} />

  <Breadcrumbs
    items={[
      { name: 'Inicio', url: '/' },
      { name: 'Listas', url: '/listas' },
      { name: list.title, url: `/listas/${list.slug}` },
    ]}
  />

  <section
    class="mx-auto max-w-6xl px-4 pt-8 pb-10"
    data-list-detail
    data-list-slug={list.slug}
    data-api-url={apiUrl}
    data-premium-preview={String(list.premiumPreview)}
  >
    <p class="text-xs uppercase tracking-wide text-accent-violet">Lista curada</p>
    <h1 class="mt-2 max-w-3xl text-4xl font-semibold tracking-tight md:text-5xl">
      {list.title}
    </h1>
    {list.description && (
      <p class="mt-4 max-w-2xl text-lg text-fg-secondary">{list.description}</p>
    )}
    <div class="mt-5 flex flex-wrap gap-2 text-sm text-fg-muted">
      <span class="rounded-md bg-surface-1 px-3 py-2" data-list-item-count>{list.itemCount ?? items.length} anime</span>
      {list.owner && <span class="rounded-md bg-surface-1 px-3 py-2">Curador: {list.owner}</span>}
      <span class="rounded-md bg-surface-1 px-3 py-2">{list.status}</span>
      {list.premiumOnly && <span class="rounded-md bg-accent-violet/15 px-3 py-2 text-accent-violet">Premium</span>}
    </div>

    {list.premiumPreview && (
      <div class="mt-6 max-w-2xl rounded-lg border border-accent-violet/40 bg-surface-1 p-5" data-premium-preview>
        <h2 class="text-lg font-semibold text-fg-primary">Preview Premium</h2>
        <p class="mt-2 text-sm text-fg-secondary">
          Esta lista muestra los primeros anime. La lista completa está incluida en Premium.
        </p>
        <a
          href={list.premiumCtaUrl ?? '/premium'}
          class="mt-4 inline-flex rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
          data-premium-click
        >
          Ver Premium
        </a>
      </div>
    )}
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20" data-list-items-region>
    {items.length === 0 ? (
      <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
        Esta lista aún no tiene anime publicados.
      </p>
    ) : (
      <ol class="grid gap-4">
        {items.map((item) => {
          const anime = item.anime;
          const title = anime?.titleEnglish || anime?.titleRomaji || item.animeSlug;

          return (
            <li class="grid gap-4 rounded-lg border border-surface-2 bg-surface-1 p-4 sm:grid-cols-[3.5rem_6rem_1fr] sm:items-start">
              <div class="flex h-10 w-14 items-center justify-center rounded-md bg-surface-2 text-sm font-semibold text-accent-violet">
                #{item.position}
              </div>
              {anime ? (
                <a href={`/anime/${anime.slug}`} class="block w-24 sm:w-full">
                  <AnimePicture
                    src={anime.coverImage}
                    alt={title}
                    width={240}
                    height={360}
                    loading={item.position <= 3 ? 'eager' : 'lazy'}
                    class="block aspect-[2/3] w-full overflow-hidden rounded-lg bg-surface-2 ring-1 ring-surface-2"
                    imgClass="h-full w-full object-cover"
                  />
                </a>
              ) : (
                <div class="aspect-[2/3] w-24 rounded-lg bg-surface-2 sm:w-full" />
              )}
              <div class="min-w-0">
                <a
                  href={`/anime/${item.animeSlug}`}
                  class="text-xl font-semibold text-fg-primary transition-colors hover:text-accent-violet"
                  data-list-anime-click
                  data-anime-slug={item.animeSlug}
                >
                  {title}
                </a>
                {anime && (
                  <p class="mt-2 text-sm text-fg-muted">
                    {anime.year ?? '---'} &middot; {formatType(anime.format)} &middot; {anime.averageScore ?? 'sin nota'}
                  </p>
                )}
                {item.note && (
                  <p class="mt-3 text-sm text-fg-secondary">{item.note}</p>
                )}
                {anime?.genres?.length ? (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {anime.genres.slice(0, 4).map((genre) => (
                      <span class="rounded-md bg-surface-2 px-2 py-1 text-xs text-fg-secondary">
                        {genre}
                      </span>
                    ))}
                  </div>
                ) : null}
              </div>
            </li>
          );
        })}
      </ol>
    )}
  </section>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-list-detail]');
      if (!root) return;
      const apiUrl = root.getAttribute('data-api-url') || '';
      const listSlug = root.getAttribute('data-list-slug') || '';
      const post = (path, payload) => {
        if (!apiUrl || !listSlug) return;
        fetch(`${apiUrl}${path}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          keepalive: true,
        }).catch(() => {});
      };

      const escapeHtml = (value) => String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

      const formatType = (value) => {
        const map = {
          TV: 'TV',
          MOVIE: 'Película',
          OVA: 'OVA',
          ONA: 'ONA',
          SPECIAL: 'Especial',
          MUSIC: 'Música',
        };
        return map[value] || value || 'Anime';
      };

      const renderPremiumList = (detail) => {
        const items = Array.isArray(detail?.items) ? detail.items : [];
        const region = document.querySelector('[data-list-items-region]');
        const count = document.querySelector('[data-list-item-count]');
        const preview = document.querySelector('[data-premium-preview]');
        if (!region || items.length === 0) return;

        if (count) count.textContent = `${detail.itemCount ?? items.length} anime`;
        preview?.remove();

        region.innerHTML = `
          <ol class="grid gap-4">
            ${items.map((item) => {
              const anime = item.anime;
              const title = anime?.titleEnglish || anime?.titleRomaji || item.animeSlug;
              const genres = Array.isArray(anime?.genres) ? anime.genres.slice(0, 4) : [];
              return `
                <li class="grid gap-4 rounded-lg border border-surface-2 bg-surface-1 p-4 sm:grid-cols-[3.5rem_6rem_1fr] sm:items-start">
                  <div class="flex h-10 w-14 items-center justify-center rounded-md bg-surface-2 text-sm font-semibold text-accent-violet">
                    #${escapeHtml(item.position)}
                  </div>
                  ${anime?.coverImage ? `
                    <a href="/anime/${escapeHtml(anime.slug)}" class="block w-24 sm:w-full">
                      <img
                        src="${escapeHtml(anime.coverImage)}"
                        alt="${escapeHtml(title)}"
                        width="240"
                        height="360"
                        loading="lazy"
                        class="block aspect-[2/3] w-full overflow-hidden rounded-lg bg-surface-2 object-cover ring-1 ring-surface-2"
                      />
                    </a>
                  ` : '<div class="aspect-[2/3] w-24 rounded-lg bg-surface-2 sm:w-full"></div>'}
                  <div class="min-w-0">
                    <a
                      href="/anime/${escapeHtml(item.animeSlug)}"
                      class="text-xl font-semibold text-fg-primary transition-colors hover:text-accent-violet"
                      data-list-anime-click
                      data-anime-slug="${escapeHtml(item.animeSlug)}"
                    >
                      ${escapeHtml(title)}
                    </a>
                    ${anime ? `
                      <p class="mt-2 text-sm text-fg-muted">
                        ${escapeHtml(anime.year ?? '---')} &middot; ${escapeHtml(formatType(anime.format))} &middot; ${escapeHtml(anime.averageScore ?? 'sin nota')}
                      </p>
                    ` : ''}
                    ${item.note ? `<p class="mt-3 text-sm text-fg-secondary">${escapeHtml(item.note)}</p>` : ''}
                    ${genres.length ? `
                      <div class="mt-4 flex flex-wrap gap-2">
                        ${genres.map((genre) => `
                          <span class="rounded-md bg-surface-2 px-2 py-1 text-xs text-fg-secondary">
                            ${escapeHtml(genre)}
                          </span>
                        `).join('')}
                      </div>
                    ` : ''}
                  </div>
                </li>
              `;
            }).join('')}
          </ol>
        `;
      };

      const loadVerifiedPremiumList = async () => {
        if (root.getAttribute('data-premium-preview') !== 'true') return;
        if (!apiUrl || !listSlug) return;
        let token = '';
        try {
          token = localStorage.getItem('dondeanime-premium-token') || '';
        } catch (error) {}
        if (!token) return;

        try {
          const response = await fetch(`${apiUrl}/api/lists/${listSlug}`, {
            headers: { Authorization: `Bearer ${token}` },
          });
          if (!response.ok) return;
          const detail = await response.json();
          if (detail?.premiumPreview === false) {
            renderPremiumList(detail);
          }
        } catch (error) {}
      };

      post('/api/track/lists/view', { listSlug });
      loadVerifiedPremiumList();

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const animeLink = target?.closest('[data-list-anime-click]');
        if (animeLink) {
          post('/api/track/lists/anime-click', {
            listSlug,
            animeSlug: animeLink.getAttribute('data-anime-slug') || '',
          });
        }

        const premiumLink = target?.closest('[data-premium-click]');
        if (premiumLink) {
          try {
            localStorage.setItem('dondeanime-premium-source-list', listSlug);
          } catch (error) {}
          post('/api/track/lists/premium-click', { listSlug });
        }
      });
    })();
  </script>
</BaseLayout>
