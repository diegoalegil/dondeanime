---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import NewsList from '@/components/news/NewsList.astro';
import NewsPager from '@/components/news/NewsPager.astro';
import { getNews } from '@/lib/api';
import { NEWS_PAGE_SIZE, newsPageCount } from '@/lib/newsPagination';
import { absoluteUrl, buildItemListSchema } from '@/lib/seo';
import { setLocale, t } from '@/i18n';

setLocale('es');

const news = await getNews(100);
const items = news.slice(0, NEWS_PAGE_SIZE);
const totalPages = newsPageCount(news.length);
const pageUrl = absoluteUrl('/noticias');
const itemList = buildItemListSchema(
  items.map((n) => ({ name: n.title, url: absoluteUrl(`/noticias/${n.slug}`) })),
  pageUrl,
  t('news.index.heading'),
);
---
{/* suppressAlternates: /en/news canonicaliza aquí (contenido sin traducir). */}
<BaseLayout title={t('news.index.title')} description={t('news.index.description')} canonical={pageUrl} image={absoluteUrl('/og-news.png')} suppressAlternates>
  <link
    slot="head"
    rel="alternate"
    type="application/rss+xml"
    title={t('news.rss.title')}
    href={absoluteUrl('/noticias/rss.xml')}
  />
  {totalPages > 1 && <link slot="head" rel="next" href={absoluteUrl('/noticias/pagina/2')} />}
  {items.length > 0 && <JsonLd slot="head" data={itemList} />}

  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.news'), url: '/noticias' },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-20">
    <div class="flex flex-col items-center gap-6 md:flex-row md:items-center md:justify-between md:gap-10">
      <div class="text-center md:text-left">
        <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">{t('news.index.heading')}</h1>
        <p class="mt-4 max-w-2xl text-lg text-fg-secondary">{t('news.index.description')}</p>
      </div>
      <img
        src="/mascota-noticias.webp"
        alt=""
        width="376"
        height="680"
        loading="eager"
        decoding="async"
        class="h-40 w-auto shrink-0 drop-shadow-[0_10px_30px_rgba(0,0,0,0.45)] sm:h-48 md:h-60"
      />
    </div>

    <div class="mt-10">
      {items.length === 0 ? (
        <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
          {t('news.index.empty')}
        </p>
      ) : (
        <NewsList items={items} />
      )}
    </div>

    <NewsPager page={1} totalPages={totalPages} indexPath="/noticias" pagePathPrefix="/noticias/pagina" />
  </section>
</BaseLayout>
