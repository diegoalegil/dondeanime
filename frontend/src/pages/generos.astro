---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import { getGenres } from '@/lib/api';
import { localizedGenreName } from '@/lib/genres';
import { absoluteUrl } from '@/lib/seo';
import { DURATION_MINUTES, EPISODE_LIMITS, durationPath, episodeLimitPath } from '@/lib/programmaticSeo';
import { setLocale, t } from '@/i18n';

setLocale('es');

const genres = (await getGenres())
  .slice()
  .sort((a, b) => b.animeCount - a.animeCount);
---
<BaseLayout
  title="Géneros de anime — todos los géneros y dónde verlos | DondeAnime"
  description="Explora el anime por género: acción, romance, terror, comedia y más, con en qué plataformas de streaming ver cada serie en Hispanoamérica."
  image={absoluteUrl('/og-genero.png')}
>
  <Breadcrumbs
    items={[
      { name: t('breadcrumbs.home'), url: '/' },
      { name: t('breadcrumbs.genres'), url: '/generos' },
    ]}
  />

  <section class="mx-auto max-w-6xl px-4 pt-8 pb-4">
    <p class="text-xs uppercase tracking-wide text-accent-violet">Catálogo por género</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight md:text-5xl">Anime por género</h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-secondary">
      Cada género de anime, de más a menos catálogo. Abre uno para ver sus series y en qué plataformas verlas.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20">
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
      {genres.map((g) => (
        <li>
          <a
            href={`/genero/${g.slug}`}
            class="flex items-center justify-between rounded-lg border border-surface-2 bg-surface-1 px-4 py-3 transition-colors hover:border-accent-violet/60"
          >
            <span class="font-medium text-fg-primary">{localizedGenreName(g.slug, g.name)}</span>
            <span class="text-xs text-fg-muted">{g.animeCount}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mx-auto max-w-6xl border-t border-surface-2 px-4 pt-10 pb-20">
    <h2 class="text-2xl font-semibold tracking-tight">Explora también por</h2>
    <div class="mt-6 grid gap-8 sm:grid-cols-2">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-fg-secondary">Duración por episodio</h3>
        <ul class="mt-3 flex flex-wrap gap-2">
          {DURATION_MINUTES.map((m) => (
            <li>
              <a
                href={durationPath(m)}
                class="inline-flex rounded-full border border-surface-2 bg-surface-1 px-3 py-1.5 text-sm text-fg-secondary transition-colors hover:border-accent-violet/60 hover:text-fg-primary"
              >
                Hasta {m} min
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-fg-secondary">Número de episodios</h3>
        <ul class="mt-3 flex flex-wrap gap-2">
          {EPISODE_LIMITS.map((n) => (
            <li>
              <a
                href={episodeLimitPath(n)}
                class="inline-flex rounded-full border border-surface-2 bg-surface-1 px-3 py-1.5 text-sm text-fg-secondary transition-colors hover:border-accent-violet/60 hover:text-fg-primary"
              >
                {n} episodios o menos
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
