---
import { COUNTRIES, COUNTRY_SLUGS } from '@/lib/countries';
import { PLATFORMS, type PlatformSlug } from '@/lib/platforms';
import JsonLd from '@/components/seo/JsonLd.astro';
import { buildOrganizationSchema } from '@/lib/seo';
import { t } from '@/i18n';

const year = new Date().getFullYear();
const organizationSchema = buildOrganizationSchema();
const featuredPlatforms: PlatformSlug[] = [
  'crunchyroll',
  'netflix',
  'amazon-prime-video',
  'hbo-max',
  'disney-plus',
];
const featuredGenres = [
  { slug: 'action', name: t('footer.genre.action') },
  { slug: 'drama', name: t('footer.genre.drama') },
  { slug: 'comedy', name: t('footer.genre.comedy') },
  { slug: 'adventure', name: t('footer.genre.adventure') },
  { slug: 'romance', name: t('footer.genre.romance') },
];
---
<footer class="mt-16 border-t border-surface-2 bg-surface-1">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div>
        <p class="text-base font-semibold brand-gradient-text">{t('brand.name')}</p>
        <p class="mt-3 text-sm text-fg-muted">
          {t('footer.tagline')}
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-fg-secondary">{t('footer.countries')}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {COUNTRY_SLUGS.map((slug) => {
            const c = COUNTRIES[slug];
            return (
              <li>
                <a href={`/pais/${slug}`} class="flex items-center gap-2 text-fg-muted transition-colors hover:text-fg-primary">
                  <span class={`fi fi-${c.flagCode} rounded`} aria-hidden="true"></span>
                  {c.name}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-fg-secondary">{t('footer.platforms')}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {featuredPlatforms.map((slug) => (
            <li>
              <a href={`/plataforma/${slug}`} class="text-fg-muted transition-colors hover:text-fg-primary">
                {PLATFORMS[slug].name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-fg-secondary">{t('footer.genres')}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {featuredGenres.map((g) => (
            <li>
              <a href={`/genero/${g.slug}`} class="text-fg-muted transition-colors hover:text-fg-primary">
                {g.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-surface-2 pt-6 text-xs text-fg-muted sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {t('brand.name')}. {t('footer.dataAttribution')}</p>
      <p class="sm:text-right">
        <a href="/legal/privacidad" class="transition-colors hover:text-fg-primary">{t('footer.privacy')}</a>
        <span class="mx-2">&middot;</span>
        {t('footer.affiliateDisclosure')}
        <a href="/legal/afiliados" class="transition-colors hover:text-fg-primary">{t('footer.moreInfo')}</a>
        <span class="mx-2">&middot;</span>
        {t('footer.noHosting')}
      </p>
    </div>
  </div>
  <JsonLd data={organizationSchema} />
</footer>
