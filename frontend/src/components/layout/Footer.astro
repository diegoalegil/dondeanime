---
import { COUNTRIES, COUNTRY_SLUGS } from '@/lib/countries';
import { PLATFORMS, type PlatformSlug } from '@/lib/platforms';
import JsonLd from '@/components/seo/JsonLd.astro';
import { buildOrganizationSchema } from '@/lib/seo';
import { t } from '@/i18n';
import { localizedCountryName, localizedPath } from '@/lib/localizedRoutes';
import { localizedGenreName } from '@/lib/genres';
import CountryFlag from '@/components/ui/CountryFlag.astro';

const year = new Date().getFullYear();
const organizationSchema = buildOrganizationSchema();
const featuredPlatforms: PlatformSlug[] = [
  'crunchyroll',
  'netflix',
  'amazon-prime-video',
  'hbo-max',
  'disney-plus',
];
const featuredGenres = [
  { slug: 'action', name: t('footer.genre.action') },
  { slug: 'drama', name: t('footer.genre.drama') },
  { slug: 'comedy', name: t('footer.genre.comedy') },
  { slug: 'adventure', name: t('footer.genre.adventure') },
  { slug: 'romance', name: t('footer.genre.romance') },
];
const legalLinks = [
  { href: localizedPath('/sobre'), label: t('footer.about') },
  { href: localizedPath('/contacto'), label: t('footer.contact') },
  { href: localizedPath('/legal/privacidad'), label: t('footer.privacy') },
  { href: localizedPath('/legal/cookies'), label: t('footer.cookies') },
  { href: localizedPath('/legal/terminos'), label: t('footer.terms') },
  { href: localizedPath('/legal/afiliados'), label: t('breadcrumbs.affiliates') },
];
---
<footer class="mt-16 border-t border-surface-2 bg-surface-1">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div>
        <img src="/brand/logo-lockup-horizontal-mono-white.svg" alt={t('brand.name')} width="112" height="28" class="h-7 w-auto opacity-90" />
        <p class="mt-3 text-sm text-fg-muted">
          {t('footer.tagline')}
        </p>
        <div class="mt-3 flex flex-col gap-1.5 text-sm">
          <a href={localizedPath('/temporadas')} class="text-fg-muted transition-colors hover:text-fg-primary">{t('breadcrumbs.seasons')}</a>
          <a href={localizedPath('/stickers')} class="text-fg-muted transition-colors hover:text-fg-primary">{t('footer.stickers')}</a>
        </div>
      </div>

      <div>
        <h3 class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-fg-secondary"><img src="/icons/icon-pais.svg" alt="" width="16" height="16" class="footer-section-icon h-4 w-4" />{t('footer.countries')}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {COUNTRY_SLUGS.map((slug) => {
            const c = COUNTRIES[slug];
            return (
              <li>
                <a href={localizedPath(`/pais/${slug}`)} class="flex items-center gap-2 text-fg-muted transition-colors hover:text-fg-primary">
                  <CountryFlag country={c} />
                  {localizedCountryName(slug)}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        <h3 class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-fg-secondary"><img src="/icons/icon-plataforma.svg" alt="" width="16" height="16" class="footer-section-icon h-4 w-4" />{t('footer.platforms')}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {featuredPlatforms.map((slug) => (
            <li>
              <a href={localizedPath(`/plataforma/${slug}`)} class="text-fg-muted transition-colors hover:text-fg-primary">
                {PLATFORMS[slug].name}
              </a>
            </li>
          ))}
          <li>
            <a href={localizedPath('/plataformas')} class="text-accent-violet transition-colors hover:text-fg-primary">{t('footer.allPlatforms')}</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-fg-secondary"><img src="/icons/icon-genero.svg" alt="" width="16" height="16" class="footer-section-icon h-4 w-4" />{t('footer.genres')}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {featuredGenres.map((g) => (
            <li>
              <a href={localizedPath(`/genero/${g.slug}`)} class="text-fg-muted transition-colors hover:text-fg-primary">
                {localizedGenreName(g.slug, g.name)}
              </a>
            </li>
          ))}
          <li>
            <a href={localizedPath('/generos')} class="text-accent-violet transition-colors hover:text-fg-primary">{t('footer.allGenres')}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-surface-2 pt-6 text-xs text-fg-muted sm:flex-row sm:items-start sm:justify-between">
      <div class="space-y-1">
        <p>&copy; {year} {t('brand.name')}. {t('footer.dataAttribution')}</p>
        <p>{t('footer.tmdbDisclaimer')}</p>
      </div>
      <div class="space-y-2 sm:max-w-xl sm:text-right">
        <nav class="flex flex-wrap gap-x-4 gap-y-2 sm:justify-end" aria-label="Legal">
          <a href="/api" class="transition-colors hover:text-fg-primary">{t('nav.api')}</a>
          {legalLinks.map((link) => (
            <a href={link.href} class="transition-colors hover:text-fg-primary">{link.label}</a>
          ))}
        </nav>
        <p>
          {t('footer.affiliateDisclosure')} <a href={localizedPath('/legal/afiliados')} class="transition-colors hover:text-fg-primary">{t('footer.moreInfo')}</a>
          <span class="mx-2">&middot;</span>
          {t('footer.noHosting')}
        </p>
      </div>
    </div>
  </div>
  <JsonLd data={organizationSchema} />
</footer>
