---
import { COUNTRIES, COUNTRY_SLUGS } from '@/lib/countries';
import { PLATFORMS, type PlatformSlug } from '@/lib/platforms';
import JsonLd from '@/components/seo/JsonLd.astro';
import { buildOrganizationSchema } from '@/lib/seo';
import CountryFlag from '@/components/ui/CountryFlag.astro';

const year = new Date().getFullYear();
const organizationSchema = buildOrganizationSchema();
const featuredPlatforms: PlatformSlug[] = [
  'crunchyroll',
  'netflix',
  'amazon-prime-video',
  'hbo-max',
  'disney-plus',
];
const featuredGenres = [
  { slug: 'action', name: 'Acción' },
  { slug: 'drama', name: 'Drama' },
  { slug: 'comedy', name: 'Comedia' },
  { slug: 'adventure', name: 'Aventura' },
  { slug: 'romance', name: 'Romance' },
];
---
<footer class="mt-16 border-t border-surface-2 bg-surface-1">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div>
        <p class="text-base font-semibold brand-gradient-text">DondeAnime</p>
        <p class="mt-3 text-sm text-fg-muted">
          Dónde y cuándo ver cada anime en streaming, por país.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-fg-secondary">Países</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {COUNTRY_SLUGS.map((slug) => {
            const c = COUNTRIES[slug];
            return (
              <li>
                <a href={`/pais/${slug}`} class="flex items-center gap-2 text-fg-muted transition-colors hover:text-fg-primary">
                  <CountryFlag country={c} />
                  {c.name}
                </a>
              </li>
            );
          })}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-fg-secondary">Plataformas</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {featuredPlatforms.map((slug) => (
            <li>
              <a href={`/plataforma/${slug}`} class="text-fg-muted transition-colors hover:text-fg-primary">
                {PLATFORMS[slug].name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-fg-secondary">Géneros</h3>
        <ul class="mt-3 space-y-2 text-sm">
          {featuredGenres.map((g) => (
            <li>
              <a href={`/genero/${g.slug}`} class="text-fg-muted transition-colors hover:text-fg-primary">
                {g.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-surface-2 pt-6 text-xs text-fg-muted sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} DondeAnime. Datos vía AniList y TMDb.</p>
      <p class="sm:text-right">
        <a href="/legal/privacidad" class="transition-colors hover:text-fg-primary">Privacidad</a>
        <span class="mx-2">·</span>
        Esta web contiene enlaces de afiliado.
        <a href="/legal/afiliados" class="transition-colors hover:text-fg-primary">Más info</a>
        <span class="mx-2">·</span>
        No alojamos contenido.
      </p>
    </div>
  </div>
  <JsonLd data={organizationSchema} />
</footer>
