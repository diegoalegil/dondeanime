---
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import SearchBox from '@/components/ui/SearchBox.astro';
import LanguageSwitcher from '@/components/ui/LanguageSwitcher.astro';
import { t, getLocale } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

const showLanguageSwitcher = !Astro.url.pathname.startsWith('/admin');
// /listas (marketplace de listas curadas) es solo-ES: no existe /en/listas, así
// que enlazarlo en EN daba 404. Se oculta hasta que haya versión inglesa.
const isSpanish = getLocale() === 'es';
---
<header class="sticky top-0 z-50 border-b border-surface-2 bg-surface-1/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href={localizedPath('/')} class="inline-flex items-center" aria-label={t('brand.name')}>
      <img src="/brand/logo-lockup-horizontal.svg" alt={t('brand.name')} width="128" height="32" class="hidden h-8 w-auto sm:block" />
      <img src="/brand/isotype.svg" alt={t('brand.name')} width="32" height="32" class="h-8 w-8 sm:hidden" />
    </a>
    <nav aria-label={t('nav.primary')} class="hidden items-center gap-5 text-sm text-fg-secondary md:flex">
      <a href={localizedPath('/')} class="transition-colors hover:text-fg-primary">{t('nav.catalog')}</a>
      {isSpanish && <a href="/listas" class="transition-colors hover:text-fg-primary">{t('nav.lists')}</a>}
      <a href={localizedPath('/pais/espana')} class="transition-colors hover:text-fg-primary">{t('nav.countries')}</a>
      <a href={localizedPath('/plataforma/crunchyroll')} class="transition-colors hover:text-fg-primary">{t('nav.platforms')}</a>
      <a href={localizedPath('/premium')} class="transition-colors hover:text-fg-primary">{t('nav.premium')}</a>
    </nav>
    <div class="flex items-center gap-3">
      <SearchBox />
      <a
        href={localizedPath('/mi-lista')}
        aria-label={t('library.nav')}
        title={t('library.nav')}
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-fg-secondary transition-colors hover:text-accent-pink"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5">
          <path d="M12 21s-7.4-4.6-10-9.3C.6 8.9 1.7 5.6 4.6 4.7 6.6 4.1 8.7 4.8 12 8c3.3-3.2 5.4-3.9 7.4-3.3 2.9.9 4 4.2 2.6 7C19.4 16.4 12 21 12 21z" />
        </svg>
      </a>
      {showLanguageSwitcher && <LanguageSwitcher />}
      <ThemeToggle />
      <details class="relative md:hidden">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-md border border-surface-2 bg-surface-1 text-fg-secondary transition-colors hover:text-fg-primary [&::-webkit-details-marker]:hidden"
          aria-label={t('nav.menu')}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="h-5 w-5">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full z-50 mt-2 flex w-52 flex-col gap-1 rounded-md border border-surface-2 bg-surface-1 p-2 text-sm text-fg-secondary shadow-lg">
          <a href={localizedPath('/')} class="rounded px-3 py-2 transition-colors hover:bg-surface-2 hover:text-fg-primary">{t('nav.catalog')}</a>
          {isSpanish && <a href="/listas" class="rounded px-3 py-2 transition-colors hover:bg-surface-2 hover:text-fg-primary">{t('nav.lists')}</a>}
          <a href={localizedPath('/pais/espana')} class="rounded px-3 py-2 transition-colors hover:bg-surface-2 hover:text-fg-primary">{t('nav.countries')}</a>
          <a href={localizedPath('/plataforma/crunchyroll')} class="rounded px-3 py-2 transition-colors hover:bg-surface-2 hover:text-fg-primary">{t('nav.platforms')}</a>
          <a href={localizedPath('/premium')} class="rounded px-3 py-2 transition-colors hover:bg-surface-2 hover:text-fg-primary">{t('nav.premium')}</a>
        </div>
      </details>
    </div>
  </div>
</header>
