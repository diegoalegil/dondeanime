---
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
import SearchBox from '@/components/ui/SearchBox.astro';
---
<header class="sticky top-0 z-50 border-b border-surface-2 bg-surface-1/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="text-xl font-semibold brand-gradient-text">
      DondeAnime
    </a>
    <nav class="hidden items-center gap-5 text-sm text-fg-secondary md:flex">
      <a href="/" class="transition-colors hover:text-fg-primary">Catálogo</a>
      <a href="/pais/espana" class="transition-colors hover:text-fg-primary">Países</a>
      <a href="/plataforma/crunchyroll" class="transition-colors hover:text-fg-primary">Plataformas</a>
      <a href="/premium" class="transition-colors hover:text-fg-primary">Premium</a>
    </nav>
    <div class="flex items-center gap-3">
      <SearchBox />
      <ThemeToggle />
    </div>
  </div>
</header>
