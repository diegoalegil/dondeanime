---
import JsonLd from '@/components/seo/JsonLd.astro';
import { buildBreadcrumbSchema, absoluteUrl, type BreadcrumbItem } from '@/lib/seo';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schema = buildBreadcrumbSchema(
  items.map((i) => ({ name: i.name, url: absoluteUrl(i.url) }))
);
---
<nav class="mx-auto max-w-6xl px-4 pt-4" aria-label="Migas de pan">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-fg-muted">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span aria-hidden="true" class="text-surface-3">/</span>}
        {i < items.length - 1 ? (
          <a href={item.url} class="transition-colors hover:text-fg-primary">
            {item.name}
          </a>
        ) : (
          <span class="text-fg-secondary">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<JsonLd data={schema} />
