---
import type { NewsSummary } from '@/lib/api';
import { localizedPath } from '@/lib/localizedRoutes';
import { getLocale, t } from '@/i18n';

interface Props {
  item: NewsSummary;
}

const { item } = Astro.props;
const href = localizedPath(`/noticias/${item.slug}`);
const date = new Intl.DateTimeFormat(getLocale() === 'en' ? 'en-US' : 'es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(item.publishedAt));
---
<article class="group overflow-hidden rounded-lg border border-surface-2 bg-surface-1">
  <a href={href} class="flex h-full flex-col">
    {item.imageUrl && (
      <div class="relative aspect-[16/9] overflow-hidden bg-surface-2">
        <img
          src={item.imageUrl}
          alt={item.title}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    )}
    <div class="flex flex-1 flex-col p-4">
      <p class="text-xs text-fg-muted">{item.sourceName} • {date}</p>
      <h3 class="mt-2 line-clamp-2 text-base font-semibold text-fg-primary transition-colors group-hover:text-accent-violet">
        {item.title}
      </h3>
      {item.summary && <p class="mt-2 line-clamp-3 text-sm text-fg-secondary">{item.summary}</p>}
      <span class="mt-3 text-sm font-medium text-accent-violet">{t('news.card.readMore')} →</span>
    </div>
  </a>
</article>
