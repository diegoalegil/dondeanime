---
import type { AnimeCharacter } from '@/lib/api';
import { t } from '@/i18n';

interface Props {
  characters?: AnimeCharacter[];
}

const characters = Astro.props.characters ?? [];
---
{characters.length > 0 && (
  <section class="mx-auto max-w-6xl px-4 py-8">
    <h2 class="mb-4 text-lg font-semibold text-fg-primary">{t('anime.characters.title')}</h2>
    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {characters.map((character) => (
        <li class="flex min-h-24 items-center gap-4 rounded-lg border border-surface-2 bg-surface-1 p-3">
          {character.image ? (
            <img
              src={character.image}
              alt={character.name}
              class="h-16 w-16 shrink-0 rounded-md object-cover"
              loading="lazy"
            />
          ) : (
            <div class="h-16 w-16 shrink-0 rounded-md bg-surface-2" aria-hidden="true"></div>
          )}
          <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-fg-primary">{character.name}</p>
            <p class="mt-1 text-xs uppercase tracking-wide text-fg-muted">{character.role}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>
)}
