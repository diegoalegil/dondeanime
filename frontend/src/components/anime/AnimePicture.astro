---
import {
  DEFAULT_ANIME_IMAGE_QUALITY,
  DEFAULT_ANIME_IMAGE_SIZES,
  DEFAULT_ANIME_IMAGE_WIDTHS,
  buildAnimeImageSrcset,
  buildAnimeImageUrl,
  canOptimizeAnimeImage,
  normalizeImageWidths,
} from '@/lib/images';

interface Props {
  src: string;
  alt?: string;
  class?: string;
  imgClass?: string;
  widths?: number[];
  sizes?: string;
  width?: number;
  height?: number;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
  fetchpriority?: 'high' | 'low' | 'auto';
  quality?: number;
  ariaHidden?: boolean;
  fallbackSrc?: string;
}

const {
  src,
  alt = '',
  class: className = 'block',
  imgClass = '',
  widths = DEFAULT_ANIME_IMAGE_WIDTHS,
  sizes = DEFAULT_ANIME_IMAGE_SIZES,
  width,
  height,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  quality = DEFAULT_ANIME_IMAGE_QUALITY,
  ariaHidden = false,
  fallbackSrc,
} = Astro.props;

const canUseSrcset = canOptimizeAnimeImage(src);
const normalizedWidths = normalizeImageWidths(widths);
const fallbackWidth = normalizedWidths[Math.min(1, normalizedWidths.length - 1)] ?? width ?? 320;
const imageAlt = ariaHidden ? '' : alt;
const optimizedSrc = buildAnimeImageUrl(src, fallbackWidth, quality);
const optimizedSrcset = buildAnimeImageSrcset(src, normalizedWidths, quality);
// Si la carátula no carga (AniList throttla covers en ráfaga) caemos al placeholder de marca.
const onCoverError = fallbackSrc
  ? `this.onerror=null;this.removeAttribute('srcset');this.removeAttribute('sizes');this.src='${fallbackSrc}';`
  : undefined;
---
<picture class={className} aria-hidden={ariaHidden ? 'true' : undefined}>
  <img
    src={optimizedSrc}
    srcset={optimizedSrcset}
    sizes={canUseSrcset ? sizes : undefined}
    alt={imageAlt}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={imgClass}
    data-cover={canUseSrcset ? '' : undefined}
    onerror={onCoverError}
  />
</picture>
