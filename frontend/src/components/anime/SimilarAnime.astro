---
import type { AnimeSummary } from '@/lib/api';
import AnimeCard from './AnimeCard.astro';
import { t } from '@/i18n';

interface Props {
  anime: AnimeSummary[];
  sourceSlug: string;
}

const { anime, sourceSlug } = Astro.props;
---
{anime.length > 0 && (
  <section class="mx-auto max-w-6xl px-4 py-8">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-accent-violet">{t('anime.similar.eyebrow')}</p>
        <h2 class="mt-2 text-xl font-semibold text-fg-primary">{t('anime.similar.title')}</h2>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5 lg:grid-cols-5">
      {anime.slice(0, 10).map((item) => <AnimeCard anime={item} recommendationSourceSlug={sourceSlug} />)}
    </div>
  </section>
)}
