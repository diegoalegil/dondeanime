---
import type { AnimeSummary } from '@/lib/api';
import AnimeCard from './AnimeCard.astro';

interface Props {
  anime: AnimeSummary[];
}

const { anime } = Astro.props;
---
{anime.length > 0 && (
  <section class="mx-auto max-w-6xl px-4 py-8">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-accent-violet">Recomendaciones</p>
        <h2 class="mt-2 text-xl font-semibold text-fg-primary">Anime similares</h2>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5 lg:grid-cols-5">
      {anime.slice(0, 10).map((item) => <AnimeCard anime={item} />)}
    </div>
  </section>
)}
