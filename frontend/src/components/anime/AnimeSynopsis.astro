---
import { t } from '@/i18n';
import { sanitizeHtml } from '@/lib/sanitizeHtml';

interface Props {
  description: string | null;
  translationPending?: boolean;
}

const { description, translationPending = false } = Astro.props;
// La descripción puede venir de la API o de un override editorial del admin.
// Sanitizamos antes del set:html para no permitir XSS almacenado.
const safeDescription = sanitizeHtml(description);
---
{safeDescription && (
  <section class="mx-auto max-w-6xl px-4 py-8">
    <div class="mb-4 flex flex-wrap items-center gap-3">
      <h2 class="text-lg font-semibold text-fg-primary">{t('anime.synopsis.title')}</h2>
      {translationPending && (
        <span class="rounded-full border border-amber-400/40 bg-amber-400/10 px-3 py-1 text-xs font-medium text-amber-200">
          {t('anime.synopsis.translationPending')}
        </span>
      )}
    </div>
    <div
      class="max-w-3xl text-base leading-relaxed text-fg-secondary"
      set:html={safeDescription}
    />
  </section>
)}
