---
import type { AnimeDetail } from '@/lib/api';
import { formatType, formatStatus } from '@/lib/format';
import { genreSlug } from '@/lib/programmaticSeo';
import { localizedGenreName } from '@/lib/genres';
import { t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';
import AnimePicture from './AnimePicture.astro';
import FavoriteButton from './FavoriteButton.astro';
import { HERO_COVER_SIZES } from '@/lib/images';

interface Props {
  anime: AnimeDetail['anime'];
}

const { anime } = Astro.props;
const title = anime.titleEnglish || anime.titleRomaji;
const hasDistinctRomaji = anime.titleRomaji && anime.titleRomaji !== anime.titleEnglish;
const backdropImage = anime.bannerImage ?? anime.coverImage;
---
<section class="relative">
  <div class="absolute inset-0 overflow-hidden">
    <AnimePicture
      src={backdropImage}
      ariaHidden
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      class="block h-full w-full"
      imgClass="h-full w-full object-cover opacity-30 blur-2xl scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-surface-0/60 via-surface-0/80 to-surface-0"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 pt-12 pb-8 md:pt-16">
    <div class="flex flex-col gap-6 md:flex-row md:gap-10">
      <div class="mx-auto w-40 shrink-0 md:mx-0 md:w-56">
        <AnimePicture
          src={anime.coverImage}
          alt={title}
          width={448}
          height={672}
          widths={[224, 320, 448, 640]}
          sizes={HERO_COVER_SIZES}
          loading="eager"
          fetchpriority="high"
          class="block"
          imgClass="aspect-[2/3] w-full rounded-xl object-cover shadow-2xl shadow-black/50"
        />
      </div>

      <div class="flex-1 text-center md:text-left">
        <h1 class="text-3xl font-semibold tracking-tight md:text-5xl">
          {title}
        </h1>
        {hasDistinctRomaji && (
          <p class="mt-2 text-sm text-fg-muted md:text-base">{anime.titleRomaji}</p>
        )}

        <div class="mt-5 flex flex-wrap justify-center gap-2 md:justify-start">
          <span class="rounded-md bg-surface-2 px-2.5 py-1 text-xs font-medium text-fg-secondary">
            {formatType(anime.format)}
          </span>
          {anime.startYear && (
            <span class="rounded-md bg-surface-2 px-2.5 py-1 text-xs font-medium text-fg-secondary">
              {anime.startYear}
            </span>
          )}
          {anime.episodes !== null && (
            <span class="rounded-md bg-surface-2 px-2.5 py-1 text-xs font-medium text-fg-secondary">
              {anime.episodes} {anime.episodes === 1 ? t('anime.hero.episode.one') : t('anime.hero.episode.other')}
            </span>
          )}
          <span class="rounded-md bg-surface-2 px-2.5 py-1 text-xs font-medium text-fg-secondary">
            {formatStatus(anime.status)}
          </span>
          {anime.averageScore !== null && (
            <span class="rounded-md bg-accent-violet/15 px-2.5 py-1 text-xs font-semibold text-accent-violet">
              {anime.averageScore} / 100
            </span>
          )}
        </div>

        {anime.genres.length > 0 && (
          <div class="mt-4 flex flex-wrap justify-center gap-1.5 md:justify-start">
            {anime.genres.map((g) => (
              <a
                href={localizedPath(`/genero/${genreSlug(g)}`)}
                class="rounded-full border border-surface-2 px-3 py-1 text-xs text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary"
              >
                {localizedGenreName(genreSlug(g), g)}
              </a>
            ))}
          </div>
        )}

        <div class="mt-6 flex justify-center md:justify-start">
          <FavoriteButton
            slug={anime.slug}
            title={title}
            image={anime.coverImage}
            score={anime.averageScore}
            format={anime.format}
            year={anime.startYear}
            track={true}
          />
        </div>
      </div>
    </div>
  </div>
</section>
