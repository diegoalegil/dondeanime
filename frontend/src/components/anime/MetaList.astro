---
import type { AnimeDetail } from '@/lib/api';
import { formatType, formatStatus, formatDate, formatSeasonYear, formatNumber } from '@/lib/format';
import { t } from '@/i18n';

interface Props {
  anime: AnimeDetail['anime'];
}

const { anime } = Astro.props;
const studios = anime.studios ?? [];

const rows: Array<{ label: string; value: string; mono?: boolean }> = [
  { label: t('anime.meta.format'), value: formatType(anime.format) },
  { label: t('anime.meta.status'), value: formatStatus(anime.status) },
  { label: t('anime.meta.episodes'), value: anime.episodes !== null ? String(anime.episodes) : '—', mono: true },
  { label: t('anime.meta.start'), value: formatDate(anime.startYear, anime.startMonth, anime.startDay), mono: true },
  { label: t('anime.meta.end'), value: formatDate(anime.endYear, anime.endMonth, anime.endDay), mono: true },
  { label: t('anime.meta.season'), value: formatSeasonYear(anime.season, anime.seasonYear) },
  { label: t('anime.meta.score'), value: anime.averageScore !== null ? `${anime.averageScore} / 100` : '—', mono: true },
  { label: t('anime.meta.popularity'), value: formatNumber(anime.popularity), mono: true },
];
---
<section class="mx-auto max-w-6xl px-4 py-8">
  <h2 class="mb-4 text-lg font-semibold text-fg-primary">{t('anime.meta.title')}</h2>
  <dl class="grid grid-cols-2 gap-4 rounded-lg border border-surface-2 bg-surface-1 p-6 sm:grid-cols-3 md:grid-cols-4">
    {rows.map((row) => (
      <div>
        <dt class="text-xs uppercase tracking-wide text-fg-muted">{row.label}</dt>
        <dd class={`mt-1 text-sm text-fg-primary ${row.mono ? 'font-mono' : ''}`}>
          {row.value}
        </dd>
      </div>
    ))}
  </dl>
</section>
{studios.length > 0 && (
  <section class="mx-auto max-w-6xl px-4 pb-8">
    <h2 class="mb-4 text-lg font-semibold text-fg-primary">Estudios</h2>
    <div class="flex flex-wrap gap-2">
      {studios.map((studio) => (
        <a
          href={`/estudio/${studio.slug}`}
          class="rounded-full border border-surface-2 bg-surface-1 px-4 py-2 text-sm text-fg-secondary transition-colors hover:border-accent-violet hover:text-fg-primary"
        >
          {studio.name}
        </a>
      ))}
    </div>
  </section>
)}
