---
interface Props {
  position?: 'sidebar' | 'inline' | 'footer';
  slot?: string;
}

const { position = 'sidebar', slot } = Astro.props;
const enabled =
  import.meta.env.ADSENSE_ENABLED === 'true' ||
  import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const clientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
const slotByPosition = {
  sidebar: import.meta.env.PUBLIC_ADSENSE_SIDEBAR_SLOT,
  inline: import.meta.env.PUBLIC_ADSENSE_INLINE_SLOT,
  footer: import.meta.env.PUBLIC_ADSENSE_FOOTER_SLOT,
};
const adSlot = slot ?? slotByPosition[position];
const shouldRender = enabled && clientId && adSlot;
const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
---
{shouldRender && (
  <aside
    class="mx-auto max-w-6xl px-4 py-6"
    data-ad-position={position}
    data-ad-client={clientId}
    data-ad-slot={adSlot}
    data-api-url={apiUrl}
  >
    <script is:inline>
      (async () => {
        const script = document.currentScript;
        const container = script?.closest('[data-ad-position]');
        if (!container) return;

        const mountAd = () => {
          const ad = document.createElement('ins');
          ad.className = 'adsbygoogle';
          ad.style.display = 'block';
          ad.setAttribute('data-ad-client', container.getAttribute('data-ad-client') || '');
          ad.setAttribute('data-ad-slot', container.getAttribute('data-ad-slot') || '');
          ad.setAttribute('data-ad-format', 'auto');
          ad.setAttribute('data-full-width-responsive', 'true');
          container.insertBefore(ad, script);
          (window.adsbygoogle = window.adsbygoogle || []).push({});
        };

        try {
          const apiUrl = container.getAttribute('data-api-url') || '';
          const token = localStorage.getItem('dondeanime-premium-token') || '';
          if (apiUrl && token) {
            const response = await fetch(`${apiUrl}/api/premium/status`, {
              headers: { Authorization: `Bearer ${token}` },
            });
            const status = response.ok ? await response.json() : null;
            if (status?.premium === true) {
              container.remove();
              return;
            }
            localStorage.removeItem('dondeanime-premium-token');
            localStorage.removeItem('dondeanime-premium-tier');
            localStorage.removeItem('dondeanime-premium-expires-at');
          }
        } catch (error) {}

        mountAd();
      })();
    </script>
  </aside>
)}
