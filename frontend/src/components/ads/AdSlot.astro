---
interface Props {
  position?: 'sidebar' | 'inline' | 'footer';
  slot?: string;
}

const { position = 'sidebar', slot } = Astro.props;
const enabled =
  import.meta.env.ADSENSE_ENABLED === 'true' ||
  import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const clientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
const slotByPosition = {
  sidebar: import.meta.env.PUBLIC_ADSENSE_SIDEBAR_SLOT,
  inline: import.meta.env.PUBLIC_ADSENSE_INLINE_SLOT,
  footer: import.meta.env.PUBLIC_ADSENSE_FOOTER_SLOT,
};
const adSlot = slot ?? slotByPosition[position];
const shouldRender = enabled && clientId && adSlot;
---
{shouldRender && (
  <aside class="mx-auto max-w-6xl px-4 py-6" data-ad-position={position}>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={clientId}
      data-ad-slot={adSlot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </aside>
)}
