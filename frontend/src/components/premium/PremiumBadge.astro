---
interface Props {
  label?: string;
}

const { label = 'Premium activo' } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
---
<span
  class="hidden items-center gap-2 rounded-md border border-warning/40 bg-warning/10 px-2.5 py-1 text-xs font-semibold text-warning"
  data-premium-badge
  data-api-url={apiUrl}
>
  <span class="h-1.5 w-1.5 rounded-full bg-warning"></span>
  <span data-premium-badge-label>{label}</span>
</span>

<script>
  const badge = document.querySelector('[data-premium-badge]');
  const label = document.querySelector('[data-premium-badge-label]');

  (async () => {
    if (!(badge instanceof HTMLElement)) return;

    try {
      const apiUrl = badge.getAttribute('data-api-url') || '';
      const token = localStorage.getItem('dondeanime-premium-token') || '';
      if (!apiUrl || !token) return;

      const response = await fetch(`${apiUrl}/api/premium/status`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const status = response.ok ? await response.json() : null;
      if (status?.premium === true) {
        const tier = status.planTier || localStorage.getItem('dondeanime-premium-tier') || 'Premium';
        localStorage.setItem('dondeanime-premium-tier', tier);
        if (status.expiresAt) {
          localStorage.setItem('dondeanime-premium-expires-at', status.expiresAt);
        }
        if (label) label.textContent = `${tier} activo`;
        badge.classList.remove('hidden');
        badge.classList.add('inline-flex');
        return;
      }

      localStorage.removeItem('dondeanime-premium-token');
      localStorage.removeItem('dondeanime-premium-tier');
      localStorage.removeItem('dondeanime-premium-expires-at');
    } catch (error) {
      // LocalStorage o red pueden estar bloqueados; el badge se queda oculto.
    }
  })();
</script>
