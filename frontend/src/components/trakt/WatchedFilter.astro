---
import WatchedFilterIsland from './WatchedFilter.svelte';

// Apagado por defecto: el filtro "ya visto" depende de Trakt, deshabilitado en
// prod. Sin el flag la isla solo enviaria JS muerto a cada pagina (mismo patron
// que AnimeChatSearch / AdSense / Plausible).
const traktEnabled = import.meta.env.PUBLIC_TRAKT_ENABLED === 'true';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
---
{traktEnabled && <WatchedFilterIsland apiUrl={apiUrl} client:load />}
