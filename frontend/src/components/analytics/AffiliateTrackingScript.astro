---
const apiUrl = import.meta.env.PUBLIC_API_URL;
---
<script define:vars={{ apiUrl }}>
  (() => {
    if (window.__dondeAnimeAffiliateTracking) return;
    window.__dondeAnimeAffiliateTracking = true;

    const sendTracking = (path, payload) => {
      const url = `${apiUrl}${path}`;
      const body = JSON.stringify(payload);

      if (navigator.sendBeacon) {
        const blob = new Blob([body], { type: 'application/json' });
        navigator.sendBeacon(url, blob);
        return;
      }

      fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body,
        keepalive: true,
      }).catch(() => {});
    };

    document.addEventListener('click', (event) => {
      const link = event.target?.closest?.('[data-affiliate-link="true"]');
      if (link) {
        const providerSlug = link.getAttribute('data-affiliate-provider') ?? '';
        const country = link.getAttribute('data-affiliate-country') ?? '';
        const animeSlug = link.getAttribute('data-affiliate-anime') ?? '';
        if (providerSlug && country && animeSlug) {
          sendTracking('/api/track/affiliate', { providerSlug, country, animeSlug });

          if (typeof window.plausible === 'function') {
            window.plausible('Affiliate Click', {
              props: { provider: providerSlug, country },
            });
          }
        }
      }

      const recommendationLink = event.target?.closest?.('[data-recommendation-link="true"]');
      if (!recommendationLink) return;

      const sourceAnimeSlug = recommendationLink.getAttribute('data-recommendation-source') ?? '';
      const targetAnimeSlug = recommendationLink.getAttribute('data-recommendation-target') ?? '';
      if (!sourceAnimeSlug || !targetAnimeSlug) return;

      sendTracking('/api/track/recommendation', { sourceAnimeSlug, targetAnimeSlug });

      if (typeof window.plausible === 'function') {
        window.plausible('Recommendation Click', {
          props: { source: sourceAnimeSlug, target: targetAnimeSlug },
        });
      }
    });
  })();
</script>
