---
import type { WatchProvider } from '@/lib/api';
import PlatformBadge from './PlatformBadge.astro';
import { formatProviderType } from '@/lib/format';

interface Props {
  provider: WatchProvider;
}

const { provider } = Astro.props;

const typeClass =
  provider.providerType === 'FLATRATE' || provider.providerType === 'FREE'
    ? 'bg-success/15 text-success'
    : provider.providerType === 'RENT'
    ? 'bg-warning/15 text-warning'
    : 'bg-surface-2 text-fg-secondary';
---
<div class="flex items-center justify-between rounded-lg border border-surface-2 bg-surface-1 p-3 transition-colors hover:border-accent-violet/40">
  <PlatformBadge provider={provider} />
  <span class={`rounded-md px-2.5 py-1 text-xs font-semibold ${typeClass}`}>
    {formatProviderType(provider.providerType)}
  </span>
</div>
