---
import type { WatchProvider } from '@/lib/api';
import PlatformBadge from './PlatformBadge.astro';
import { formatProviderType } from '@/lib/format';
import { getPlatform } from '@/lib/platforms';
import { t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

interface Props {
  provider: WatchProvider;
  animeSlug?: string;
}

const { provider, animeSlug = '' } = Astro.props;
const platform = getPlatform(provider.providerSlug);
const href = provider.affiliateUrl ?? platform?.url ?? localizedPath(`/plataforma/${provider.providerSlug}`);
const isAffiliate = Boolean(provider.affiliateUrl);

const typeClass =
  provider.providerType === 'FLATRATE' || provider.providerType === 'FREE'
    ? 'bg-success/15 text-success'
    : provider.providerType === 'RENT'
    ? 'bg-warning/15 text-warning'
    : 'bg-surface-2 text-fg-secondary';
---
<a
  href={href}
  target="_blank"
  rel={isAffiliate ? 'noopener noreferrer sponsored' : 'noopener noreferrer'}
  class="flex items-center justify-between rounded-lg border border-surface-2 bg-surface-1 p-3 transition-colors hover:border-accent-violet/40"
  data-affiliate-link={isAffiliate ? 'true' : undefined}
  data-affiliate-provider={isAffiliate ? provider.providerSlug : undefined}
  data-affiliate-country={isAffiliate ? provider.countryCode : undefined}
  data-affiliate-anime={isAffiliate ? animeSlug : undefined}
>
  <PlatformBadge provider={provider} />
  <span class="flex items-center gap-2">
    <span class={`rounded-md px-2.5 py-1 text-xs font-semibold ${typeClass}`}>
      {formatProviderType(provider.providerType)}
    </span>
    <span class="rounded-md border border-surface-2 px-2.5 py-1 text-xs font-semibold text-fg-secondary">
      {t('anime.providerRow.watch')}
    </span>
  </span>
</a>
