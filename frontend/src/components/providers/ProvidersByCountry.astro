---
import type { WatchProvider } from '@/lib/api';
import { COUNTRIES, COUNTRY_SLUGS, type CountrySlug } from '@/lib/countries';
import { filterVisibleProviders } from '@/lib/platforms';
import ProviderRow from './ProviderRow.astro';

interface Props {
  providersByCountry: Record<string, WatchProvider[]>;
  animeSlug: string;
}

const { providersByCountry, animeSlug } = Astro.props;

const blocks = COUNTRY_SLUGS.map((slug: CountrySlug) => {
  const country = COUNTRIES[slug];
  const raw = providersByCountry[country.iso] ?? [];
  const visible = filterVisibleProviders(raw);
  return { slug, country, providers: visible };
});

const hasAnyProvider = blocks.some((b) => b.providers.length > 0);
---
<section class="mx-auto max-w-6xl px-4 py-8">
  <h2 class="mb-6 text-lg font-semibold text-fg-primary">Dónde verlo</h2>

  {!hasAnyProvider && (
    <p class="rounded-lg border border-surface-2 bg-surface-1 p-6 text-sm text-fg-secondary">
      No tenemos información de plataformas para este anime todavía.
    </p>
  )}

  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {blocks.map(({ slug, country, providers }) => (
      <div class="rounded-xl border border-surface-2 bg-surface-1 p-5">
        <header class="mb-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class={`fi fi-${country.flagCode} rounded`} aria-hidden="true"></span>
            <h3 class="text-base font-semibold text-fg-primary">{country.name}</h3>
          </div>
          <a
            href={`/anime/${Astro.params.slug}/${slug}`}
            class="text-xs text-fg-muted transition-colors hover:text-accent-violet"
          >
            Ver más
          </a>
        </header>
        {providers.length === 0 ? (
          <p class="text-sm text-fg-muted">No disponible</p>
        ) : (
          <div class="space-y-2">
            {providers.map((p) => <ProviderRow provider={p} animeSlug={animeSlug} />)}
          </div>
        )}
      </div>
    ))}
  </div>
</section>
