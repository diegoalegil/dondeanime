---
import PushSubscribeButton from './PushSubscribeButton.astro';
import { t } from '@/i18n';
import { localizedPath } from '@/lib/localizedRoutes';

interface Props {
  animeSlug: string;
  animeTitle: string;
  countryIso: string;
  countryName: string;
}

const { animeSlug, animeTitle, countryIso, countryName } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL;
const alertApiUrl = `${apiUrl}/api/alerts`;
---
<section
  class="mx-auto max-w-6xl px-4 pb-8"
  data-alert-form
  data-alert-api-url={alertApiUrl}
  data-anime-slug={animeSlug}
  data-country={countryIso}
  data-status-creating={t('alert.creating')}
  data-status-success={t('alert.success')}
  data-status-error={t('alert.error')}
  data-status-queued={t('alert.queued')}
  data-status-offline-error={t('alert.offlineError')}
>
  <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-lg font-semibold text-fg-primary">{t('alert.title')}</h2>
        <p class="mt-1 text-sm text-fg-muted">
          {t('alert.description', { title: animeTitle, country: countryName })}
        </p>
      </div>
      <button
        type="button"
        class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
        data-open-alert
      >
        {t('alert.open')}
      </button>
    </div>

    <form class="mt-5 hidden gap-4 md:grid-cols-[1fr_auto]" data-alert-panel>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-fg-secondary">{t('alert.email')}</span>
        <input
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none transition-colors focus:border-accent-violet"
        />
      </label>
      <button
        type="submit"
        class="self-end rounded-md bg-accent-pink px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
      >
        {t('alert.submit')}
      </button>
      <label class="flex gap-2 text-sm text-fg-muted md:col-span-2">
        <input type="checkbox" required class="mt-1" />
        <span>
          {t('alert.privacyPrefix')} <a href={localizedPath('/legal/privacidad')} class="text-accent-violet hover:underline">{t('alert.privacyLink')}</a>.
        </span>
      </label>
      <p class="min-h-5 text-sm text-fg-muted md:col-span-2" data-alert-status></p>
    </form>

    <PushSubscribeButton countryIso={countryIso} />
  </div>

  <script>
    const ALERT_SYNC_TAG = 'dondeanime-alerts-sync';
    const ALERT_DB_NAME = 'dondeanime-alerts';
    const ALERT_STORE = 'alerts';

    const openAlertDb = () => new Promise((resolve, reject) => {
      const request = indexedDB.open(ALERT_DB_NAME, 1);

      request.onupgradeneeded = () => {
        const db = request.result;
        if (!db.objectStoreNames.contains(ALERT_STORE)) {
          db.createObjectStore(ALERT_STORE, { keyPath: 'id' });
        }
      };

      request.onsuccess = () => resolve(request.result);
      request.onerror = () => reject(request.error);
    });

    const queueAlert = async (endpoint, payload) => {
      const db = await openAlertDb();
      const id = crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random()}`;

      await new Promise((resolve, reject) => {
        const tx = db.transaction(ALERT_STORE, 'readwrite');
        tx.objectStore(ALERT_STORE).put({
          id,
          endpoint,
          payload,
          createdAt: new Date().toISOString(),
        });
        tx.oncomplete = () => resolve(undefined);
        tx.onerror = () => reject(tx.error);
      });

      db.close();
    };

    const scheduleAlertSync = async () => {
      if (!('serviceWorker' in navigator)) return;

      const registration = await navigator.serviceWorker.ready;
      const syncRegistration = registration.sync;
      if (syncRegistration) {
        await syncRegistration.register(ALERT_SYNC_TAG);
      }
      registration.active?.postMessage({ type: 'SYNC_ALERTS' });
    };

    const requestQueuedAlertNotification = () => {
      if (!('Notification' in window) || Notification.permission !== 'default') return;
      Notification.requestPermission().catch(() => {});
    };

    window.addEventListener('online', () => {
      scheduleAlertSync().catch(() => {});
    });

    // ClientRouter (View Transitions) reemplaza el form en cada navegacion
    // soft; re-enlazamos en cada astro:page-load (dispara en la carga inicial).
    const init = () => document.querySelectorAll('[data-alert-form]').forEach((root) => {
      const alertApiUrl = root.getAttribute('data-alert-api-url') ?? '';
      const animeSlug = root.getAttribute('data-anime-slug') ?? '';
      const country = root.getAttribute('data-country') ?? '';
      const creatingMessage = root.getAttribute('data-status-creating') ?? '';
      const successMessage = root.getAttribute('data-status-success') ?? '';
      const errorMessage = root.getAttribute('data-status-error') ?? '';
      const queuedMessage = root.getAttribute('data-status-queued') ?? '';
      const offlineErrorMessage = root.getAttribute('data-status-offline-error') ?? '';
      const openButton = root.querySelector('[data-open-alert]');
      const panel = root.querySelector('[data-alert-panel]');
      const status = root.querySelector('[data-alert-status]');

      const setStatus = (message, tone = 'muted') => {
        if (!status) return;
        status.textContent = message;
        status.className = `min-h-5 text-sm md:col-span-2 ${
          tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'
        }`;
      };

      openButton?.addEventListener('click', () => {
        // 'hidden' y 'grid' nunca coexisten: al mostrar quitamos hidden y
        // ponemos grid (layout), al ocultar al revés. Evita el conflicto de
        // dos utilidades display en el mismo nodo.
        panel?.classList.toggle('hidden');
        panel?.classList.toggle('grid');
      });

      panel?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const form = event.currentTarget as HTMLFormElement;
        const submitButton = form.querySelector('button[type="submit"]');
        // Evita envíos duplicados por doble click mientras hay petición en curso.
        if (submitButton instanceof HTMLButtonElement && submitButton.disabled) return;
        const data = new FormData(form);
        const email = String(data.get('email') ?? '').trim();
        const payload = { email, animeSlug, country };

        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;
        setStatus(creatingMessage);
        try {
          const response = await fetch(alertApiUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          form.reset();
          setStatus(successMessage, 'success');
        } catch (error) {
          const canQueue = !navigator.onLine || error instanceof TypeError;
          if (canQueue) {
            try {
              await queueAlert(alertApiUrl, payload);
              await scheduleAlertSync();
              requestQueuedAlertNotification();
              form.reset();
              setStatus(queuedMessage, 'success');
              return;
            } catch {
              setStatus(offlineErrorMessage, 'danger');
              return;
            }
          }
          setStatus(errorMessage, 'danger');
        } finally {
          if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
        }
      });
    });

    document.addEventListener('astro:page-load', init);
  </script>
</section>
