---
import PushSubscribeButton from './PushSubscribeButton.astro';

interface Props {
  animeSlug: string;
  animeTitle: string;
  countryIso: string;
  countryName: string;
}

const { animeSlug, animeTitle, countryIso, countryName } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL;
---
<section
  class="mx-auto max-w-6xl px-4 pb-8"
  data-alert-form
  data-api-url={apiUrl}
  data-anime-slug={animeSlug}
  data-country={countryIso}
>
  <div class="rounded-lg border border-surface-2 bg-surface-1 p-5">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-lg font-semibold text-fg-primary">Aviso de disponibilidad</h2>
        <p class="mt-1 text-sm text-fg-muted">
          Recibe un correo cuando {animeTitle} aparezca en plataformas de {countryName}.
        </p>
      </div>
      <button
        type="button"
        class="rounded-md bg-accent-violet px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
        data-open-alert
      >
        Avisarme
      </button>
    </div>

    <form class="mt-5 hidden grid gap-4 md:grid-cols-[1fr_auto]" data-alert-panel>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-fg-secondary">Email</span>
        <input
          name="email"
          type="email"
          required
          autocomplete="email"
          class="w-full rounded-md border border-surface-2 bg-surface-0 px-3 py-2 text-sm text-fg-primary outline-none transition-colors focus:border-accent-violet"
        />
      </label>
      <button
        type="submit"
        class="self-end rounded-md bg-accent-pink px-4 py-2 text-sm font-semibold text-surface-0 transition-opacity hover:opacity-90"
      >
        Crear alerta
      </button>
      <label class="flex gap-2 text-sm text-fg-muted md:col-span-2">
        <input type="checkbox" required class="mt-1" />
        <span>
          Acepto la <a href="/legal/privacidad" class="text-accent-violet hover:underline">política de privacidad</a>.
        </span>
      </label>
      <p class="min-h-5 text-sm text-fg-muted md:col-span-2" data-alert-status></p>
    </form>

    <PushSubscribeButton countryIso={countryIso} />
  </div>

  <script>
    document.querySelectorAll('[data-alert-form]').forEach((root) => {
      const apiUrl = root.getAttribute('data-api-url') ?? '';
      const animeSlug = root.getAttribute('data-anime-slug') ?? '';
      const country = root.getAttribute('data-country') ?? '';
      const openButton = root.querySelector('[data-open-alert]');
      const panel = root.querySelector('[data-alert-panel]');
      const status = root.querySelector('[data-alert-status]');

      const setStatus = (message, tone = 'muted') => {
        if (!status) return;
        status.textContent = message;
        status.className = `min-h-5 text-sm md:col-span-2 ${
          tone === 'danger' ? 'text-danger' : tone === 'success' ? 'text-success' : 'text-fg-muted'
        }`;
      };

      openButton?.addEventListener('click', () => {
        panel?.classList.toggle('hidden');
      });

      panel?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        const data = new FormData(form);
        const email = String(data.get('email') ?? '').trim();

        setStatus('Creando alerta...');
        try {
          const response = await fetch(`${apiUrl}/api/subscriptions`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, animeSlug, country }),
          });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          form.reset();
          setStatus('Te hemos enviado un correo de confirmación.', 'success');
        } catch {
          setStatus('No se pudo crear la alerta. Inténtalo de nuevo.', 'danger');
        }
      });
    });
  </script>
</section>
