---
import { t } from '@/i18n';
---
<div class="relative" data-search-root data-no-results={t('search.noResults')}>
  <label class="sr-only" for="search-input">{t('search.label')}</label>
  <div class="flex items-center gap-2 rounded-md border border-surface-2 bg-surface-1 px-3 py-1.5">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-4 w-4 text-fg-muted"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="7" />
      <path d="m21 21-4.3-4.3" />
    </svg>
    <input
      id="search-input"
      type="search"
      placeholder={t('search.placeholder')}
      autocomplete="off"
      class="w-32 bg-transparent text-sm text-fg-primary placeholder:text-fg-muted focus:outline-none md:w-48"
      data-search-input
    />
  </div>

  <div
    class="absolute right-0 top-full z-50 mt-2 hidden max-h-[60vh] w-80 overflow-y-auto rounded-lg border border-surface-2 bg-surface-1 shadow-2xl shadow-black/40"
    data-search-results
  ></div>
</div>

<script>
  interface SearchEntry {
    slug: string;
    en: string;
    jp: string;
    year: number | null;
    format: string;
    cover: string;
  }

  const root = document.querySelector('[data-search-root]') as HTMLElement | null;
  const input = root?.querySelector('[data-search-input]') as HTMLInputElement | null;
  const panel = root?.querySelector('[data-search-results]') as HTMLElement | null;

  if (root && input && panel) {
    let index: SearchEntry[] | null = null;
    let loading = false;

    const normalize = (s: string) =>
      s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

    const load = async () => {
      if (index || loading) return;
      loading = true;
      try {
        const res = await fetch('/search-index.json');
        index = await res.json();
      } catch (e) {
        console.error('Search index failed:', e);
      } finally {
        loading = false;
      }
    };

    const render = (q: string) => {
      if (!index || !q.trim()) {
        panel.classList.add('hidden');
        panel.innerHTML = '';
        return;
      }
      const qn = normalize(q);
      const matches = index
        .filter((a) =>
          normalize(a.en).includes(qn) ||
          normalize(a.jp).includes(qn) ||
          a.slug.includes(qn),
        )
        .slice(0, 8);

      if (matches.length === 0) {
        panel.innerHTML = `<p class="px-4 py-3 text-sm text-fg-muted">${root.dataset.noResults}</p>`;
        panel.classList.remove('hidden');
        return;
      }

      panel.innerHTML = matches
        .map(
          (a) => `
          <a href="/anime/${a.slug}" class="flex items-center gap-3 border-b border-surface-2/50 px-3 py-2 last:border-b-0 transition-colors hover:bg-surface-2">
            <img src="${a.cover}" alt="" loading="lazy" class="h-12 w-9 rounded object-cover ring-1 ring-surface-2" />
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-semibold text-fg-primary">${a.en}</p>
              <p class="truncate text-xs text-fg-muted">${a.year ?? '—'} · ${a.format}</p>
            </div>
          </a>`,
        )
        .join('');
      panel.classList.remove('hidden');
    };

    input.addEventListener('focus', () => { void load(); });
    input.addEventListener('input', () => {
      void load().then(() => render(input.value));
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        panel.classList.add('hidden');
      }
    });
  }
</script>
