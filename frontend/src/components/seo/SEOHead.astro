---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  locale?: string;
  // Cuando una página canonicaliza a OTRA URL (p.ej. país sin providers → ficha
  // base) no debe emitir hreflang propio: un clúster hreflang con una URL no
  // canónica hace que Google lo descarte. true = no emitir alternates.
  suppressAlternates?: boolean;
}

import { localeFromPath, setLocale, t } from '@/i18n';
import { localeAlternates } from '@/lib/localizedRoutes';

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  locale,
  suppressAlternates = false,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const cleanPathname = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonicalUrl = canonical ?? new URL(cleanPathname || '/', siteUrl).toString();
const ogImage = image ?? `${siteUrl}/og-default.png`;
const activeLocale = localeFromPath(Astro.url.pathname);
setLocale(activeLocale);
const ogLocale = activeLocale === 'en' ? 'en_US' : locale ?? 'es_ES';
const ogLocaleAlternates = activeLocale === 'en' ? ['es_ES'] : ['en_US'];
const alternates = localeAlternates(cleanPathname || '/');
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={t('brand.name')} />
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternates.map((alternateLocale) => (
  <meta property="og:locale:alternate" content={alternateLocale} />
))}

{!suppressAlternates && alternates.map((alternate) => (
  <link rel="alternate" hreflang={alternate.hreflang} href={new URL(alternate.path, siteUrl).toString()} />
))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
