{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "images": {
    "sizes": [160, 224, 240, 320, 448, 480, 640, 960, 1280, 1920],
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "s4.anilist.co",
        "port": "",
        "pathname": "^/file/anilistcdn/media/anime/.*$"
      }
    ],
    "minimumCacheTTL": 604800,
    "qualities": [75],
    "formats": ["image/avif", "image/webp"]
  },
  "trailingSlash": false
}
